DataPropertyAssertion(<http://qudt.org/schema/qudt/allowedPattern> <http://qudt.org/schema/qudt/ISO8601-UTCDateTime-BasicFormat> "[0-9]{4}[0-9]{2}[0-9]{2}T[0-9]{2}[0-9]{2}[0-9]{2}.[0-9]+Z")
DataPropertyAssertion(<http://qudt.org/schema/qudt/allowedPattern> <http://qudt.org/schema/qudt/ISO8601-UTCDateTime-BasicFormat> "[0-9]{4}[0-9]{2}[0-9]{2}T[0-9]{2}[0-9]{2}[0-9]{2}Z")

