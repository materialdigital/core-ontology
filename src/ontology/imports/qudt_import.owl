############################
#   Classes
############################

# Class: <http://qudt.org/schema/qudt/Aspect> (QUDT Aspect)

AnnotationAssertion(rdfs:comment <http://qudt.org/schema/qudt/Aspect> "An aspect is an abstract type class that defines properties that can be reused."^^rdf:HTML)
AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/Aspect> "QUDT Aspect")

# Class: <http://qudt.org/schema/qudt/AspectClass> (Aspect Class)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/AspectClass> "Aspect Class")
SubClassOf(<http://qudt.org/schema/qudt/AspectClass> rdfs:Class)

# Class: <http://qudt.org/schema/qudt/BitEncodingType> (Bit Encoding)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/BitEncodingType> "Bit Encoding")
EquivalentClasses(<http://qudt.org/schema/qudt/BitEncodingType> ObjectOneOf(<http://qudt.org/schema/qudt/BitEncoding>))
SubClassOf(<http://qudt.org/schema/qudt/BitEncodingType> <http://qudt.org/schema/qudt/Encoding>)

# Class: <http://qudt.org/schema/qudt/BooleanEncodingType> (Boolean encoding type)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/BooleanEncodingType> "Boolean encoding type")
EquivalentClasses(<http://qudt.org/schema/qudt/BooleanEncodingType> ObjectOneOf(<http://qudt.org/schema/qudt/BitEncoding> <http://qudt.org/schema/qudt/BooleanEncoding> <http://qudt.org/schema/qudt/OctetEncoding>))
SubClassOf(<http://qudt.org/schema/qudt/BooleanEncodingType> <http://qudt.org/schema/qudt/Encoding>)

# Class: <http://qudt.org/schema/qudt/ByteEncodingType> (Byte Encoding)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/ByteEncodingType> "Byte Encoding")
SubClassOf(<http://qudt.org/schema/qudt/ByteEncodingType> <http://qudt.org/schema/qudt/Encoding>)

# Class: <http://qudt.org/schema/qudt/CardinalityType> (Cardinality Type)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/CardinalityType> "Cardinality Type")
EquivalentClasses(<http://qudt.org/schema/qudt/CardinalityType> ObjectOneOf(<http://qudt.org/schema/qudt/CT_COUNTABLY-INFINITE> <http://qudt.org/schema/qudt/CT_FINITE> <http://qudt.org/schema/qudt/CT_UNCOUNTABLE>))
SubClassOf(<http://qudt.org/schema/qudt/CardinalityType> <http://qudt.org/schema/qudt/EnumeratedValue>)
SubClassOf(<http://qudt.org/schema/qudt/CardinalityType> DataMaxCardinality(1 <http://www.linkedmodel.org/schema/dtype#literal>))

# Class: <http://qudt.org/schema/qudt/CharEncodingType> (Char Encoding Type)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/CharEncodingType> "Char Encoding Type")
EquivalentClasses(<http://qudt.org/schema/qudt/CharEncodingType> ObjectOneOf(<http://qudt.org/schema/qudt/CharEncoding>))
SubClassOf(<http://qudt.org/schema/qudt/CharEncodingType> <http://qudt.org/schema/qudt/Encoding>)

# Class: <http://qudt.org/schema/qudt/Concept> (QUDT Concept)

AnnotationAssertion(rdfs:comment <http://qudt.org/schema/qudt/Concept> "The root class for all QUDT concepts."^^rdf:HTML)
AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/Concept> "QUDT Concept")
SubClassOf(<http://qudt.org/schema/qudt/Concept> ObjectMaxCardinality(1 <http://purl.org/dc/terms/isReplacedBy>))
SubClassOf(<http://qudt.org/schema/qudt/Concept> DataMaxCardinality(1 <http://purl.org/dc/terms/description>))
SubClassOf(<http://qudt.org/schema/qudt/Concept> DataMaxCardinality(1 <http://qudt.org/schema/qudt/deprecated>))
SubClassOf(<http://qudt.org/schema/qudt/Concept> DataMaxCardinality(1 <http://qudt.org/schema/qudt/plainTextDescription>))

# Class: <http://qudt.org/schema/qudt/DateTimeStringEncodingType> (Date Time String Encoding Type)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/DateTimeStringEncodingType> "Date Time String Encoding Type")
SubClassOf(<http://qudt.org/schema/qudt/DateTimeStringEncodingType> <http://qudt.org/schema/qudt/StringEncodingType>)
SubClassOf(<http://qudt.org/schema/qudt/DateTimeStringEncodingType> DataMinCardinality(1 <http://qudt.org/schema/qudt/allowedPattern>))

# Class: <http://qudt.org/schema/qudt/Encoding> (Encoding)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/Encoding> "Encoding")
SubClassOf(<http://qudt.org/schema/qudt/Encoding> <http://qudt.org/schema/qudt/Concept>)
SubClassOf(<http://qudt.org/schema/qudt/Encoding> DataMaxCardinality(1 <http://qudt.org/schema/qudt/bits>))
SubClassOf(<http://qudt.org/schema/qudt/Encoding> DataMaxCardinality(1 <http://qudt.org/schema/qudt/bytes>))

# Class: <http://qudt.org/schema/qudt/EndianType> (Endian Type)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/EndianType> "Endian Type")
EquivalentClasses(<http://qudt.org/schema/qudt/EndianType> ObjectOneOf(<http://qudt.org/vocab/type/BigEndian> <http://qudt.org/vocab/type/LittleEndian>))
SubClassOf(<http://qudt.org/schema/qudt/EndianType> <http://qudt.org/schema/qudt/EnumeratedValue>)

# Class: <http://qudt.org/schema/qudt/EnumeratedValue> (Enumerated Value)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/EnumeratedValue> "Enumerated Value")
SubClassOf(<http://qudt.org/schema/qudt/EnumeratedValue> <http://qudt.org/schema/qudt/Concept>)
SubClassOf(<http://qudt.org/schema/qudt/EnumeratedValue> <http://qudt.org/schema/qudt/Verifiable>)
SubClassOf(<http://qudt.org/schema/qudt/EnumeratedValue> <http://www.linkedmodel.org/schema/dtype#EnumeratedValue>)
SubClassOf(<http://qudt.org/schema/qudt/EnumeratedValue> DataMaxCardinality(1 <http://purl.org/dc/terms/description>))

# Class: <http://qudt.org/schema/qudt/FloatingPointEncodingType> (Floating Point Encoding)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/FloatingPointEncodingType> "Floating Point Encoding")
SubClassOf(<http://qudt.org/schema/qudt/FloatingPointEncodingType> <http://qudt.org/schema/qudt/Encoding>)

# Class: <http://qudt.org/schema/qudt/IntegerEncodingType> (Integer Encoding)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/IntegerEncodingType> "Integer Encoding")
EquivalentClasses(<http://qudt.org/schema/qudt/IntegerEncodingType> ObjectOneOf(<http://qudt.org/schema/qudt/LongUnsignedIntegerEncoding> <http://qudt.org/schema/qudt/ShortUnsignedIntegerEncoding> <http://qudt.org/schema/qudt/SignedIntegerEncoding> <http://qudt.org/schema/qudt/UnsignedIntegerEncoding>))
SubClassOf(<http://qudt.org/schema/qudt/IntegerEncodingType> <http://qudt.org/schema/qudt/Encoding>)

# Class: <http://qudt.org/schema/qudt/NumericUnion> (Numeric union)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/NumericUnion> "Numeric union")
SubClassOf(<http://qudt.org/schema/qudt/NumericUnion> <http://qudt.org/schema/qudt/Concept>)
SubClassOf(<http://qudt.org/schema/qudt/NumericUnion> <http://www.linkedmodel.org/schema/dtype#numericUnion>)

# Class: <http://qudt.org/schema/qudt/OrderedType> (Ordered type)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/OrderedType> "Ordered type")
EquivalentClasses(<http://qudt.org/schema/qudt/OrderedType> ObjectOneOf(<http://qudt.org/schema/qudt/PartiallyOrdered> <http://qudt.org/schema/qudt/TotallyOrdered> <http://qudt.org/schema/qudt/Unordered>))
SubClassOf(<http://qudt.org/schema/qudt/OrderedType> <http://qudt.org/schema/qudt/EnumeratedValue>)
SubClassOf(<http://qudt.org/schema/qudt/OrderedType> DataMaxCardinality(1 <http://www.linkedmodel.org/schema/dtype#literal>))

# Class: <http://qudt.org/schema/qudt/Quantifiable> (Quantifiable)

AnnotationAssertion(rdfs:comment <http://qudt.org/schema/qudt/Quantifiable> "<p><em>Quantifiable</em> ascribes to some thing the capability of being measured, observed, or counted.</p>"^^rdf:HTML)
AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/Quantifiable> "Quantifiable")
SubClassOf(<http://qudt.org/schema/qudt/Quantifiable> <http://qudt.org/schema/qudt/Aspect>)
SubClassOf(<http://qudt.org/schema/qudt/Quantifiable> ObjectAllValuesFrom(<http://qudt.org/schema/qudt/unit> <http://qudt.org/schema/qudt/Unit>))
SubClassOf(<http://qudt.org/schema/qudt/Quantifiable> ObjectMaxCardinality(1 <http://qudt.org/schema/qudt/unit>))

# Class: <http://qudt.org/schema/qudt/QuantityValue> (Quantity value)

AnnotationAssertion(rdfs:comment <http://qudt.org/schema/qudt/QuantityValue> "A <i>Quantity Value</i> expresses the magnitude and kind of a quantity and is given by the product of a numerical value <code>n</code> and a unit of measure <code>U</code>. The number multiplying the unit is referred to as the numerical value of the quantity expressed in that unit. Refer to <a href=\"http://physics.nist.gov/Pubs/SP811/sec07.html\">NIST SP 811 section 7</a> for more on quantity values."^^rdf:HTML)
AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/QuantityValue> "Quantity value")
SubClassOf(<http://qudt.org/schema/qudt/QuantityValue> <http://qudt.org/schema/qudt/Concept>)
SubClassOf(<http://qudt.org/schema/qudt/QuantityValue> <http://qudt.org/schema/qudt/Quantifiable>)
SubClassOf(<http://qudt.org/schema/qudt/QuantityValue> ObjectMaxCardinality(1 <http://qudt.org/schema/qudt/unit>))

# Class: <http://qudt.org/schema/qudt/Unit> (Unit)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/Unit> "Unit")
SubClassOf(<http://qudt.org/schema/qudt/Unit> <http://qudt.org/schema/qudt/Concept>)
SubClassOf(<http://qudt.org/schema/qudt/Unit> <http://qudt.org/schema/qudt/Verifiable>)

# Class: <http://qudt.org/schema/qudt/Verifiable> (Verifiable)

AnnotationAssertion(rdfs:comment <http://qudt.org/schema/qudt/Verifiable> "An aspect class that holds properties that provide external knowledge and specifications of a given resource.")
AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/Verifiable> "Verifiable")
SubClassOf(<http://qudt.org/schema/qudt/Verifiable> <http://qudt.org/schema/qudt/Aspect>)

# Class: <http://qudt.org/schema/qudt/valueUnion> (value union)

AnnotationAssertion(rdfs:label <http://qudt.org/schema/qudt/valueUnion> "value union")
EquivalentClasses(<http://qudt.org/schema/qudt/valueUnion> ObjectUnionOf(<http://www.linkedmodel.org/schema/dtype#EnumeratedValue> xsd:anySimpleType))
SubClassOf(<http://qudt.org/schema/qudt/valueUnion> rdfs:Resource)

# Class: <http://www.linkedmodel.org/schema/dtype#EnumeratedValue> (DTYPE Enumerated Value)

AnnotationAssertion(rdfs:label <http://www.linkedmodel.org/schema/dtype#EnumeratedValue> "DTYPE Enumerated Value")
SubClassOf(<http://www.linkedmodel.org/schema/dtype#EnumeratedValue> DataExactCardinality(1 <http://www.linkedmodel.org/schema/dtype#value>))
SubClassOf(<http://www.linkedmodel.org/schema/dtype#EnumeratedValue> DataMaxCardinality(1 <http://www.linkedmodel.org/schema/dtype#literal>))

# Class: <http://www.linkedmodel.org/schema/dtype#dateUnion> (date union)

AnnotationAssertion(rdfs:label <http://www.linkedmodel.org/schema/dtype#dateUnion> "date union")
EquivalentClasses(<http://www.linkedmodel.org/schema/dtype#dateUnion> ObjectUnionOf(xsd:date xsd:dateTime xsd:gDay xsd:gMonth xsd:gMonthDay xsd:gYear xsd:gYearMonth))
SubClassOf(<http://www.linkedmodel.org/schema/dtype#dateUnion> rdfs:Resource)

# Class: <http://www.linkedmodel.org/schema/dtype#numericUnion> (numeric union)

AnnotationAssertion(rdfs:label <http://www.linkedmodel.org/schema/dtype#numericUnion> "numeric union")
SubClassOf(<http://www.linkedmodel.org/schema/dtype#numericUnion> rdfs:Resource)

# Class: <http://www.linkedmodel.org/schema/vaem#GraphMetaData> (Graph Metadata)

AnnotationAssertion(rdfs:label <http://www.linkedmodel.org/schema/vaem#GraphMetaData> "Graph Metadata")
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> ObjectAllValuesFrom(<http://www.linkedmodel.org/schema/vaem#hasGraphRole> <http://www.linkedmodel.org/schema/vaem#GraphRole>))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> ObjectAllValuesFrom(<http://www.linkedmodel.org/schema/vaem#hasOwner> <http://www.linkedmodel.org/schema/vaem#Party>))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> ObjectAllValuesFrom(<http://www.linkedmodel.org/schema/vaem#hasSteward> <http://www.linkedmodel.org/schema/vaem#Party>))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> ObjectMaxCardinality(1 <http://www.linkedmodel.org/schema/vaem#hasLicenseType>))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> ObjectMaxCardinality(1 <http://www.linkedmodel.org/schema/vaem#hasSteward>))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> DataAllValuesFrom(<http://www.linkedmodel.org/schema/vaem#description> xsd:string))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> DataExactCardinality(1 <http://www.linkedmodel.org/schema/vaem#name>))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> DataMaxCardinality(1 <http://www.linkedmodel.org/schema/vaem#intent>))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> DataMaxCardinality(1 <http://www.linkedmodel.org/schema/vaem#latestPublishedVersion>))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> DataMaxCardinality(1 <http://www.linkedmodel.org/schema/vaem#namespace>))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> DataMaxCardinality(1 <http://www.linkedmodel.org/schema/vaem#namespacePrefix>))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> DataMaxCardinality(1 <http://www.linkedmodel.org/schema/vaem#owner>))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> DataMaxCardinality(1 <http://www.linkedmodel.org/schema/vaem#previousPublishedVersion>))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> DataMaxCardinality(1 <http://www.linkedmodel.org/schema/vaem#rdfxmlFileURL>))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> DataMaxCardinality(1 <http://www.linkedmodel.org/schema/vaem#revision>))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphMetaData> DataMaxCardinality(1 <http://www.linkedmodel.org/schema/vaem#turtleFileURL>))

# Class: <http://www.linkedmodel.org/schema/vaem#GraphRole> (Graph role)

AnnotationAssertion(rdfs:label <http://www.linkedmodel.org/schema/vaem#GraphRole> "Graph role")
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphRole> DataMaxCardinality(1 <http://www.linkedmodel.org/schema/vaem#description>))
SubClassOf(<http://www.linkedmodel.org/schema/vaem#GraphRole> DataMaxCardinality(1 <http://www.linkedmodel.org/schema/vaem#filePrefix>))

# Class: <http://www.linkedmodel.org/schema/vaem#Party> (Party)

AnnotationAssertion(rdfs:label <http://www.linkedmodel.org/schema/vaem#Party> "Party")
