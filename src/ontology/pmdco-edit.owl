############################
#   Classes
############################

# Class: pmd:PMD_0010034 (curing)

AnnotationAssertion(skos:comment pmd:PMD_0010034 "Curing may be induced by thermal energy, radiation, atmospheric exposure, or chemical additives. It applies broadly to material systems including polymer resins, concrete, vulcanized rubbers, drying oils, and coatings.")

# Class: pmd:PMD_0090020 (monomer)

AnnotationAssertion(rdfs:label pmd:PMD_0090020 "monomer"@en)
AnnotationAssertion(skos:comment pmd:PMD_0090020 "A monomer bears a disposition to polymerize and may bear the polymerisation monomer role in an appropriate polymerization process.")
AnnotationAssertion(skos:definition pmd:PMD_0090020 "A monomer is a chemical entity that can undergo a polymerization process and thereby contribute constitutional units to a macromolecule or a polymer.")
SubClassOf(pmd:PMD_0090020 obo:CHEBI_24431)
SubClassOf(pmd:PMD_0090020 ObjectSomeValuesFrom(obo:RO_0000091 pmd:PMD_0090021))

# Class: pmd:PMD_0090021 (disposition to polymerize)

AnnotationAssertion(rdfs:label pmd:PMD_0090021 "disposition to polymerize"@en)
AnnotationAssertion(skos:comment pmd:PMD_0090021 "Typical bearers of this disposition include monomers and oligomeric or prepolymeric materials that can undergo polymerization under suitable conditions.")
AnnotationAssertion(skos:definition pmd:PMD_0090021 "A disposition to polymerize is a disposition of a chemical entity to undergo polymerization and thereby contribute constitutional units to a macromolecule or a polymer.")
SubClassOf(pmd:PMD_0090021 obo:BFO_0000016)

# Class: pmd:PMD_0090022 (resin role)

AnnotationAssertion(rdfs:label pmd:PMD_0090022 "resin role"@en)
AnnotationAssertion(skos:comment pmd:PMD_0090022 "Typical bearers of this role include curable or processable materials used in polymer formulation, coating, impregnation, adhesive application, or composite manufacturing. Many such bearers are viscous liquids or solids that may later be transformed into higher-molar-mass, networked materials or a polymeric matrix during processing.")
AnnotationAssertion(skos:definition pmd:PMD_0090022 "A resin role is a role borne by a material entity that is realized when the bearer functions as a matrix-forming, binding, adhesive, coating, or impregnating component in a material processing or manufacturing process.")
SubClassOf(pmd:PMD_0090022 obo:BFO_0000023)

# Class: pmd:PMD_0090023 (curing (polymers))

AnnotationAssertion(rdfs:label pmd:PMD_0090023 "curing (polymers)"@en)
AnnotationAssertion(skos:comment pmd:PMD_0090023 "In many thermosetting systems, polymer curing involves crosslinking and leads to formation of a hardened network. 
Polymer curing results in an increase in molar mass, viscosity, and structural stability. 
While crosslinking is a primary mechanism for thermosets, physical curing or chain extension mechanisms can also occur.")
AnnotationAssertion(skos:definition pmd:PMD_0090023 "A polymer curing process is a curing process in which a monomeric, oligomeric, or polymeric precursor undergoes chemical reaction to form a polymer network or material of higher molar mass."@en)
SubClassOf(pmd:PMD_0090023 pmd:PMD_0010034)

# Class: pmd:PMD_0090024 (crosslinking)

AnnotationAssertion(rdfs:label pmd:PMD_0090024 "crosslinking"@en)
AnnotationAssertion(skos:altLabel pmd:PMD_0090024 "cross-linking"@en)
AnnotationAssertion(skos:comment pmd:PMD_0090024 "Crosslinking can involve covalent bonds, ionic interactions, or other linking interactions between polymer chains.
It can reduce solubility and melt flow while increasing thermal and mechanical stability.")
AnnotationAssertion(skos:definition pmd:PMD_0090024 "A crosslinking process is a chemical or physical interaction process in which chemical bonds or other linking interactions are formed between macromolecular chains or distinct regions of a polymeric material, thereby increasing network connectivity or contributing to network formation.")
SubClassOf(pmd:PMD_0090024 obo:BFO_0000015)


