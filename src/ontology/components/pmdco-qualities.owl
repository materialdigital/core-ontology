AnnotationAssertion(rdfs:label pmdco:PMD_0001046 "Tiefe"@de)
SubClassOf(pmdco:PMD_0001046 pmdco:PMD_0040001)

# Class: pmdco:PMD_0010000 (corrosion resistant)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0010000 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0010000 "PERSON: Bernd Bayerlein")
AnnotationAssertion(rdfs:label pmdco:PMD_0010000 "corrosion resistant")
AnnotationAssertion(skos:definition pmdco:PMD_0010000 "a disposition to withstand corrosive attack to a certain extend")
SubClassOf(pmdco:PMD_0010000 pmdco:PMD_0000005)

# Class: pmdco:PMD_0010013 (hardenable)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0010013 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0010013 "PERSON: Bernd Bayerlein")
AnnotationAssertion(rdfs:label pmdco:PMD_0010013 "hardenable"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0010013 "härtbar"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0010013 "a disposition to gain a greatly increased hardness at the surface or entire volume by the process of hardening")
SubClassOf(pmdco:PMD_0010013 pmdco:PMD_0000848)

# Class: pmdco:PMD_0010022 (enthält magnetische Spezies)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0010022 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0010022 "PERSON: Bernd Bayerlein")
AnnotationAssertion(rdfs:label pmdco:PMD_0010022 "containing magnetic species"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0010022 "enthält magnetische Spezies"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0010022 "Materialeigenschaft, die einer materiellen Einheit aufgrund der Anwesenheit einer oder mehrerer magnetischer Spezies (z. B. ferromagnetischer, paramagnetischer oder diamagnetischer Partikel oder Atome) innewohnt und die sich unter geeigneten Bedingungen als magnetische Reaktion oder Einfluss in einem Magnetfeld manifestiert"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0010022 "material property that inheres in a material entity in virtue of the presence of one or more magnetic species (e.g. ferromagnetic, paramagnetic, or diamagnetic particles or atoms), and that manifests under appropriate conditions as a magnetic response or influence in a magnetic field"@en)
SubClassOf(pmdco:PMD_0010022 pmdco:PMD_0000005)

# Class: pmdco:PMD_0010023 (bioactive)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0010023 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0010023 "PERSON: Bernd Bayerlein")
AnnotationAssertion(rdfs:label pmdco:PMD_0010023 "bioactive"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0010023 "bioaktiv"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0010023 "Disposition, die einer materiellen Einheit innewohnt und in einem Organismuskontext als spezifische Interaktion mit einem oder mehreren biologischen Systemen verwirklicht wird und eine messbare biologische Wirkung hervorruft, beispielsweise eine therapeutische, toxische oder signalisierende Wirkung"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0010023 "disposition that inheres in a material entity and is realized in an organismal context as a specific interaction with one or more biological systems, producing a measurable biological effect such as therapeutic, toxic, or signaling outcome"@en)
SubClassOf(pmdco:PMD_0010023 obo:BFO_0000016)

# Class: pmdco:PMD_0010024 (bioinert)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0010024 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0010024 "PERSON: Bernd Bayerlein")
AnnotationAssertion(rdfs:label pmdco:PMD_0010024 "bioinert"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0010024 "bioinert"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0010024 "a disposition to elicit minimal or no biological response when in contact with tissue or implanted"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0010024 "eine Neigung, bei Kontakt mit Gewebe oder einer Implantation nur eine minimale oder keine biologische Reaktion hervorzurufen"@de)
AnnotationAssertion(skos:example pmdco:PMD_0010024 "non-toxic and non-immunogenic, with little or no bonding or integration with the body.")
SubClassOf(pmdco:PMD_0010024 obo:BFO_0000016)

# Class: pmdco:PMD_0010025 (bioresorbierbar)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0010025 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0010025 "PERSON: Bernd Bayerlein")
AnnotationAssertion(rdfs:label pmdco:PMD_0010025 "bioresorbable"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0010025 "bioresorbierbar"@de)
AnnotationAssertion(skos:comment pmdco:PMD_0010025 "being absorbed or excreted as it performs its function, often eliminating the need for removal.")
AnnotationAssertion(skos:definition pmdco:PMD_0010025 "biocompatibe and degrading and being resorbed by the body over time"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0010025 "biokompatibel und im Laufe der Zeit vom Körper abgebaut und resorbiert"@de)
SubClassOf(pmdco:PMD_0010025 pmdco:PMD_0020251)

# Class: pmdco:PMD_0010026 (organische Zusammensetzung)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0010026 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0010026 "PERSON: Bernd Bayerlein")
AnnotationAssertion(rdfs:label pmdco:PMD_0010026 "organic composition"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0010026 "organische Zusammensetzung"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0010026 "A composition characterized by a primary molecular structure of carbon atoms covalently bonded to hydrogen (C-H bonds), typically forming linear, branched, or networked chains."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0010026 "Eine Zusammensetzung, die durch eine primäre Molekülstruktur aus kovalent an Wasserstoff gebundenen Kohlenstoffatomen (C-H-Bindungen) gekennzeichnet ist und typischerweise lineare, verzweigte oder vernetzte Ketten bildet."@de)
SubClassOf(pmdco:PMD_0010026 pmdco:PMD_0025001)

# Class: pmdco:PMD_0010027 (inorganic composition)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0010027 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0010027 "PERSON: Bernd Bayerlein")
AnnotationAssertion(rdfs:label pmdco:PMD_0010027 "anorganische Zusammensetzung"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0010027 "inorganic composition"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0010027 "Materialzusammensetzung, die auf anderen chemischen Elementen als denen organischer Verbindungen basiert und typischerweise durch ionische oder metallische Bindungen und das Fehlen eines Kohlenstoff-Wasserstoff-Gerüsts ($C-H$) gekennzeichnet ist"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0010027 "material composition based on chemical elements other than those defining organic compounds, typically characterized by ionic or metallic bonding and the absence of a carbon-hydrogen ($C-H$) framework"@en)
SubClassOf(pmdco:PMD_0010027 pmdco:PMD_0025001)

# Class: pmdco:PMD_0010029 (spezifische Festigkeit)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0010029 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0010029 "PERSON: Bernd Bayerlein")
AnnotationAssertion(rdfs:label pmdco:PMD_0010029 "specific strength"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0010029 "spezifische Festigkeit"@de)
AnnotationAssertion(skos:comment pmdco:PMD_0010029 "SI unit for specific strength is Pa⋅m3/kg, or N⋅m/kg, which is dimensionally equivalent to m2/s2, In fiber or textile applications, tenacity is the usual measure of specific strength
")
AnnotationAssertion(skos:definition pmdco:PMD_0010029 "Specific strength is a quality that inheres in a material entity and is defined as the ratio of its tensile strength to its density."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0010029 "Spezifische Festigkeit ist eine Eigenschaft, die einem Material innewohnt und als das Verhältnis seiner Zugfestigkeit zu seiner Dichte definiert wird."@de)
SubClassOf(pmdco:PMD_0010029 pmdco:PMD_0000952)

# Class: pmdco:PMD_0020003 (crystal)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020003 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020003 "PERSON: Philipp von Hartrott")

# Class: pmdco:PMD_0020004 (Zusammensetzungsdatenelement)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020004 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0020004 "See editior note of composition to underatand the difference between composition and chemical composition data items.

To understand the difference between the composition and the composition data item, one has to understand the difference between SDCs and GDCs in BFO. A triple \"material entity has quality compsition\", conveys the fact such quality exists without telling us what are fractions of compounds in this material entity. A triple \"compostion is subject of composition data item\" conveys that there's an information about values of these fractions. Think of comosition data item as a pdf where the composition is documented."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020004 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:comment pmdco:PMD_0020004 "These portions of other matters do not have to be portions of specific chemical elements, i.e., atomic composition, but rather portions of other substances, such as nitric acid and water."@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020004 "Zusammensetzungsdatenelement"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020004 "composition data item"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0020004 "composition specification"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020004 "Bei einem Zusammensetzungsdatenelement handelt es sich um eine Informationsinhaltseinheit, die sich mit der Zusammensetzung einer materiellen Einheit befasst. Es verfügt über Bruchwertspezifikationen für Mitglieder, die Werte von Anteilen von Verbindungen angeben, die Teile der materiellen Einheit sind."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020004 "Composition data item is an information content entity that is about composition of a material enity. It has members fraction value specifications which specifiy values of propotions of compounds, which are parts of the material enity."@en)
AnnotationAssertion(skos:example pmdco:PMD_0020004 "Nitric acid solution has quality  composition, and  the composition data item is about this composition.The composition data item has members fraction specifications of nitric acid, e.g., 4 vol.%, and distilled water. These fraction specifications specify value of pure substances of nitric acid and distilled water, respectively. Furthermore, these fraction specifications specify values of relational qualities (volume) proportion of nitric acid and (volume) proportion of distilled water."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020004 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020004 obo:IAO_0000027)
SubClassOf(pmdco:PMD_0020004 ObjectIntersectionOf(obo:IAO_0000027 ObjectSomeValuesFrom(obo:IAO_0000136 pmdco:PMD_0025001)))
SubClassOf(pmdco:PMD_0020004 ObjectSomeValuesFrom(obo:RO_0002351 pmdco:PMD_0025997))

# Class: pmdco:PMD_0020005 (Porosität)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020005 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020005 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020005 "Porosität"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020005 "porosity"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020005 "itensive Qualität, die den Anteil des von Poren eingenommenen (umschließenden) räumlichen Bereichs des Materials verkörpert."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020005 "itensive quality embodiying the fraction of the materials (enclosing) spatial region occupied by pores."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020005 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020005 pmdco:PMD_0020131)

# Class: pmdco:PMD_0020022 (Korrosion)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020022 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020022 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:comment pmdco:PMD_0020022 "Corrosion is typically of interest when the change of the material affects the objects ability to fulfill its function."@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020022 "Korrosion"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020022 "corrosion"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020022 "Korrosion ist ein langsamer chemischer oder elektrochemischer Zersetzungsprozess eines Materials aufgrund seiner Wechselwirkung mit der Umgebung."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020022 "corrosion is a slow chemical or electrochemical degradation process of a material entity due to its interaction with the surrounding environment."@en)
SubClassOf(pmdco:PMD_0020022 obo:BFO_0000015)

# Class: pmdco:PMD_0020023 (metallische Kornstrukturen)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020023 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020023 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020023 "metallic grain structures"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020023 "metallische Kornstrukturen"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020023 "Bei der metallischen Kornstruktur handelt es sich um eine kategoriale Wertspezifikation, die den Wert der Qualität der metallischen Kornstruktur angibt. Es beschreibt die Morphologie polykristalliner metallischer Werkstoffe. Polykristalline metallische Materialien bilden ihre Kornstrukturen typischerweise als eine dieser Kategorien oder als Übergangs- oder Mischungszustand davon aus."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020023 "The metallic grain structures is a categorical value specification that specifies value of the  metallic grain structure quality. It describes the morphology of polycrystalline metallic materials. Polycrystalline metallic materials will typically form their grain structures as one of those categories or a transition or mixture state of those."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020023 "true"^^xsd:boolean)
EquivalentClasses(pmdco:PMD_0020023 ObjectOneOf(pmdco:PMD_0020027 pmdco:PMD_0020097 pmdco:PMD_0020100 pmdco:PMD_0020107 pmdco:PMD_0020109 pmdco:PMD_0020110 pmdco:PMD_0020111))
SubClassOf(pmdco:PMD_0020023 obo:OBI_0001930)

# Class: pmdco:PMD_0020024 (Wasserstoffbindung)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020024 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020024 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020024 "Wasserstoffbindung"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020024 "hydrogen bond"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020024 "A hydrogen bond is a bond that binds one molecule’s hydrogen atom with the electronegative atoms of another molecule."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020024 "Eine Wasserstoffbindung ist eine Bindung, die das Wasserstoffatom eines Moleküls mit den elektronegativen Atomen eines anderen Moleküls verbindet."@de)
AnnotationAssertion(skos:example pmdco:PMD_0020024 "The bond that forms between liquid water molecules at one molecules hydrogen ends and the other molecules oxygen end."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020024 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020024 pmdco:PMD_0050000)

# Class: pmdco:PMD_0020025 (obstacle role)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020025 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020025 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020025 "Hindernisrolle"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020025 "obstacle role"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020025 "An obstacle role is a role of an independent continuant C that is realized in a motion process and indictes that C hinders the motion of a participant in the process."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020025 "Eine Hindernisrolle ist eine Rolle eines unabhängigen kontinuierlichen C, die in einem Bewegungsprozess realisiert wird und anzeigt, dass C die Bewegung eines Teilnehmers am Prozess behindert."@de)
AnnotationAssertion(skos:example pmdco:PMD_0020025 "A precipitate or grain boundary may hinder the motion of a dislocation."@en)
SubClassOf(pmdco:PMD_0020025 obo:BFO_0000023)

# Class: pmdco:PMD_0020098 (Naturkonstante)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020098 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020098 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020098 "Naturkonstante"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020098 "nature constant"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020098 "A nature constant is a generically dependent continuant whose value, maginitude or configuration is determined by nature including physics and mathematics."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020098 "Eine Naturkonstante ist ein generisch abhängiger Kontinuant, dessen Wert, Größe oder Konfiguration durch die Natur, einschließlich Physik und Mathematik, bestimmt wird."@de)
AnnotationAssertion(skos:example pmdco:PMD_0020098 "Examples of nature constants are the speed of light, pi, etc."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020098 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020098 obo:BFO_0000031)

# Class: pmdco:PMD_0020099 (Bravais-Gitter (3D))

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020099 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020099 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:comment pmdco:PMD_0020099 "TODO: possibly extend for 2D (Graphene etc)

More elaborate crystal descriptions may be found in http://emmo.info/domain-crystallography/crystallography or https://purls.helmholtz-metadaten.de/disos/cso"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020099 "Bravais-Gitter (3D)"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020099 "bravais lattice (3D)"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020099 "Das Bravais-Gitter ist eine kategoriale Wertspezifikation, die den Wert der Kristallstrukturqualität angibt. Es beschreibt die mögliche geometrische Anordnung von Gitterpunkten in einem Kristall. Der vorliegende Deskriptor beschränkt sich auf die 14 möglichen dreidimensionalen Anordnungen."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020099 "The bravais lattice is a categorical value specification that specifies value of the crystal structure quality. It describes the possible geometric arrangement of lattice points in a crystal. The present descriptor is limited to the 14 possible three-dimensional arrangements."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020099 "true"^^xsd:boolean)
EquivalentClasses(pmdco:PMD_0020099 ObjectOneOf(pmdco:PMD_0020006 pmdco:PMD_0020007 pmdco:PMD_0020008 pmdco:PMD_0020009 pmdco:PMD_0020010 pmdco:PMD_0020011 pmdco:PMD_0020012 pmdco:PMD_0020013 pmdco:PMD_0020014 pmdco:PMD_0020015 pmdco:PMD_0020016 pmdco:PMD_0020017 pmdco:PMD_0020018 pmdco:PMD_0020019))
SubClassOf(pmdco:PMD_0020099 obo:OBI_0001930)

# Class: pmdco:PMD_0020101 (proportion)

AnnotationAssertion(rdfs:comment pmdco:PMD_0020101 "The proportion relation doesn't specify which entity is the whole and which is the part, so an addtional 'part of' is necessary between the two."@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020101 "Anteil"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020101 "proportion"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020101 "A proportion is a relational quality between two entities (the whole and the part) which quantifies the relation between the whole and its part."@en)
SubClassOf(pmdco:PMD_0020101 obo:BFO_0000145)

# Class: pmdco:PMD_0020102 (mass proportion)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020102 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0020102 "Necessary and sufficient conditions for 'mass ratio' have not yet been formalized. The term is defined as a specific subtype of 'material composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020102 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020102 "Massenverhältnis"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020102 "mass proportion"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020102 "a proportion which quantifies the mass of the part relative to the mass of the whole."@en)
AnnotationAssertion(skos:example pmdco:PMD_0020102 "A fiber-reinforced composite has a fiber-to-matrix mass ratio of 60:40"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020102 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020102 pmdco:PMD_0020101)

# Class: pmdco:PMD_0020103 (molar proportion)

AnnotationAssertion(rdfs:label pmdco:PMD_0020103 "Molverhältnis"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020103 "molar proportion"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020103 "a proportion which quantifies the entities count of the part in relation to the entities count of the whole."@en)
AnnotationAssertion(skos:example pmdco:PMD_0020103 "The molar ratio of hydrogen gas H2 molecules to water H2O molecules is 1/1 in the oxyhydrogen reaction. The molar ratio of oxygen molecules O2 to water molecules is 2/1.
The molar ratio of carbon dioxide to average atmosphere air is 420 ppm as of 2022 AD."@en)
SubClassOf(pmdco:PMD_0020103 pmdco:PMD_0020101)

# Class: pmdco:PMD_0020104 (volume proportion)

AnnotationAssertion(rdfs:label pmdco:PMD_0020104 "volume proportion"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020104 "a proportion which quantifies the volume of the part relative to the volume of the whole."@en)
AnnotationAssertion(skos:example pmdco:PMD_0020104 "A foam material has a pore-to-solid volume ratio of 4:1, indicating 80 % porosity"@en)
SubClassOf(pmdco:PMD_0020104 pmdco:PMD_0020101)

# Class: pmdco:PMD_0020106 (polycrystal)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020106 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020106 "PERSON: Philipp von Hartrott")

# Class: pmdco:PMD_0020108 (temper)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020108 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020108 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020108 "temper"@en)
AnnotationAssertion(skos:comment pmdco:PMD_0020108 "The temper is not expressed in terms of the structure of a material but by the process steps that have been applied to the material. It thus contributes to the \"process aspect\" in the definition of a material.

Typically tempering involes process steps of heat treatment and forming."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020108 "an intensive quality of an alloy that is output of a tempering process"@en)
SubClassOf(pmdco:PMD_0020108 pmdco:PMD_0020131)

# Class: pmdco:PMD_0020112 (Korngrößenverteilung)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020112 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020112 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020112 "Korngrößenverteilung"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020112 "grain size distribution"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020112 "An intensive quality describing the lower length scale object aggregate (grains) that is part of the material."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020112 "Eine intensive Qualität, die das Objektaggregat (Körner) auf niedrigerer Längenskala beschreibt, das Teil des Materials ist."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020112 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020112 pmdco:PMD_0020131)

# Class: pmdco:PMD_0020116 (aggregierter Zustandswert)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020116 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020116 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020116 "aggregate state value"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020116 "aggregierter Zustandswert"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020116 "Der Aggregatzustandswert ist eine kategoriale Wertspezifikation, die den Wert der Aggregatzustandsqualität angibt."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020116 "The aggregate state value is a categorical value specification that specifies value of the aggregate state quality."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020116 "true"^^xsd:boolean)
EquivalentClasses(pmdco:PMD_0020116 ObjectOneOf(pmdco:PMD_0020117 pmdco:PMD_0020118 pmdco:PMD_0020119 pmdco:PMD_0020120 pmdco:PMD_0020121 pmdco:PMD_0020122 pmdco:PMD_0020123 pmdco:PMD_0020124 pmdco:PMD_0020125))
SubClassOf(pmdco:PMD_0020116 obo:OBI_0001930)

# Class: pmdco:PMD_0020129 (reversibler Prozess)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020129 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020129 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020129 "reversible process"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020129 "reversibler Prozess"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020129 "A reversible process is a process whose participants form a thermodynamic system with an entropy S and S remains constant during the process."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020129 "Ein reversibler Prozess ist ein Prozess, dessen Teilnehmer ein thermodynamisches System mit einer Entropie S bilden und S während des Prozesses konstant bleibt."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020129 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020129 obo:BFO_0000015)

# Class: pmdco:PMD_0020130 (Triebkraft einer Phase im System)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020130 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020130 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020130 "Triebkraft einer Phase im System"@de)
SubClassOf(pmdco:PMD_0020130 pmdco:PMD_0080005)

# Class: pmdco:PMD_0020131 (intensive quality)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020131 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020131 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020131 "intensive Qualität"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020131 "intensive quality"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0020131 "Point property"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020131 "An intensive quality is a quality that inheres in only portion of matter and thus is independent of the bearers (system-) size."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020131 "Eine intensive Qualität ist eine Qualität, die nur einem Teil der Materie innewohnt und daher unabhängig von der (System-)Größe des Trägers ist."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020131 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020131 obo:BFO_0000019)
SubClassOf(Annotation(rdfs:comment "Due to the duality of object and portion of matter this axiom can not be an equivalent class axiom."@en) pmdco:PMD_0020131 ObjectSomeValuesFrom(obo:RO_0000080 pmdco:PMD_0000001))
DisjointClasses(pmdco:PMD_0020131 pmdco:PMD_0020148)

# Class: pmdco:PMD_0020132 (dimension quality)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020132 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0020132 "Necessary and sufficient conditions for 'dimension quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000019'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020132 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020132 "Dimensionsqualität"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020132 "dimension quality"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020132 "Die Dimensionsqualität ist eine Qualität einer materiellen Einheit, die sich auf ihre messbare räumliche Ausdehnung bezieht, beispielsweise Länge, Fläche oder Volumen"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020132 "a quality of an entity that pertains to its measurable spatial extent, such as length, area, or volume"@en)
AnnotationAssertion(skos:example pmdco:PMD_0020132 "the diameter of the hole in the cheese (site), the wall thickness of a steel pipe"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020132 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020132 obo:BFO_0000019)

# Class: pmdco:PMD_0020133 (Masse)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020133 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020133 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:comment pmdco:PMD_0020133 "Mass is relevant in such processes as gravitation, acceleration, etc."@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020133 "Masse"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020133 "mass"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020133 "Mass is fundamental extensive quality."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020133 "Masse ist grundlegende umfassende Qualität."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020133 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020133 pmdco:PMD_0020148)

# Class: pmdco:PMD_0020134 (stimulus role)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020134 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020134 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020134 "Reizrolle"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020134 "stimulus role"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020134 "Die Reizrolle ist eine Rolle, die ein Objekt in einem Prozess spielt, wenn es ein anderes Objekt, das im selben Prozess eine Stimulationszielrolle spielt, kausal beeinflusst. „Rolle“ impliziert hier, dass die „tragende“ Zuordnung von der Absicht abhängt."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020134 "The stimulus role is a role that an object bears in a process when causally influencing another object  that bears a stimulation target role in the same process. 'Role' implies here, that the 'bearing' assignment depends on the intent."@en)
SubClassOf(pmdco:PMD_0020134 obo:BFO_0000023)

# Class: pmdco:PMD_0020135 (stimulation target role)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020135 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020135 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020135 "Stimulationszielrolle"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020135 "stimulation target role"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020135 "See 'Stimulus role'"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020135 "Siehe „Stimulusrolle“"@de)
SubClassOf(pmdco:PMD_0020135 pmdco:PMD_0000975)

# Class: pmdco:PMD_0020136 (phase transformation)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020136 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020136 "PERSON: Philipp von Hartrott")

# Class: pmdco:PMD_0020141 (fatigue (reaction to repetitive loading))

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020141 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020141 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:comment pmdco:PMD_0020141 "Fatigue is typically of interest when the change of the material affects the objects ability to fulfill its function."@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020141 "Müdigkeit (Reaktion auf wiederholte Belastung)"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020141 "fatigue (reaction to repetitive loading)"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020141 "Ermüdung ist ein Prozess, der die Integrität eines Materials durch Keimbildung und wachsende Risse beeinträchtigt."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020141 "fatigue is a process that affects an material entities integrity by nucleation and growing cracks."@en)
SubClassOf(pmdco:PMD_0020141 obo:BFO_0000015)

# Class: pmdco:PMD_0020142 (energy)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020142 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020142 "PERSON: Philipp von Hartrott")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0020142 <http://openenergy-platform.org/ontology/oeo/OEO_00000150>)
AnnotationAssertion(rdfs:label pmdco:PMD_0020142 "Energie"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020142 "energy"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020142 "an extensive quality of material entities which manifests as a capacity to perform work (such as causing motion or the interaction of molecules)"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020142 "eine umfassende Qualität materieller Einheiten, die sich in der Fähigkeit manifestiert, Arbeit zu verrichten (z. B. Bewegung zu verursachen oder die Wechselwirkung von Molekülen)"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020142 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020142 pmdco:PMD_0020148)
SubClassOf(pmdco:PMD_0020142 pmdco:PMD_0080005)

# Class: pmdco:PMD_0020148 (extensive quality)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020148 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020148 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020148 "extensive quality"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020148 "umfangreiche Qualität"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020148 "An extensive quality is a quality that inheres in only object or object aggregate or fiat object part or chemical entity and is dependent on the bearers (system-) size."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020148 "Eine umfassende Qualität ist eine Qualität, die nur einem Objekt oder einem Objektaggregat oder einem Fiat-Objektteil oder einer chemischen Einheit innewohnt und von der (System-)Größe des Trägers abhängt."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020148 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020148 obo:BFO_0000019)

# Class: pmdco:PMD_0020150 (Volumen)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020150 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0020150 "Necessary and sufficient conditions for 'volume' have not yet been formalized. The term is defined as a specific subtype of 'DimensionQuality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000918."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020150 "PERSON: Philipp von Hartrott")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0020150 obo:PATO_0000918)
AnnotationAssertion(rdfs:label pmdco:PMD_0020150 "Volumen"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020150 "volume"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020150 "Volume is a three dimensional size."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020150 "Volumen ist eine dreidimensionale Größe."@de)
AnnotationAssertion(skos:example pmdco:PMD_0020150 "A cylindrical billet has a volume of 0.002 m3, determined from its radius and height"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020150 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020150 pmdco:PMD_0020132)

# Class: pmdco:PMD_0020151 (internal energy)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020151 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020151 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020151 "innere Energie"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020151 "internal energy"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020151 "Innere Energie ist eine universelle umfassende Qualität, die das Potenzial des Trägers zur Arbeit festlegt."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020151 "Internal energy is a universal extensive quality that specifies the bearers potential to do work."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020151 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020151 pmdco:PMD_0020142)
DisjointClasses(pmdco:PMD_0020151 pmdco:PMD_0020155)

# Class: pmdco:PMD_0020155 (interatomic interaction energy)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020155 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020155 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020155 "interatomare Wechselwirkungsenergie"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020155 "interatomic interaction energy"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020155 "Interatomare Wechselwirkungsenergie wird dem Atomaggregat hinzugefügt/entfernt, wenn ein Atom unendlich vom Rest des Aggregats entfernt wird."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020155 "Interatomic interaction energy is added/removed from the atom aggregate if one atom is moved infinitely away from the rest of the aggregate."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020155 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020155 pmdco:PMD_0020142)

# Class: pmdco:PMD_0020161 (activity (thermodynamic))

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020161 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020161 "PERSON: Philipp von Hartrott")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0020161 "old defintion: 
Activity (a_X) is a relational property between a chemical species X and a non-ideal solution. a_X is a measure of the effective concentration of a chemical species X in the non-ideal solution, accounting for interactions between particles. It is defined as the product of the concentration and an activity coefficient, where the activity coefficient corrects for non-ideal behavior.")
AnnotationAssertion(rdfs:label pmdco:PMD_0020161 "activity (thermodynamic)"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020161 "thermodynamische Aktivität"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020161 "Thermodynamic activity is a relational quality that inheres between a chemical species and a non-ideal solution and represents the effective concentration of the species accounting for particle interactions."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020161 "Thermodynamische Aktivität ist eine Beziehungsqualität, die zwischen einer chemischen Spezies und einer nicht idealen Lösung innewohnt und die effektive Konzentration der Spezies darstellt, die für Partikelwechselwirkungen verantwortlich ist."@de)
SubClassOf(pmdco:PMD_0020161 pmdco:PMD_0080005)

# Class: pmdco:PMD_0020162 (Aktivierungsenergie)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020162 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020162 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020162 "Aktivierungsenergie"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020162 "activation energy"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020162 "Activation energy (E_a) a process attribute characterizing the minimum amount of energy required to initiate a reaction, allowing educts to overcome an energy barrier to transform into products."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020162 "Aktivierungsenergie (E_a) ist ein Prozessmerkmal, das die minimale Energiemenge charakterisiert, die zum Initiieren einer Reaktion erforderlich ist und es Edukten ermöglicht, eine Energiebarriere zu überwinden, um sich in Produkte umzuwandeln."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020162 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020162 pmdco:PMD_0000008)

# Class: pmdco:PMD_0020163 (eutectic phase transformation)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020163 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020163 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020163 "eutectic phase transformation"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020163 "eutektische Phasenumwandlung"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020163 "A eutectic phase transformation is a phase transformation in which a liquid parent phase decomposes into two distinct solid daughter phases at constant temperature and pressure."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020163 "Eine eutektische Phasenumwandlung ist eine Phasenumwandlung, bei der eine flüssige Mutterphase bei konstanter Temperatur und konstantem Druck in zwei verschiedene feste Tochterphasen zerfällt."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020163 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020163 pmdco:PMD_0020136)

# Class: pmdco:PMD_0020164 (state of matter boundary)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020164 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020164 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020164 "Zustandsgrenze der Materie"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020164 "state of matter boundary"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020164 "A state of matter boundary is a phase boundary that is realized by the transition from one aggregate state to another aggregate state."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020164 "Eine Zustandsgrenze ist eine Phasengrenze, die durch den Übergang von einem Aggregatzustand in einen anderen Aggregatzustand realisiert wird."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020164 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020164 pmdco:PMD_0000882)

# Class: pmdco:PMD_0020165 (Disposition einer Phase zur Transformation)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020165 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020165 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:comment pmdco:PMD_0020165 "The disposition is grounded in the phases activity in the thermodynamic system in question."@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020165 "Disposition einer Phase zur Transformation"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020165 "disposition of a phase to transform"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020165 "Die Disposition einer Phase zur Umwandlung in eine andere Phase in einem Phasenumwandlungsprozess."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020165 "The disposition of a phase to transform into another phase in a phase transformation process."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020165 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020165 obo:BFO_0000016)

# Class: pmdco:PMD_0020167 (strukturelle Grenze)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020167 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020167 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020167 "structural boundary"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020167 "strukturelle Grenze"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020167 "Structural phase boundary is a phase boundary that is realized in the transition from one structure to another structure."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020167 "Strukturelle Phasengrenze ist eine Phasengrenze, die beim Übergang von einer Struktur zu einer anderen Struktur realisiert wird."@de)
AnnotationAssertion(skos:example pmdco:PMD_0020167 "ɑ-Ɣ transformation in iron at 910 °C"@en)
SubClassOf(pmdco:PMD_0020167 pmdco:PMD_0000882)

# Class: pmdco:PMD_0020168 (magnetic boundary)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020168 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020168 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020168 "magnetic boundary"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0020168 "magnetische Grenze"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020168 "A magnetic boundary is a phase boundary that is realized by the transition from one magnetic ordering to another magnetic ordering."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020168 "Eine magnetische Grenze ist eine Phasengrenze, die durch den Übergang von einer magnetischen Ordnung zu einer anderen magnetischen Ordnung realisiert wird."@de)
SubClassOf(pmdco:PMD_0020168 pmdco:PMD_0000882)

# Class: pmdco:PMD_0020169 (mixture boundary)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020169 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020169 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020169 "Mischungsgrenze"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020169 "mixture boundary"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020169 "A mixture boundary is a phase boundary that is realized by the transition from one phase to another phase in a system involving also chemical variations."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020169 "Eine Gemischgrenze ist eine Phasengrenze, die durch den Übergang von einer Phase in eine andere Phase in einem System realisiert wird, das auch chemische Variationen beinhaltet."@de)
SubClassOf(pmdco:PMD_0020169 pmdco:PMD_0000882)

# Class: pmdco:PMD_0020171 (Phasengrenze (räumlich))

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020171 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0020171 "Should it have exactly two phases as member parts?"@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020171 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020171 "Phasengrenze (räumlich)"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020171 "phase boundary (spatial)"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020171 "A fiat surface separating one phase from another phase."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020171 "Eine flache Oberfläche, die eine Phase von einer anderen trennt."@de)
AnnotationAssertion(skos:example pmdco:PMD_0020171 "The phase boundary between liquid and the gaseous phase in a tank. 
The phase boundary between Fe3C and Fe of a pearlite lamellae."@en)
SubClassOf(pmdco:PMD_0020171 obo:BFO_0000146)

# Class: pmdco:PMD_0020190 (metallografischer Schnitt (Oberfläche))

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020190 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020190 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020190 "metallografischer Schnitt (Oberfläche)"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020190 "metallographic section (surface)"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020190 "A surface layer (fiat object part) of an object which at the same time is a metal and the object is specified output of a planned process which describes the preparation of the surface."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020190 "Eine Oberflächenschicht (Fiat-Objektteil) eines Objekts, die gleichzeitig ein Metall ist und das Objekt ist das spezifizierte Ergebnis eines geplanten Prozesses, der die Vorbereitung der Oberfläche beschreibt."@de)
SubClassOf(pmdco:PMD_0020190 pmdco:PMD_0000965)

# Class: pmdco:PMD_0020192 (macrosection (metallography))

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020192 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020192 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020192 "Makroschliff (Metallographie)"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020192 "macrosection (metallography)"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020192 "A macrosection (metallography) is a metallographic section (surface) that is produced directly on an object. The object may be cut in order to make accessible a section (fiat surface) of interest."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020192 "Ein Makroschliff (Metallografie) ist ein metallografischer Schnitt (Oberfläche), der direkt an einem Objekt angefertigt wird. Das Objekt kann geschnitten werden, um einen interessierenden Abschnitt (flache Oberfläche) zugänglich zu machen."@de)
SubClassOf(pmdco:PMD_0020192 pmdco:PMD_0020190)

# Class: pmdco:PMD_0020200 (force)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020200 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020200 "PERSON: Philipp von Hartrott")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0020200 "Old definition: Force is a reciprocal relation realized between two objects where the other object exerts the same force with opposite sign onto the first. Force may be responsible for changes in velocity and/or deformation of objects.")
AnnotationAssertion(rdfs:label pmdco:PMD_0020200 "Kraft"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020200 "force"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020200 "A force is a realizable entity that consists of a reciprocal interaction between two objects and is realized as equal and opposite influences capable of changing motion or causing deformation."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020200 "Eine Kraft ist eine realisierbare Einheit, die aus einer wechselseitigen Wechselwirkung zwischen zwei Objekten besteht und als gleiche und entgegengesetzte Einflüsse realisiert wird, die eine Bewegung ändern oder eine Verformung verursachen können."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020200 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020200 pmdco:PMD_0080069)

# Class: pmdco:PMD_0020201 (Abschnitt)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020201 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020201 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020201 "Abschnitt"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020201 "section"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020201 "Ein Abschnitt ist eine ebene, flache Oberfläche, die das Objekt durchschneidet"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020201 "Section is a planar fiat surface cutting across the object"@en)
SubClassOf(pmdco:PMD_0020201 obo:BFO_0000146)

# Class: pmdco:PMD_0020202 (Riss)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020202 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020202 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020202 "Riss"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020202 "crack"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020202 "A crack is a site that consists of a physical separation within a material entity occurring at the level of atomic bonds."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020202 "Ein Riss ist eine Stelle, die aus einer physikalischen Trennung innerhalb einer Materialeinheit besteht, die auf der Ebene atomarer Bindungen erfolgt."@de)
SubClassOf(pmdco:PMD_0020202 obo:BFO_0000029)

# Class: pmdco:PMD_0020203 (Kerbe)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020203 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020203 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020203 "Kerbe"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020203 "notch"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020203 "A notch is a site that consists of a geometric surface feature of an object characterized by a strong local change in shape or cross-section."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020203 "Eine Kerbe ist eine Stelle, die aus einem geometrischen Oberflächenmerkmal eines Objekts besteht, das durch eine starke lokale Änderung der Form oder des Querschnitts gekennzeichnet ist."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020203 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020203 obo:BFO_0000029)

# Class: pmdco:PMD_0020204 (Pore)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020204 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020204 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020204 "Pore"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020204 "pore"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020204 "A pore is a site that consists of a cavity located within the bulk of a material entity."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020204 "Eine Pore ist eine Stelle, die aus einem Hohlraum besteht, der sich innerhalb der Masse eines Materialgebildes befindet."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020204 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020204 obo:BFO_0000029)

# Class: pmdco:PMD_0020205 (Defektrolle)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020205 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020205 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020205 "Defektrolle"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020205 "defect role"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020205 "A defect role is a role of an independent continuant C indicating that C may affect a material entity E's ability to realize a function. C is continuant part of E."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020205 "Eine Defektrolle ist eine Rolle eines unabhängigen Kontinuums C, die darauf hinweist, dass C die Fähigkeit einer materiellen Entität E, eine Funktion zu realisieren, beeinträchtigen kann. C ist fortlaufender Teil von E."@de)
AnnotationAssertion(skos:example pmdco:PMD_0020205 "A crack in an structural member may affect its ability to carry a load."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020205 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0020205 obo:BFO_0000023)

# Class: pmdco:PMD_0020207 (amount of substance)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0020207 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0020207 "PERSON: Philipp von Hartrott")
AnnotationAssertion(rdfs:label pmdco:PMD_0020207 "Stoffmenge"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020207 "amount of substance"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0020207 "number of moles of an entity"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020207 "Amount of substance n is a molar proportion when the whole is an object aggregate N, which has avogadro number objects (of same type) as parts (n = N/N_A)."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020207 "Die Menge der Substanz n ist ein molarer Anteil, wenn das Ganze ein Objektaggregat N ist, das Avogadro-Anzahlobjekte (gleicher Art) als Teile hat (n = N/N_A)."@de)
SubClassOf(pmdco:PMD_0020207 pmdco:PMD_0020148)
SubClassOf(pmdco:PMD_0020207 ObjectSomeValuesFrom(obo:RO_0000080 obo:BFO_0000027))

