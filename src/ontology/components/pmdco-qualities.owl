AnnotationAssertion(rdfs:label pmdco:PMD_0080175 "extentional viscosity"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080175 "Die Dehnviskosität ist die Messung des Widerstands einer Flüssigkeit gegen den Fluss bei Dehnspannung"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080175 "Extentional viscosity measures a fluid's resistance to tension flow"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080175 "A polymer melt shows an extensional viscosity three times its shear viscosity at low strain rates"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080175 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080175 pmdco:PMD_0080174)

