AnnotationAssertion(skos:example pmdco:PMD_0080021 "A concrete wall has a sound reflection coefficient near 0.99 at 500 Hz, acting nearly as a perfect reflector"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080021 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080021 pmdco:PMD_0000506)
