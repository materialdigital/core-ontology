AnnotationAssertion(skos:definition pmdco:PMD_0080187 "Strahlungsabsorptionsfähigkeit beschreibt die Fähigkeit einer Entität, elektromagnetische Strahlung zu absorbieren"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080187 "Carbon black pigment has high radiation absorption capability, absorbing over 99 % of incident visible light"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080187 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080187 pmdco:PMD_0000877)

