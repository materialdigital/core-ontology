AnnotationAssertion(skos:definition pmdco:PMD_0080189 "Strahlungsübertragungsfähigkeit beschreibt die Fähigkeit einer Entität, elektromagnetische Strahlung zu übertragen"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080189 "A thin beryllium window has high radiation transmission capability for soft X-rays, passing over 90 % of flux"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080189 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080189 pmdco:PMD_0000877)

# Class: pmdco:PMD_0080191 (thermal capacity)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080191 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080191 "Necessary and sufficient conditions for 'thermal capacity' have not yet been formalized. The term is defined as a specific subtype of 'thermal capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Heat_capacity."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080191 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080191 <https://en.wikipedia.org/wiki/Heat_capacity>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080191 "thermal capacity"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080191 "thermische Kapazität"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080191 "Wärmekapazität"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080191 "heat capacity"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080191 "Thermal capacity, or heat capacity, is defined as the amount of heat required to produce a unit change in temperature of an object"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080191 "Wärmekapazität, auch als thermische Kapazität bekannt, ist die Menge an Wärme, die erforderlich ist, um eine Änderung der Temperatur eines Objekts um eine Einheit zu erzeugen"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080191 "A steel block of 1 kg has a thermal capacity of 500 J/K, absorbing heat with moderate temperature rise"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080191 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080191 pmdco:PMD_0000981)

# Class: pmdco:PMD_0080192 (flammability)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080192 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080192 "Necessary and sufficient conditions for 'flammability' have not yet been formalized. The term is defined as a specific subtype of 'thermal capability'. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080192 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080192 "Entflammbarkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080192 "flammability"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080192 "Brennbarkeit"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080192 "combustibility"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080192 "Entflammbarkeit ist eine thermische Fähigkeit eines Materials, die seine Fähigkeit beschreibt, bei Exposition gegenüber einer Flamme oder Wärmequelle unter festgelegten Bedingungen zu entzünden und die Verbrennung aufrechtzuerhalten"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080192 "Flammability is a thermal capability of a material that characterises its ability to ignite and sustain combustion when exposed to a flame or heat source under specified conditions"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080192 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080192 pmdco:PMD_0000981)

# Class: pmdco:PMD_0080194 (thermische Isolierung)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080194 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080194 "Necessary and sufficient conditions for 'thermal insulation' have not yet been formalized. The term is defined as a specific subtype of 'thermal capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Thermal_insulation."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080194 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080194 <https://en.wikipedia.org/wiki/Thermal_insulation>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080194 "thermal insulation"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080194 "thermische Isolierung"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080194 "Thermal insulation reduces heat transfer between objects in thermal contact or radiative influence, achieved with engineered methods or material properties"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080194 "Thermische Isolierung verringert den Wärmeaustausch zwischen Objekten, die in thermischem Kontakt oder Strahlungseinfluss stehen, realisiert durch spezielle Konstruktionsmethoden oder Materialien"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080194 "Glass wool with a thermal conductivity of 0.04 W/(m·K) provides effective thermal insulation in building walls"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080194 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080194 pmdco:PMD_0000981)

# Class: pmdco:PMD_0080195 (radiant energy)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080195 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080195 "Necessary and sufficient conditions for 'radiant energy' have not yet been formalized. The term is defined as a specific subtype of 'thermal capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Radiant_energy."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080195 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080195 <https://en.wikipedia.org/wiki/Radiant_energy>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080195 "Strahlungsenergie"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080195 "radiant energy"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080195 "Radiant energy refers to the energy of electromagnetic radiation, calculated by integrating radiant flux over time"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080195 "Strahlungsenergie bezieht sich auf die Energie elektromagnetischer Strahlung, die durch Integration des Strahlungsflusses über die Zeit berechnet wird"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080195 "A pulsed laser delivers 1 mJ of radiant energy per pulse to the workpiece surface"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080195 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080195 pmdco:PMD_0000981)

# Class: pmdco:PMD_0080196 (thermal expansion coefficient)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080196 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080196 "Necessary and sufficient conditions for 'thermal expansion coefficient' have not yet been formalized. The term is defined as a specific subtype of 'thermal capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080196 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080196 "thermal expansion coefficient"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080196 "thermischer Ausdehnungkoeffizient"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080196 "Thermal expansion coefficient quantifies the degree to which a material expands upon heating, representing fractional change per degree temperature increase"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080196 "Thermischer Ausdehnungkoeffizient quantifiziert den Grad, in dem ein Material beim Erhitzen expandiert, und stellt die proportionale Änderung pro Temperaturanstieg dar"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080196 "The thermal expansion coefficient of borosilicate glass is 3.3e-6 per K, enabling thermal shock resistance"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080196 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080196 pmdco:PMD_0000981)

# Class: pmdco:PMD_0080197 (volumetric thermal expansion coefficient)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080197 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080197 "Necessary and sufficient conditions for 'volumetric thermal expansion coefficient' have not yet been formalized. The term is defined as a specific subtype of 'thermal expansion coefficient'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080197 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080197 "thermischer Volumenausdehnungskoeffizient"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080197 "volumetric thermal expansion coefficient"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080197 "Der volumetrische Wärmeausdehnungskoeffizient quantifiziert den Grad, um den sich ein Material beim gleichzeitigen Erhitzen in alle drei axialen Richtungen ausdehnt"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080197 "Volumetric thermal expansion coefficient quantifies the degree to which a material expands upon heating into all three axial directions simultaneously"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080197 "Liquid water near 4 C has a near-zero volumetric thermal expansion coefficient, giving maximum density"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080197 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080197 pmdco:PMD_0080196)

# Class: pmdco:PMD_0080198 (linear thermal expansion coefficient)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080198 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080198 "Necessary and sufficient conditions for 'linear thermal expansion coefficient' have not yet been formalized. The term is defined as a specific subtype of 'thermal expansion coefficient'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080198 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080198 "linear thermal expansion coefficient"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080198 "linearer thermischer Ausdehnungkoeffizient"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080198 "Der lineare Wärmeausdehnungskoeffizient quantifiziert den Grad, um den sich ein Material beim Erhitzen in eine bestimmte axiale Richtung ausdehnt"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080198 "Linear thermal expansion coefficient quantifies the degree to which a material expands upon heating into a specific axial direction"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080198 "Aluminum has a linear thermal expansion coefficient of 23.1e-6 per K, causing notable dimensional changes during heating"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080198 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080198 pmdco:PMD_0080196)

# Class: pmdco:PMD_0080200 (flame resistance)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080200 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080200 "Necessary and sufficient conditions for 'flame resistance' have not yet been formalized. The term is defined as a specific subtype of 'thermal capability', disjoint from 'flammability' as the inverse capability. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080200 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080200 "Flammbeständigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080200 "flame resistance"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080200 "Brandbeständigkeit"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080200 "fire resistance"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080200 "Flame resistance is a thermal capability of a material that characterises its ability to resist ignition and inhibit the spread of combustion when exposed to a flame or heat source"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080200 "Flammbeständigkeit ist eine thermische Fähigkeit eines Materials, die seine Fähigkeit beschreibt, einer Entzündung zu widerstehen und die Ausbreitung der Verbrennung bei Exposition gegenüber einer Flamme oder Wärmequelle zu verhindern"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080200 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080200 pmdco:PMD_0000981)

# Class: pmdco:PMD_0080201 (thermische Leitfähigkeit)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080201 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080201 "Necessary and sufficient conditions for 'thermal conductance' have not yet been formalized. The term is defined as a specific subtype of 'thermal capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080201 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080201 "thermal conductance"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080201 "thermische Leitfähigkeit"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080201 "Thermal conduction refers to the process by which heat is transferred from the hotter end to the colder end of an object, characterized by conductance"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080201 "Thermische Leitung beschreibt den Prozess, bei dem Wärme vom heißeren zum kälteren Ende eines Objekts übertragen wird, gekennzeichnet durch Leitfähigkeit"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080201 "A copper heat spreader of 2 mm thickness has a high thermal conductance, efficiently dissipating chip heat"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080201 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080201 pmdco:PMD_0000981)

# Class: pmdco:PMD_0080202 (thermal shock resistance)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080202 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080202 "Necessary and sufficient conditions for 'thermal shock resistance' have not yet been formalized. The term is defined as a specific subtype of 'thermal capability'. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080202 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080202 "Thermoschockbeständigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080202 "thermal shock resistance"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080202 "Temperaturwechselbeständigkeit"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080202 "Thermal shock resistance is a thermal capability of a material that characterises its ability to withstand rapid and large changes in temperature without cracking, spalling, or loss of mechanical integrity"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080202 "Thermoschockbeständigkeit ist eine thermische Fähigkeit eines Materials, die seine Fähigkeit beschreibt, schnelle und große Temperaturänderungen ohne Rissbildung, Abplatzungen oder Verlust der mechanischen Integrität zu überstehen"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080202 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080202 pmdco:PMD_0000981)

# Class: pmdco:PMD_0080203 (radiation emission capability)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080203 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080203 "Necessary and sufficient conditions for 'radiation emission capability' have not yet been formalized. The term is defined as a specific subtype of 'physical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080203 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080203 "Strahlungsemissionsfähigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080203 "radiation emission capability"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080203 "Die Strahlungsemissionsfähigkeit ist die physikalische Fähigkeit eines materiellen Wesens, elektromagnetische Strahlung auszusenden, die in Prozessen realisiert wird, bei denen der Träger Energie in Form elektromagnetischer Wellen ausstrahlt"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080203 "Radiation emission capability is a physical capability of a material entity to emit electromagnetic radiation, realized in processes where the bearer radiates energy in the form of electromagnetic waves"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080203 "A tungsten filament at 2800 K has significant radiation emission capability, producing visible white light"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080203 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080203 obo:BFO_0000016)

# Class: pmdco:PMD_0080204 (Wasseraufnahme)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080204 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080204 "Necessary and sufficient conditions for 'water absorption' have not yet been formalized. The term is defined as a specific subtype of 'physical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080204 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080204 "Wasseraufnahme"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080204 "water absorption"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080204 "Wasseraufnahme ist eine physische Fähigkeit eines Materials, Wasser aufzunehmen, quantifiziert als Massenzunahme einer Probe im Verhältnis zur anfänglichen Trockenmasse"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080204 "Water absorption is a physical capability of a material to take up water, quantified as the increase in mass of a specimen relative to its initial dry mass"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080204 "Water absorption of a nylon 6 specimen immersed for 24 hours expressed as 2.5% of its dry mass, measured according to ISO 62."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080204 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080204 obo:BFO_0000016)

# Class: pmdco:PMD_0080597 (vector density fields)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080597 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080597 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080597 "Vektorfelddichte"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080597 "vector density fields"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080597 "Vektorfeld, bei dem die Größe an einem bestimmten Punkt die Konzentration oder den Fluss einer physikalischen Größe darstellt, die durch eine Einheitsfläche senkrecht zur Richtung des Vektors verläuft"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080597 "vector field where the magnitude at any given point represents the concentration or flux of a physical quantity passing through a unit area perpendicular to the vector's direction"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080597 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080597 pmdco:PMD_0020131)

# Class: pmdco:PMD_0090001 (Halbleitfähigkeit)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0090001 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0090001 "PERSON: thnlrd")
AnnotationAssertion(rdfs:label pmdco:PMD_0090001 "Halbleitfähigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0090001 "semiconductivity"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0090001 "Semiconductivity is the disposition of a material to conduct electricity only when a certain level of excitation (via temperature, impurities, photonic excitation, electric field) elevates electrons from the valence band into the conduction band."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0090001 "Unter Halbleiterfähigkeit versteht man die Eigenschaft eines Materials, Elektrizität nur dann zu leiten, wenn ein bestimmtes Maß an Anregung (durch Temperatur, Verunreinigungen, photonische Anregung, elektrisches Feld) Elektronen aus dem Valenzband in das Leitungsband hebt."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0090001 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0090001 pmdco:PMD_0000621)

# Class: pmdco:PMD_0090002 (Bandlücke)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0090002 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0090002 "PERSON: thnlrd")
AnnotationAssertion(rdfs:label pmdco:PMD_0090002 "Bandlücke"@de)


