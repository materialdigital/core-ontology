AnnotationAssertion(skos:altLabel pmdco:PMD_0080177 "kinematic viscosity"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080177 "kinematische Viskosität"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080177 "kinetic viscosity"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080177 "kinetische Viskosität"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080177 "Die kinematische Viskosität ist das Verhältnis der dynamischen Viskosität zur Dichte"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080177 "Kinematic viscosity is the ratio of dynamic viscosity to density"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080177 "The kinematic viscosity of water at 20 C is about 1e-6 m2/s, used in pipe flow calculations"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080177 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080177 pmdco:PMD_0080174)

# Class: pmdco:PMD_0080178 (dynamische Viskosität)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080178 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080178 "Necessary and sufficient conditions for 'dynamic viscosity' have not yet been formalized. The term is defined as a specific subtype of 'viscosity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080178 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080178 "dynamic viscosity"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080178 "dynamische Viskosität"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080178 "dynamic viscosity"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080178 "dynamische Viskosität"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080178 "Die dynamische Viskosität ist ein Maß für den Widerstand eines Fluids gegen eine allmähliche Verformung durch Scher- oder Zugspannung. Es ist ein Maß für den inneren Widerstand des Fluids gegen den Fluss und kann als Maß für die Flüssigkeitsreibung betrachtet werden"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080178 "Dynamic viscosity measures a fluid's resistance to gradual deformation by shear stress or tensile stress, indicative of the fluid's internal friction"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080178 "Motor oil at 40 C has a dynamic viscosity of about 100 mPa·s, resisting flow under shear"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080178 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080178 pmdco:PMD_0080174)

# Class: pmdco:PMD_0080179 (volume viscosity)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080179 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080179 "Necessary and sufficient conditions for 'volume viscosity' have not yet been formalized. The term is defined as a specific subtype of 'viscosity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080179 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080179 "Volumenviskosität"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080179 "volume viscosity"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080179 "Volume viscosity measures a fluid's resistance to volumetric stress"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080179 "Volumenviskosität misst den Widerstand eines Fluids gegenüber volumetrischer Belastung"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080179 "Water has a volume viscosity of about 3 mPa·s at 25 C, relevant in acoustic wave propagation"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080179 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080179 pmdco:PMD_0080174)

# Class: pmdco:PMD_0080180 (Sprödigkeit)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080180 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080180 "Necessary and sufficient conditions for 'brittleness' have not yet been formalized. The term is defined as a specific subtype of 'mechanical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080180 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080180 "Sprödigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080180 "brittleness"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080180 "Sprödigkeit"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080180 "Zerbrechlichkeit"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080180 "brittleness"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080180 "fragility"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080180 "Opposite to toughness, brittleness is the property of being easily broken or damaged"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080180 "Sprödigkeit ist die Eigenschaft, leicht zu brechen oder zu beschädigen"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080180 "Cast iron has high brittleness, fracturing without measurable plastic deformation under tensile loading"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080180 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080180 pmdco:PMD_0000848)

# Class: pmdco:PMD_0080181 (ductility)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080181 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080181 "Necessary and sufficient conditions for 'ductility' have not yet been formalized. The term is defined as a specific subtype of 'mechanical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080181 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080181 "Duktilität"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080181 "ductility"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080181 "Biegsamkeit"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080181 "Duktilität"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080181 "ductility"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080181 "flexibility"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080181 "Ductility is the ability of a material to deform plastically without breaking"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080181 "Duktilität ist die Fähigkeit eines Materials, plastisch zu verformen, ohne zu brechen"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080181 "Low-carbon steel has high ductility, with elongation at break exceeding 30 %"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080181 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080181 pmdco:PMD_0000848)

# Class: pmdco:PMD_0080182 (Formbarkeit)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080182 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080182 "Necessary and sufficient conditions for 'malleability' have not yet been formalized. The term is defined as a specific subtype of 'ductility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080182 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080182 "Formbarkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080182 "malleability"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080182 "Formbarkeit"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080182 "Malleability"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080182 "Malleable"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080182 "formbar"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080182 "Formbarkeit beschreibt Materialien, die durch Hammern oder Walzen bearbeitet werden können und sich von Duktilität unterscheiden"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080182 "Malleability refers to a material's amenability to forming by hammering or rolling, distinct from ductility"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080182 "Gold has high malleability, allowing it to be hammered into sheets less than 100 nm thick"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080182 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080182 pmdco:PMD_0080181)

# Class: pmdco:PMD_0080184 (Resilienz)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080184 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080184 "Necessary and sufficient conditions for 'resilience' have not yet been formalized. The term is defined as a specific subtype of 'mechanical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080184 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080184 "Resilienz"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080184 "resilience"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080184 "Resilienzmodul"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080184 "modulus of resilience"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080184 "Elastizität ist die mechanische Fähigkeit eines Materials, bei elastischer Verformung Energie zu absorbieren und diese Energie bei Entlastung ohne bleibende Verformung abzugeben"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080184 "Resilience is a mechanical capability of a material to absorb energy when elastically deformed and release that energy upon unloading without permanent deformation"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080184 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080184 pmdco:PMD_0000848)

