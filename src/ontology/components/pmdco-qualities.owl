AnnotationAssertion(skos:definition pmdco:PMD_0080176 "Shear viscosity measures a fluid's resistance to shear flow"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080176 "The shear viscosity of glycerol at 25 C is about 1.5 Pa·s, much higher than water"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080176 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080176 pmdco:PMD_0080174)

# Class: pmdco:PMD_0080177 (kinematische Viskosität)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080177 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080177 "Necessary and sufficient conditions for 'kinematic viscosity' have not yet been formalized. The term is defined as a specific subtype of 'viscosity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080177 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080177 "kinematic viscosity"@en)
