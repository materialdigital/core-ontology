AnnotationAssertion(skos:definition pmdco:PMD_0020009 "orthorhombic Bravais lattice with primitive centering (oP), having three mutually perpendicular 2-fold rotation axes and one lattice point per unit cell"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020009 "orthorhombisches Bravais-Gitter mit primitiver Zentrierung (oP), mit drei zueinander senkrechten zweizähligen Rotationsachsen und einem Gitterpunkt pro Elementarzelle"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020009 "true"^^xsd:boolean)

