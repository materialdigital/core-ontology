AnnotationAssertion(rdfs:label pmdco:PMD_0080157 "shear strength"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080157 "shear breaking strength"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080157 "Scherfestigkeit ist die maximale Scherspannung, die ein Material entlang einer zur aufgebrachten Kraft parallelen Ebene vor dem Versagen widerstehen kann"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080157 "Shear strength is the maximum shear stress a material can withstand before failure along a plane parallel to the applied force"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080157 "Shear strength of a CFRP laminate specimen measured as 85 MPa according to ISO 14130 test conditions."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080157 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080157 pmdco:PMD_0080153)

# Class: pmdco:PMD_0080158 (operational strength)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080158 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080158 "Necessary and sufficient conditions for 'operational strength' have not yet been formalized. The term is defined as a specific subtype of 'strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080158 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080158 "Betriebsfestigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080158 "operational strength"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080158 "Betriebsfestigkeit"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080158 "Betriebsstärke"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080158 "operation strength"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080158 "operational strength"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080158 "Betriebsfestigkeit beschreibt die Fähigkeit eines Systems, seine vorgesehene Funktion in einer betrieblichen Umgebung auszuführen"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080158 "Operational strength describes a system's ability to perform its intended function in an operational environment"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080158 "The operational strength of a drive shaft is the maximum cyclic stress it sustains without fatigue failure in service"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080158 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080158 pmdco:PMD_0000952)

# Class: pmdco:PMD_0080159 (Witterungsbeständigkeit)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080159 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080159 "Necessary and sufficient conditions for 'weathering resistance' have not yet been formalized. The term is defined as a specific subtype of 'operational strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080159 "Was a subclass of 'Operational Strength';  But 'Operational Strength' does not appear to be Quality."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080159 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080159 "Witterungsbeständigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080159 "weathering resistance"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080159 "Witterungsbeständigkeit"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080159 "weather resistant"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080159 "weathering resistance"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080159 "wetterbeständig"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080159 "Ability of a material to resist the effects of weathering, such as wind, rain, and sunlight."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080159 "Fähigkeit eines Materials, den Auswirkungen von Witterungseinflüssen wie Wind, Regen und Sonnenlicht standzuhalten."@de)
AnnotationAssertion(skos:example pmdco:PMD_0080159 "HDPE pipes show high weathering resistance, retaining mechanical properties after years of UV exposure"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080159 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080159 pmdco:PMD_0000952)
SubClassOf(pmdco:PMD_0080159 pmdco:PMD_0080158)

# Class: pmdco:PMD_0080161 (mechanical strength)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080161 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080161 "Necessary and sufficient conditions for 'mechanical strength' have not yet been formalized. The term is defined as a specific subtype of 'strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080161 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080161 "Festigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080161 "mechanical strength"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080161 "Festigkeit in der Mechanik von Materialien bezeichnet die Fähigkeit eines Materials, eine angewandte Last ohne Versagen oder plastische Verformung zu widerstehen. Innere Kräfte werden auf der Basis einer Einheit als Spannungen ausgedrückt und bewirken eine Verformung des Materials, bekannt als Dehnung"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080161 "Mechanical strength refers to a material's ability to resist applied load without failure or plastic deformation, characterized by stress and strain"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080161 "The mechanical strength of a fiber composite increases with fiber volume fraction up to an optimum value"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080161 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080161 pmdco:PMD_0000952)

# Class: pmdco:PMD_0080162 (proof strength)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080162 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080162 "Necessary and sufficient conditions for 'proof strength' have not yet been formalized. The term is defined as a specific subtype of 'mechanical strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080162 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080162 "Festigkeitsnachweis"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080162 "proof strength"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080162 "proof stress"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080162 "Die Dehngrenze bezieht sich auf die Spannung, die ein Material aushalten kann, bis eine geringe plastische Verformung auftritt"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080162 "Proof strength refers to the stress a material can endure until exhibiting a small amount of plastic deformation"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080162 "The Rp0.2 proof strength of stainless steel 316L is approximately 170 MPa"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080162 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080162 pmdco:PMD_0080161)

# Class: pmdco:PMD_0080163 (fatigue strength)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080163 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080163 "Necessary and sufficient conditions for 'fatigue strength' have not yet been formalized. The term is defined as a specific subtype of 'strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080163 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080163 "Ermüdungsfestigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080163 "fatigue strength"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080163 "Ermüdungsfestigkeit"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080163 "fatigue strength"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080163 "Ermüdungsfestigkeit bezeichnet die Fähigkeit eines Materials, Ermüdung oder zyklische Belastung zu widerstehen"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080163 "Fatigue strength denotes a material's ability to resist fatigue or cyclic loading"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080163 "The fatigue strength of steel at 10^7 cycles is approximately half its tensile strength"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080163 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080163 pmdco:PMD_0000952)

# Class: pmdco:PMD_0080164 (elasticity)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080164 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080164 "Necessary and sufficient conditions for 'elasticity' have not yet been formalized. The term is defined as a specific subtype of 'strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080164 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080164 "Elastizität"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080164 "elasticity"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080164 "Elastizität"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080164 "Widerstandsfähigkeit"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080164 "elastic"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080164 "elasticity"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080164 "elastisch"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080164 "resilience"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080164 "Elasticity is the ability of an object or material to resume its normal shape after deformation"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080164 "Elastizität ist die Fähigkeit eines Objekts oder Materials, nach Deformation seine normale Form wiederherzustellen"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080164 "Rubber exhibits high elasticity, recovering its original shape after 300 % elongation"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080164 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080164 pmdco:PMD_0000848)

# Class: pmdco:PMD_0080166 (shear modulus)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080166 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080166 "Necessary and sufficient conditions for 'shear modulus' have not yet been formalized. The term is defined as a specific subtype of 'stiffness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Shear_modulus."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080166 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080166 <https://en.wikipedia.org/wiki/Shear_modulus>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080166 "Schubmodul"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080166 "shear modulus"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080166 "Schubmodul ist ein Maß für die elastische Schersteifigkeit, definiert als Verhältnis von Schubspannung zu Scherdehnung"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080166 "Shear modulus is a measure of elastic shear stiffness, defined as the ratio of shear stress to shear strain"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080166 "The shear modulus of aluminum is 26 GPa, governing torsional deformation of shafts"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080166 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080166 pmdco:PMD_0000949)

# Class: pmdco:PMD_0080167 (specific elastic modulus)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080167 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080167 "Necessary and sufficient conditions for 'specific elastic modulus' have not yet been formalized. Although specific elastic modulus is defined as a ratio of elastic modulus to density, a co-inherence axiom cannot uniquely identify this quality among all stiffness qualities of the same bearer. The term is defined as a specific subtype of 'stiffness'."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080167 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080167 "specific elastic modulus"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080167 "spezifischer Elastizitätsmodul"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080167 "specific modulus"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080167 "specific stiffness"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080167 "spezifische Steifigkeit"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080167 "spezifischer Modul"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080167 "Specific elastic modulus is a stiffness quality of a material expressed as the ratio of its elastic modulus to its density, representing the material's elastic stiffness per unit mass"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080167 "Spezifischer Elastizitätsmodul ist eine Steifigkeitsqualität eines Materials, ausgedrückt als Verhältnis seines Elastizitätsmoduls zu seiner Dichte und repräsentiert die elastische Steifigkeit des Materials je Masseneinheit"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080167 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080167 pmdco:PMD_0000949)

# Class: pmdco:PMD_0080168 (flexural modulus)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080168 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080168 "Necessary and sufficient conditions for 'flexural modulus' have not yet been formalized. The term is defined as a specific subtype of 'stiffness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080168 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080168 "Biegemodul"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080168 "flexural modulus"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080168 "bending modulus"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080168 "Biegemodul ist eine Steifigkeitsqualität eines Materials, die das Verhältnis von Spannung zu Dehnung im elastischen Bereich eines Biegeversuchs beschreibt und den Widerstand gegen elastische Verformung unter Biegebelastung repräsentiert"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080168 "Flexural modulus is a stiffness quality of a material that specifies the ratio of stress to strain in the elastic region of a bending test, representing resistance to elastic deformation under flexural load"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080168 "Flexural modulus of a glass-fibre reinforced polyamide measured as 9.5 GPa under ISO 178 three-point bending test conditions."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080168 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080168 pmdco:PMD_0000949)

# Class: pmdco:PMD_0080169 (Haftfestigkeit)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080169 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080169 "Necessary and sufficient conditions for 'adhesion strength' have not yet been formalized. The term is defined as a specific subtype of 'strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080169 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080169 "Haftfestigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080169 "adhesion strength"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080169 "Adhesion Strength"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080169 "Adhesive Strength"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080169 "Haftfestigkeit"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080169 "Klebkraft"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080169 "Adhesion strength measures the force required to separate two surfaces bonded together"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080169 "Haftfestigkeit ist das Maß für die Kraft, die erforderlich ist, um zwei miteinander verbundene Oberflächen zu trennen"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080169 "An epoxy adhesive joint on steel substrates has an adhesion strength of 20 MPa in lap shear testing"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080169 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080169 pmdco:PMD_0000952)

# Class: pmdco:PMD_0080170 (plasticity)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080170 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080170 "Necessary and sufficient conditions for 'plasticity' have not yet been formalized. The term is defined as a specific subtype of 'strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080170 "PERSON: Thomas Hanke")
