SubClassOf(pmdco:PMD_0080170 pmdco:PMD_0000848)

# Class: pmdco:PMD_0080171 (Fließgrenze)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080171 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080171 "Necessary and sufficient conditions for 'yield strength' have not yet been formalized. The term is defined as a specific subtype of 'plasticity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080171 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080171 "Fließgrenze"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080171 "yield strength"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080171 "yield stress"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080171 "Fließgrenze bezeichnet das Spannungsniveau, bei dem sich Material beginnt, plastisch zu verformen und das Ende des elastischen Verhaltens markiert"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080171 "Yield strength signfies the stress level at which material begins to deform plastically, marking the end of elastic behavior"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080171 "The yield strength of mild steel is approximately 250 MPa, beyond which permanent deformation begins"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080171 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080171 pmdco:PMD_0000005)

# Class: pmdco:PMD_0080172 (untere Streckgrenze)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080172 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080172 "Necessary and sufficient conditions for 'lower yield strength' have not yet been formalized. The term is defined as a specific subtype of 'yield strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Yield_(engineering)."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080172 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080172 <https://en.wikipedia.org/wiki/Yield_(engineering)>)
