AnnotationAssertion(skos:altLabel pmdco:PMD_0080048 "Nullduktilitäts-Übergangstemperatur"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080048 "T_DBTT"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080048 "nil ductility transition temperature"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080048 "Ductile-brittle transition temperature is a thermodynamic quality of a material that specifies the temperature below which the material exhibits brittle fracture behaviour rather than ductile deformation under impact loading"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080048 "Duktil-Spröd-Übergangstemperatur ist eine thermodynamische Qualität eines Materials, die die Temperatur angibt, unterhalb derer das Material unter Schlagbelastung ein sprödes Bruchverhalten anstelle einer duktilen Verformung zeigt"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080048 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080048 pmdco:PMD_0000967)

# Class: pmdco:PMD_0080049 (Glasübergangstemperatur)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080049 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080049 "Necessary and sufficient conditions for 'glass transition temperature' have not yet been formalized. The term is defined as a specific subtype of 'ductile-brittle transition temperature' specific to amorphous and semi-crystalline materials. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Glass_transition."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080049 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080049 <https://en.wikipedia.org/wiki/Glass_transition>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080049 "Glasübergangstemperatur"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080049 "glass transition temperature"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080049 "Tg"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080049 "Glass transition temperature is a ductile-brittle transition temperature of an amorphous or semi-crystalline material that specifies the temperature at which the material transitions from a hard, glassy state to a soft, rubbery state upon heating"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080049 "Glasübergangstemperatur ist eine Duktil-Spröd-Übergangstemperatur eines amorphen oder teilkristallinen Materials, die die Temperatur beschreibt, bei der das Material beim Erwärmen von einem harten, glasartigen in einen weichen, gummiartigen Zustand übergeht"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080049 "Glass transition temperature of polycarbonate measured at approximately 147 °C, above which the material softens and loses rigidity, determined according to ISO 11357-2."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080049 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080049 pmdco:PMD_0080048)

# Class: pmdco:PMD_0080050 (Entropie)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080050 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080050 "Necessary and sufficient conditions for 'entropy' have not yet been formalized. The term is defined as a specific subtype of 'energy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/entropy-physics."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080050 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080050 <https://www.britannica.com/science/entropy-physics>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080050 "Entropie"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080050 "entropy"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080050 "Die Entropie misst die Wärmeenergie pro Temperatureinheit, die für die Arbeit in einem System nicht zur Verfügung steht und auf molekulare Unordnung oder Zufälligkeit hinweist"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080050 "Entropy measures the thermal energy per unit temperature unavailable for work in a system, indicating molecular disorder or randomness"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080050 "Melting of ice at 0 C involves an entropy increase of 22 J/(mol·K), driving the phase transition"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080050 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080050 pmdco:PMD_0020269)

# Class: pmdco:PMD_0080051 (Oberflächenenergie)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080051 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080051 "Necessary and sufficient conditions for 'surface energy' have not yet been formalized. The term is defined as a specific subtype of 'energy'. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080051 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080051 "Oberflächenenergie"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080051 "surface energy"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080051 "freie Oberflächenenergie"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080051 "surface free energy"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080051 "γ"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080051 "Oberflächenenergie ist eine Energiequalität eines Materials, die die überschüssige Energie an seiner Oberfläche im Vergleich zum Volumen quantifiziert, die durch nicht abgesättigte molekulare Bindungen an der Grenzfläche entsteht"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080051 "Surface energy is an energy quality of a material that quantifies the excess energy at its surface relative to the bulk, arising from unsatisfied molecular bonds at the interface"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080051 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080051 pmdco:PMD_0020142)

# Class: pmdco:PMD_0080052 (enthalpy)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080052 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080052 "Necessary and sufficient conditions for 'enthalpy' have not yet been formalized. The term is defined as a specific subtype of 'energy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/enthalpy."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080052 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080052 <https://www.britannica.com/science/enthalpy>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080052 "Enthalpie"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080052 "enthalpy"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080052 "Die als H bezeichnete Enthalpie stellt die Summe der inneren Energie und das Produkt aus Druck und Volumen in einem thermodynamischen System dar und ist für Energieberechnungen von entscheidender Bedeutung"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080052 "Enthalpy, denoted as H, represents the sum of internal energy and the product of pressure and volume in a thermodynamic system, crucial for energy calculations"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080052 "The enthalpy of fusion of aluminum is 397 J/g, energy required to melt it at its melting point"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080052 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080052 pmdco:PMD_0020269)

# Class: pmdco:PMD_0080053 (heat of fusion)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080053 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080053 "Necessary and sufficient conditions for 'heat of fusion' have not yet been formalized. The term is defined as a specific subtype of 'enthalpy'. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080053 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080053 "Schmelzenthalpie"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080053 "heat of fusion"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080053 "Schmelzwärme"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080053 "enthalpy of fusion"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080053 "latent heat of melting"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080053 "ΔH_fus"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080053 "Heat of fusion is an enthalpy quality of a substance that specifies the amount of thermal energy required to convert a unit mass from solid to liquid phase at constant temperature and pressure"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080053 "Schmelzenthalpie ist eine Enthalpiequalität eines Stoffes, die die thermische Energie angibt, die benötigt wird, um eine Masseneinheit bei konstanter Temperatur und konstantem Druck von der festen in die flüssige Phase umzuwandeln"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080053 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080053 pmdco:PMD_0080052)

# Class: pmdco:PMD_0080054 (Verdampfungsenthalpie)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080054 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080054 "Necessary and sufficient conditions for 'heat of vaporization' have not yet been formalized. The term is defined as a specific subtype of 'enthalpy'. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080054 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080054 "Verdampfungsenthalpie"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080054 "heat of vaporization"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080054 "Verdampfungswärme"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080054 "enthalpy of vaporization"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080054 "latent heat of vaporization"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080054 "ΔH_vap"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080054 "Heat of vaporization is an enthalpy quality of a substance that specifies the amount of thermal energy required to convert a unit mass from liquid to vapour phase at constant temperature and pressure"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080054 "Verdampfungsenthalpie ist eine Enthalpiequalität eines Stoffes, die die thermische Energie angibt, die benötigt wird, um eine Masseneinheit bei konstanter Temperatur und konstantem Druck von der flüssigen in die gasförmige Phase umzuwandeln"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080054 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080054 pmdco:PMD_0080052)

# Class: pmdco:PMD_0080055 (auto-ignition temperature)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080055 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080055 "Necessary and sufficient conditions for 'auto-ignition temperature' have not yet been formalized. The term is defined as a specific subtype of 'thermo dynamic quality'. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080055 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080055 "Selbstzündungstemperatur"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080055 "auto-ignition temperature"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080055 "T_AIT"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080055 "Zündtemperatur"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080055 "spontaneous ignition temperature"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080055 "Auto-ignition temperature is a thermodynamic quality of a substance that specifies the lowest temperature at which it spontaneously ignites in a normal atmosphere without an external ignition source"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080055 "Selbstzündungstemperatur ist eine thermodynamische Qualität eines Stoffes, die die niedrigste Temperatur angibt, bei der er sich in normaler Atmosphäre ohne externe Zündquelle selbst entzündet"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080055 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080055 pmdco:PMD_0080005)

# Class: pmdco:PMD_0080056 (Reynolds-Zahl)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080056 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080056 "Necessary and sufficient conditions for 'Reynolds number' have not yet been formalized. The term is defined as a specific subtype of 'FluidDynamicQuality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Reynolds_number."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080056 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080056 <https://en.wikipedia.org/wiki/Reynolds_number>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080056 "Reynolds number"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080056 "Reynolds-Zahl"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080056 "Reynolds number is a dimensionless quantity predicting fluid flow patterns, measuring the ratio between inertial and viscous forces"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080056 "Reynolds-Zahl ist eine dimensionslose Größe zur Vorhersage von Strömungsmustern in Flüssigkeiten, die das Verhältnis zwischen Trägheits- und Viskosekräften misst"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080056 "Flow in a 25 mm pipe at 2 m/s has a Reynolds number of about 50000, indicating turbulent regime"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080056 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080056 pmdco:PMD_0080006)

# Class: pmdco:PMD_0080057 (Geruch)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080057 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080057 "Necessary and sufficient conditions for 'odor' have not yet been formalized. The term is defined as a specific subtype of 'olfactoric quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000058."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080057 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080057 obo:PATO_0000058)
AnnotationAssertion(rdfs:label pmdco:PMD_0080057 "Geruch"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080057 "odor"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080057 "Geruch ist eine morphologische Eigenschaft, die einem Träger innewohnt, dessen Moleküle von einem Geruchsrezeptor verteilt und wahrgenommen werden"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080057 "Odor is a morphologic quality inhering in a bearer whose molecules are dispersed and perceived by an odorant receptor"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080057 "The characteristic odor of acetic acid is detectable in dilute vinegar solutions"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080057 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080057 pmdco:PMD_0080008)

# Class: pmdco:PMD_0080058 (odorless)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080058 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080058 "Necessary and sufficient conditions for 'odorless' have not yet been formalized. The term is defined as a specific subtype of 'odor'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001208."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080058 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080058 obo:PATO_0001208)
AnnotationAssertion(rdfs:label pmdco:PMD_0080058 "geruchlos"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080058 "odorless"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080058 "Geruchlos bezeichnet eine Geruchsqualität, die einem geruchlosen Träger innewohnt"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080058 "Odorless denotes an odor quality inhering in a bearer lacking odor"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080058 "Distilled water is odorless under standard conditions, emitting no detectable volatile compounds"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080058 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080058 pmdco:PMD_0080057)

# Class: pmdco:PMD_0080059 (odorous)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080059 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080059 "Necessary and sufficient conditions for 'odorous' have not yet been formalized. The term is defined as a specific subtype of 'odor'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001331."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080059 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080059 obo:PATO_0001331)
AnnotationAssertion(rdfs:label pmdco:PMD_0080059 "odorous"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080059 "riechend"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080059 "Geruchlich bezeichnet eine Geruchsqualität, die einem Geruchsträger innewohnt"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080059 "Odorous denotes an odor quality inhering in a bearer possessing odor"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080059 "Hydrogen sulfide is odorous, detectable by humans at concentrations as low as 0.5 ppb"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080059 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080059 pmdco:PMD_0080057)

# Class: pmdco:PMD_0080061 (radius)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080061 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080061 "Necessary and sufficient conditions for 'radius' have not yet been formalized. The term is defined as a specific subtype of 'length'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002390."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080061 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080061 obo:PATO_0002390)
AnnotationAssertion(rdfs:label pmdco:PMD_0080061 "Radius"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080061 "radius"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080061 "Radius is a length quality equal to the distance from the center of a circle to any endpoint on the circular boundary"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080061 "Radius ist eine Längeneigenschaft, die gleich der Entfernung vom Mittelpunkt eines Kreises zu einem beliebigen Endpunkt auf der Kreisgrenze ist"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080061 "A cylindrical specimen has a radius of 5 mm, giving a cross-sectional area of 78.5 mm2"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080061 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080061 pmdco:PMD_0040001)

# Class: pmdco:PMD_0080065 (Wellenlänge)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080065 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080065 "Necessary and sufficient conditions for 'wavelength' have not yet been formalized. The term is defined as a specific subtype of 'length'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.oxfordreference.com/display/10.1093/oi/authority.20110803121421585."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080065 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080065 <https://www.oxfordreference.com/display/10.1093/oi/authority.20110803121421585>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080065 "Wellenlänge"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080065 "wavelength"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080065 "Wavelength is the distance between successive peaks or troughs of a wave, equal to wave speed divided by frequency"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080065 "Wellenlänge ist die Entfernung zwischen aufeinanderfolgenden Gipfeln oder Tälern einer Welle, gleich der Wellenbewegungsgeschwindigkeit geteilt durch die Frequenz"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080065 "A green laser pointer emits light at a wavelength of 532 nm"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080065 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080065 pmdco:PMD_0040001)

# Class: pmdco:PMD_0080066 (Höhe)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080066 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080066 "Necessary and sufficient conditions for 'height' have not yet been formalized. The term is defined as a specific subtype of 'length'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000119."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080066 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080066 obo:PATO_0000119)
AnnotationAssertion(rdfs:label pmdco:PMD_0080066 "Höhe"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080066 "height"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080066 "Die Höhe ist eine eindimensionale Ausdehnungsqualität, die die vertikale Abmessung eines Objekts oder Raums beschreibt, gemessen von der Basis bis zur Spitze"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080066 "Height is a 1-D extent quality describing the vertical dimension of an object or space, measured from the base to the top"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080066 "A steel column has a height of 3.6 m between floor and ceiling connections"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080066 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080066 pmdco:PMD_0040001)

# Class: pmdco:PMD_0080067 (Umfang)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080067 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080067 "Necessary and sufficient conditions for 'perimeter' have not yet been formalized. The term is defined as a specific subtype of 'length'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001711."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080067 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080067 obo:PATO_0001711)
AnnotationAssertion(rdfs:label pmdco:PMD_0080067 "Umfang"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080067 "perimeter"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080067 "Der Umfang misst eine eindimensionale Ausdehnung, die einem zweidimensionalen Träger innewohnt und die Entfernung um ihn herum darstellt"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080067 "Perimeter measures a 1-D extent inhering in a two-dimensional bearer, representing the distance around it"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080067 "The perimeter of a square cross-section beam of 50 mm side length is 200 mm"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080067 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080067 pmdco:PMD_0040001)

# Class: pmdco:PMD_0080068 (Kreisumfang)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080068 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080068 "Necessary and sufficient conditions for 'circumference' have not yet been formalized. The term is defined as a specific subtype of 'perimeter'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001648."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080068 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080068 obo:PATO_0001648)
AnnotationAssertion(rdfs:label pmdco:PMD_0080068 "Kreisumfang"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080068 "circumference"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080068 "Circumference characterizes a 1-D extent equal to the length of the closed curve of a circle"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080068 "Der Umfang charakterisiert eine eindimensionale Ausdehnung, die der Länge der geschlossenen Kurve eines Kreises entspricht"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080068 "A wire of 2 mm diameter has a circumference of 6.28 mm"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080068 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080068 pmdco:PMD_0080067)

# Class: pmdco:PMD_0080069 (physisch relative Qualität)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080069 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080069 "Necessary and sufficient conditions for 'physical relational quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000145'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080069 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080069 "physical relational quality"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080069 "physisch relative Qualität"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080069 "Die physische Beziehungsqualität bezieht sich auf Eigenschaften oder Merkmale einer Entität, die von ihrer Beziehung zu anderen Entitäten abhängig sind"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080069 "Physical relational quality pertains to properties or characteristics of an entity dependent on its relation to other entities"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080069 "The coefficient of friction between two surfaces is a physical relational quality inhering in both contacting materials"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080069 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080069 obo:BFO_0000145)

# Class: pmdco:PMD_0080070 (physical rate quality)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080070 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080070 "Necessary and sufficient conditions for 'physical rate quality' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080070 "Rate =(def.) a measure, quantity, or frequency, typically one measured against some other quantity or measure"@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080070 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080070 "physical rate quality"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080070 "physische Geschwindigkeitsqualität"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080070 "Die physikalische Geschwindigkeitsqualität bezeichnet den Quotienten zweier physikalischer Größen in unterschiedlichen Einheiten, der die Änderungsrate einer Größe im Verhältnis zu einer anderen darstellt"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080070 "Physical rate quality denotes the quotient of two physical quantities in different units, representing one quantity's rate of change in relation to another"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080070 "The rate of thermal expansion of a metal rod during quenching is a physical rate quality"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080070 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080070 pmdco:PMD_0080069)

# Class: pmdco:PMD_0080071 (emissivity)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080071 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080071 "Necessary and sufficient conditions for 'emissivity' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080071 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080071 "Emissionsgrad"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080071 "emissivity"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080071 "Emissivität"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080071 "ε"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080071 "Emissionsgrad ist eine physikalische Ratenqualität einer Materialoberfläche, die das Verhältnis der von der Oberfläche emittierten Wärmestrahlung zu der eines idealen schwarzen Körpers bei gleicher Temperatur ausdrückt"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080071 "Emissivity is a physical rate quality of a material surface that expresses the ratio of thermal radiation emitted by the surface to that emitted by a perfect blackbody at the same temperature"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080071 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080071 pmdco:PMD_0080070)

# Class: pmdco:PMD_0080072 (relative isotopic mass)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080072 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080072 "Necessary and sufficient conditions for 'relative isotopic mass' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Atomic_mass."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080072 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080072 <https://en.wikipedia.org/wiki/Atomic_mass>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080072 "relative Isotopenmasse"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080072 "relative isotopic mass"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080072 "Relative Isotopenmasse bezieht sich auf die Masse eines einzelnen Isotops im Vergleich zu 1/12 der Masse eines Kohlenstoff-12-Atoms"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080072 "Relative isotopic mass refers to the mass of a single isotope compared to 1/12 of the mass of a carbon-12 atom"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080072 "The relative isotopic mass of carbon-13 is 13.003 u, slightly heavier than carbon-12"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080072 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080072 pmdco:PMD_0080070)

# Class: pmdco:PMD_0080073 (Lichtausbeute)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080073 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080073 "Necessary and sufficient conditions for 'luminous efficacy' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Luminous_efficacy."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080073 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080073 <https://en.wikipedia.org/wiki/Luminous_efficacy>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080073 "Lichtausbeute"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080073 "luminous efficacy"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080073 "Die Lichtausbeute misst, wie gut eine Lichtquelle sichtbares Licht erzeugt, berechnet als Lichtstrom geteilt durch Leistung, ausgedrückt in Lumen pro Watt"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080073 "Luminous efficacy measures how well a light source produces visible light, calculated as luminous flux divided by power, expressed in lumens per watt"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080073 "A modern LED achieves a luminous efficacy of 200 lm/W, far exceeding incandescent bulbs"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080073 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080073 pmdco:PMD_0080070)

# Class: pmdco:PMD_0080074 (optical absorptance)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080074 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080074 "Necessary and sufficient conditions for 'optical absorptance' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080074 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080074 "optical absorptance"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080074 "optische Absorption"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080074 "Die optische Absorption definiert das Verhältnis der absorbierten Strahlungsleistung zur einfallenden Strahlungsleistung und gibt Aufschluss über die Absorptionsfähigkeit eines Mediums"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080074 "Optical absorptance defines the ratio of absorbed radiant power to incident radiant power, indicating a medium's absorption capability"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080074 "A solar absorber coating has an optical absorptance of 0.96, converting most sunlight to heat"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080074 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080074 pmdco:PMD_0080070)

# Class: pmdco:PMD_0080075 (optical transmittance)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080075 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080075 "Necessary and sufficient conditions for 'optical transmittance' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080075 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080075 "optical transmittance"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080075 "optische Transmittance"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080075 "Die optische Durchlässigkeit wird durch das Verhältnis der übertragenen Strahlungsleistung zur einfallenden Strahlungsleistung definiert und dient der Beurteilung der Übertragungseffizienz"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080075 "Optical transmittance is defined by the ratio of transmitted radiant power to incident radiant power, assessing transmission efficiency"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080075 "A 3 mm thick soda-lime glass pane has an optical transmittance of 90 % in the visible range"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080075 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080075 pmdco:PMD_0080070)

# Class: pmdco:PMD_0080076 (Massendiffusivität)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080076 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080076 "Necessary and sufficient conditions for 'mass diffusivity' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080076 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080076 "Massendiffusivität"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080076 "mass diffusivity"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080076 "D"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080076 "Diffusionskoeffizient"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080076 "diffusion coefficient"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080076 "Mass diffusivity is a physical rate quality of a material that quantifies the rate at which a diffusing substance moves through it per unit concentration gradient, as described by Fick's first law"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080076 "Massendiffusivität ist eine physikalische Ratenqualität eines Materials, die die Geschwindigkeit beschreibt, mit der eine diffundierende Substanz pro Konzentrationsgradienten durch das Material transportiert wird, gemäß dem ersten Fickschen Gesetz"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080076 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080076 pmdco:PMD_0080070)

# Class: pmdco:PMD_0080077 (optical reflectance)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080077 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080077 "Necessary and sufficient conditions for 'optical reflectance' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080077 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080077 "optical reflectance"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080077 "optische Reflexion"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080077 "Der optische Reflexionsgrad wird durch das Verhältnis der reflektierten Strahlungsleistung zur einfallenden Strahlungsleistung definiert und bewertet die Reflexionsfähigkeit"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080077 "Optical reflectance is defined by the ratio of reflected radiant power to incident radiant power, assessing reflective capacity"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080077 "A silver mirror has an optical reflectance of 98 % at 600 nm wavelength"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080077 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080077 pmdco:PMD_0080070)

# Class: pmdco:PMD_0080078 (electromotive force)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080078 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080078 "Necessary and sufficient conditions for 'electromotive force' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Electromotive_force."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080078 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080078 <https://en.wikipedia.org/wiki/Electromotive_force>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080078 "Quellenspannung"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080078 "electromotive force"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080078 "EMP"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080078 "Electromotive force refers to energy transferred to an electric circuit per unit charge, measured in volts, produced by transducers converting forms of energy to electrical energy"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080078 "Unter elektromotorischer Kraft versteht man die Energie, die pro Ladungseinheit auf einen Stromkreis übertragen wird. Sie wird in Volt gemessen und von Wandlern erzeugt, die Energieformen in elektrische Energie umwandeln"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080078 "A standard zinc-copper galvanic cell produces an electromotive force of 1.1 V"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080078 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080078 pmdco:PMD_0080070)

# Class: pmdco:PMD_0080079 (Feuchtigkeit)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080079 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080079 "Necessary and sufficient conditions for 'humidity' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080079 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080079 "Feuchtigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080079 "humidity"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080079 "Die Luftfeuchtigkeit charakterisiert den Partialdruck der Luft, der durch den Wasserdampfgehalt entsteht, definiert als das Verhältnis von Wassermasse zu Volumen des Medium-Wasser-Gemisches"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080079 "Humidity characterizes air's partial pressure exerted by water vapor content, defined as the mass of water to volume of the medium-water mixture"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080079 "A drying oven maintains relative humidity below 5 % to prevent moisture absorption in polymer samples"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080079 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080079 pmdco:PMD_0080070)

# Class: pmdco:PMD_0080080 (Temperaturleitfähigkeit)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080080 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080080 "Necessary and sufficient conditions for 'thermal diffusivity' have not yet been formalized. Although thermal diffusivity is defined as a ratio of thermal conductivity to the product of density and specific heat capacity, a co-inherence axiom cannot uniquely identify this quality among all rate qualities of the same bearer. The term is defined as a specific subtype of 'physical rate quality'."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080080 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080080 "Temperaturleitfähigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080080 "thermal diffusivity"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080080 "Thermische Diffusivität"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080080 "α"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080080 "Temperaturleitfähigkeit ist eine physikalische Ratenqualität eines Materials, die die Geschwindigkeit beschreibt, mit der Wärmeenergie im Verhältnis zur Wärmespeicherkapazität geleitet wird, ausgedrückt als Verhältnis der Wärmeleitfähigkeit zum Produkt aus Dichte und spezifischer Wärmekapazität"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080080 "Thermal diffusivity is a physical rate quality of a material that quantifies the rate at which thermal energy is conducted relative to its capacity to store heat, expressed as the ratio of thermal conductivity to the product of density and specific heat capacity"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080080 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080080 pmdco:PMD_0080070)

# Class: pmdco:PMD_0080081 (work hardening coefficient)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080081 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080081 "Necessary and sufficient conditions for 'work hardening coefficient' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080081 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080081 "Verfestigungsexponent"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080081 "work hardening coefficient"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080081 "Kaltverfestigungsexponent"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080081 "n"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080081 "strain hardening exponent"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080081 "Verfestigungsexponent ist eine physikalische Ratenqualität eines Materials, die die Geschwindigkeit beschreibt, mit der die Fließspannung bei plastischer Verformung während der Kaltumformung zunimmt, ausgedrückt als Exponent n in der Hollomon-Potenzgesetzbeziehung"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080081 "Work hardening coefficient is a physical rate quality of a material that quantifies the rate at which flow stress increases with plastic strain during cold working, expressed as the exponent n in the Hollomon power-law relation"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080081 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080081 pmdco:PMD_0080070)

# Class: pmdco:PMD_0080082 (coefficient of friction)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080082 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080082 "Necessary and sufficient conditions for 'coefficient of friction' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080082 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080082 "Reibungskoeffizient"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080082 "coefficient of friction"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080082 "Reibwert"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080082 "friction coefficient"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080082 "μ"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080082 "Coefficient of friction is a dimensionless scalar quality of a pair of surfaces in contact that expresses the ratio of the friction force between them to the normal force pressing them together"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080082 "Der Reibungskoeffizient ist eine dimensionslose skalare Qualität eines Paars in Kontakt stehender Oberflächen, die das Verhältnis der Reibungskraft zwischen ihnen zur Normalkraft ausdrückt, die sie zusammendrückt"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080082 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080082 pmdco:PMD_0000848)

# Class: pmdco:PMD_0080083 (Induktion)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080083 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080083 "Necessary and sufficient conditions for 'inductance' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Inductance."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080083 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080083 <https://en.wikipedia.org/wiki/Inductance>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080083 "Induktion"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080083 "inductance"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080083 "Inductance is the tendency of an electrical conductor to oppose a change in electric current through electromagnetic induction, creating back electromotive force"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080083 "Induktivität ist die Tendenz eines elektrischen Leiters, einer Änderung des elektrischen Stroms durch elektromagnetische Induktion entgegenzuwirken und so eine elektromotorische Gegenkraft zu erzeugen"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080083 "A solenoid coil of 100 turns has an inductance of 1 mH, opposing rapid current changes"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080083 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080083 pmdco:PMD_0020275)

# Class: pmdco:PMD_0080085 (Gewicht)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080085 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080085 "Necessary and sufficient conditions for 'weight' have not yet been formalized. The term is defined as a specific subtype of 'force'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Weight."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080085 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080085 <https://en.wikipedia.org/wiki/Weight>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080085 "Gewicht"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080085 "weight"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080085 "In der Wissenschaft und Technik ist das Gewicht eines Objekts die Kraft, die aufgrund der Erdbeschleunigung auf das Objekt einwirkt."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080085 "In science and engineering, the weight of an object, is the force acting on the object due to acceleration of gravity."@en)
AnnotationAssertion(skos:example pmdco:PMD_0080085 "A concrete block has a weight of 2.5 kN in the gravitational field at sea level"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080085 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080085 pmdco:PMD_0020200)

# Class: pmdco:PMD_0080086 (Reibung)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080086 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080086 "Necessary and sufficient conditions for 'friction' have not yet been formalized. The term is defined as a specific subtype of 'force'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/friction."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080086 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080086 <https://www.britannica.com/science/friction>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080086 "Reibung"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080086 "friction force"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080086 "Friction is the force resisting the sliding or rolling of one solid object over another, arising from shear between contact regions of microscopic irregularities"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080086 "Reibung ist die Kraft, die dem Gleiten oder Rollen eines festen Objekts über ein anderes entgegenwirkt und durch Scherung zwischen Kontaktbereichen mikroskopischer Unregelmäßigkeiten entsteht"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080086 "Static friction between rubber and concrete has a coefficient of about 0.6, resisting sliding motion"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080086 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080086 pmdco:PMD_0020200)

# Class: pmdco:PMD_0080087 (Schubkraft)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080087 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080087 "Necessary and sufficient conditions for 'thrust' have not yet been formalized. The term is defined as a specific subtype of 'force'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Thrust."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080087 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080087 <https://en.wikipedia.org/wiki/Thrust>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080087 "Schubkraft"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080087 "thrust"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080087 "Schubkraft ist eine von Newtons drittem Gesetz beschriebene Kraft, bei der Massenbeschleunigung in eine Richtung eine gleich große Kraft in die entgegengesetzte Richtung verursacht"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080087 "Thrust is a force described by Newton's third law, where mass expulsion in one direction causes an equal force in the opposite direction"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080087 "A jet engine produces 150 kN of thrust at takeoff conditions"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080087 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080087 pmdco:PMD_0020200)

# Class: pmdco:PMD_0080088 (Äquivalentdosis)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080088 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080088 "Necessary and sufficient conditions for 'dose equivalent' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.nrc.gov/reading-rm/basic-ref/glossary/dose-equivalent.html."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080088 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080088 <https://www.nrc.gov/reading-rm/basic-ref/glossary/dose-equivalent.html>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080088 "dose equivalent"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080088 "Äquivalentdosis"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080088 "Das Dosisäquivalent misst die biologische Schädigung lebenden Gewebes durch Strahlenexposition, berechnet als absorbierte Dosis multipliziert mit einem Qualitätsfaktor und ausgedrückt in Rems oder Sievert"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080088 "Dose equivalent measures biological damage to living tissue from radiation exposure, calculated as absorbed dose multiplied by a quality factor, and expressed in rems or sieverts"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080088 "A radiation worker receives a dose equivalent of 2 mSv per year from occupational exposure"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080088 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080088 pmdco:PMD_0080069)

# Class: pmdco:PMD_0080089 (radiant energy density)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080089 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080089 "Necessary and sufficient conditions for 'radiant energy density' have not yet been formalized. The term is defined as a specific subtype of 'density'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Radiant_energy."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080089 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080089 <https://en.wikipedia.org/wiki/Radiant_energy>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080089 "Strahlungsenergiedichte"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080089 "radiant energy density"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080089 "Radiant energy density quantifies radiant energy per unit volume"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080089 "Strahlungsenergiedichte misst die Strahlungsenergie pro Volumeneinheit"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080089 "The radiant energy density at the focal spot of a laser is 1 GJ/m3 during material processing"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080089 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080089 pmdco:PMD_0080597)

