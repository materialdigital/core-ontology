AnnotationAssertion(skos:definition pmdco:PMD_0020013 "tetragonal Bravais lattice with primitive centering (tP), having one 4-fold rotation axis with two equal unit cell axes perpendicular to a third unequal axis"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020013 "tetragonales Bravais-Gitter mit primitiver Zentrierung (tP), mit einer vierzähligen Rotationsachse mit zwei gleichen Elementarzellenachsen senkrecht zu einer dritten ungleichen Achse"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020013 "true"^^xsd:boolean)

