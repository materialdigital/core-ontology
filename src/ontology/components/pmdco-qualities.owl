AnnotationAssertion(skos:definition pmdco:PMD_0080188 "Strahlungsemitter beschreibt die Fähigkeit einer Entität, Licht eines definierten Spektrums und Intensität zu emittieren"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080188 "A cobalt-60 source is a radiation emitter used in industrial gamma-ray testing of welds"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080188 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080188 pmdco:PMD_0000877)

