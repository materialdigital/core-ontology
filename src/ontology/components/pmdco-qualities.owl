AnnotationAssertion(rdfs:label pmdco:PMD_0020017 "Bravais-Gitter, kubisches Grundelement"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020017 "bravais lattice cubic primitive"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020017 "Kubisches Bravais-Gitter mit primitiver Zentrierung (cP), mit vier dreizähligen Rotationsachsen, wobei alle Elementarzellenachsen gleich und zueinander senkrecht sind, und einem Gitterpunkt pro Elementarzelle"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020017 "cubic Bravais lattice with primitive centering (cP), having four 3-fold rotation axes with all unit cell axes equal and mutually perpendicular and one lattice point per unit cell"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020017 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020018 (bravais lattice cubic body-centered)

AnnotationAssertion(rdfs:label pmdco:PMD_0020018 "Bravais-Gitter kubisch raumzentriert"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020018 "bravais lattice cubic body-centered"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020018 "Kubisches Bravais-Gitter mit körperzentrierter Zentrierung (cI), mit vier dreizähligen Rotationsachsen und einem zusätzlichen Gitterpunkt in der Mitte der Elementarzelle"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020018 "cubic Bravais lattice with body-centered centering (cI), having four 3-fold rotation axes and an additional lattice point at the center of the unit cell"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020018 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020019 (Bravais-Gitter kubisch flächenzentriert)

AnnotationAssertion(rdfs:label pmdco:PMD_0020019 "Bravais-Gitter kubisch flächenzentriert"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020019 "bravais lattice cubic face-centered"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020019 "Kubisches Bravais-Gitter mit flächenzentrierter Zentrierung (cF), mit vier dreizähligen Rotationsachsen und zusätzlichen Gitterpunkten in den Mittelpunkten aller Flächen"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020019 "cubic Bravais lattice with face-centered centering (cF), having four 3-fold rotation axes and additional lattice points at the centers of all faces"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020019 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020027 (Bainit)

AnnotationAssertion(rdfs:label pmdco:PMD_0020027 "Bainit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020027 "bainite"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020027 "Eisen-Kohlenstoff-Mikrostruktur, die durch isotherme Umwandlung von Austenit bei Temperaturen zwischen dem Perlit- und Martensitbildungsbereich entsteht und aus Ferrit und fein verteiltem Zementit besteht"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020027 "iron-carbon microstructure formed by isothermal transformation of austenite at temperatures between the pearlite and martensite formation ranges, consisting of ferrite and finely dispersed cementite"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020027 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020097 (austenite)

AnnotationAssertion(rdfs:label pmdco:PMD_0020097 "Austenit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020097 "austenite"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020097 "face-centered cubic phase of iron or an iron-based alloy, stable above the eutectoid temperature and capable of dissolving significant amounts of carbon in solid solution"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020097 "flächenzentrierte kubische Phase aus Eisen oder einer Legierung auf Eisenbasis, die oberhalb der Eutektoidtemperatur stabil ist und in der Lage ist, erhebliche Mengen Kohlenstoff in fester Lösung aufzulösen"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020097 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020100 (Ferrit)

AnnotationAssertion(rdfs:label pmdco:PMD_0020100 "Ferrit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020100 "ferrite"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020100 "body-centered cubic phase of iron or an iron-based alloy with very low carbon solubility, stable at low temperatures and ferromagnetic below the Curie temperature"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020100 "kubisch raumzentrierte Phase aus Eisen oder einer Eisenlegierung mit sehr geringer Kohlenstofflöslichkeit, stabil bei niedrigen Temperaturen und ferromagnetisch unterhalb der Curie-Temperatur"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020100 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020107 (ledeburite)

AnnotationAssertion(rdfs:label pmdco:PMD_0020107 "Ledeburit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020107 "ledeburite"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020107 "Eutektische Mikrostruktur von Austenit und Zementit, die sich in Eisen-Kohlenstoff-Legierungen mit einem Kohlenstoffgehalt über 2,14 Gew.-% bei der Erstarrung bei der eutektischen Temperatur von 1147 °C bildet"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020107 "eutectic microstructure of austenite and cementite formed in iron-carbon alloys with carbon content above 2.14 wt% upon solidification at the eutectic temperature of 1147 °C"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020107 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020109 (Perlit)

AnnotationAssertion(rdfs:label pmdco:PMD_0020109 "Perlit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020109 "pearlite"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020109 "Lamellare eutektoide Mikrostruktur aus abwechselnden Ferrit- und Zementitschichten, die durch Zersetzung von Austenit bei der eutektoiden Temperatur von 723 °C entsteht"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020109 "lamellar eutectoid microstructure of alternating ferrite and cementite layers formed by decomposition of austenite at the eutectoid temperature of 723 °C"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020109 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020110 (Widmanstätten-Struktur)

AnnotationAssertion(rdfs:label pmdco:PMD_0020110 "Widmanstätten-Struktur"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020110 "widmanstatten structure"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020110 "Mikrostruktur, in der beim Abkühlen Ferrit- oder Zementitplatten Keime bilden und entlang bestimmter kristallographischer Ebenen des Ausgangsaustenits wachsen und ein charakteristisches nadel- oder plattenartiges Muster bilden"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020110 "microstructure in which ferrite or cementite plates nucleate and grow along specific crystallographic planes of the parent austenite during cooling, forming a characteristic needle-like or plate-like pattern"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020110 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020111 (martensite)

AnnotationAssertion(rdfs:label pmdco:PMD_0020111 "Martensit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020111 "martensite"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020111 "hard, body-centered tetragonal phase formed by diffusionless shear transformation of austenite upon rapid quenching in iron-carbon alloys, with carbon atoms trapped in interstitial sites"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020111 "harte, körperzentrierte tetragonale Phase, die durch diffusionslose Scherumwandlung von Austenit beim schnellen Abschrecken in Eisen-Kohlenstoff-Legierungen entsteht, wobei Kohlenstoffatome in Zwischengitterplätzen eingeschlossen sind"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020111 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020117 (aggregate state solid)

AnnotationAssertion(rdfs:label pmdco:PMD_0020117 "Aggregatzustand fest"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020117 "aggregate state solid"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020117 "A state where the bonds between entities transmit shear forces."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020117 "Ein Zustand, in dem die Bindungen zwischen Einheiten Scherkräfte übertragen."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020117 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020118 (aggregate state liquid)

AnnotationAssertion(rdfs:label pmdco:PMD_0020118 "Aggregatzustand flüssig"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020118 "aggregate state liquid"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020118 "A state where the bonds of the entities transmit no shear force."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020118 "Ein Zustand, in dem die Bindungen der Einheiten keine Scherkräfte übertragen."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020118 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020119 (Aggregatzustand gasförmig)

AnnotationAssertion(rdfs:label pmdco:PMD_0020119 "Aggregatzustand gasförmig"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020119 "aggregate state gaseous"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020119 "A state where the entities have no bonding."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020119 "Ein Zustand, in dem die Entitäten keine Bindung haben."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020119 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020120 (aggregate state plasma)

AnnotationAssertion(rdfs:label pmdco:PMD_0020120 "Aggregatzustandsplasma"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020120 "aggregate state plasma"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020120 "An aggregate state where the entities are atom nuclei and have no bonds."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020120 "Ein Aggregatzustand, in dem die Einheiten Atomkerne sind und keine Bindungen aufweisen."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020120 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020121 (Aggregatzustand Atomgas)

AnnotationAssertion(rdfs:label pmdco:PMD_0020121 "Aggregatzustand Atomgas"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020121 "aggregate state atom gas"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020121 "A gaseous state where the gas entities are atoms."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020121 "Ein gasförmiger Zustand, in dem die Gaseinheiten Atome sind."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020121 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020122 (Aggregatzustand überkritisches Fluid)

AnnotationAssertion(rdfs:label pmdco:PMD_0020122 "Aggregatzustand überkritisches Fluid"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020122 "aggregate state supercritical fluid"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020122 "A state with strong bindings between entities that do not transmit shear force."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020122 "Ein Zustand mit starken Bindungen zwischen Entitäten, die keine Scherkräfte übertragen."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020122 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020123 (aggregate state mesomorphic)

AnnotationAssertion(rdfs:label pmdco:PMD_0020123 "Aggregatzustand mesomorph"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020123 "aggregate state mesomorphic"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020123 "A state where some bonds transmit shear stresses and some do not."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020123 "Ein Zustand, in dem einige Bindungen Scherspannungen übertragen und andere nicht."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020123 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020124 (Aggregatzustand suprafluid)

AnnotationAssertion(rdfs:label pmdco:PMD_0020124 "Aggregatzustand suprafluid"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020124 "aggregate state suprafluid"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020124 "A state with frictionless binding that transmits no shear force between entities."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020124 "Ein Zustand mit reibungsloser Bindung, der keine Scherkräfte zwischen Entitäten überträgt."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020124 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020125 (aggregate state suprasolid)

AnnotationAssertion(rdfs:label pmdco:PMD_0020125 "Aggregatzustand suprasolid"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020125 "aggregate state suprasolid"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020125 "A state that exhibits suprafluid and solid properties."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020125 "Ein Zustand, der suprafluide und feste Eigenschaften aufweist."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020125 "true"^^xsd:boolean)

# Individual: pmdco:PMD_0020217 (short range order)

AnnotationAssertion(rdfs:label pmdco:PMD_0020217 "Kurzstreckenauftrag"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020217 "short range order"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020217 "periodic arrangement of structural features up to a few entities"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020217 "periodische Anordnung von Strukturmerkmalen bis hin zu wenigen Einheiten"@de)

# Individual: pmdco:PMD_0020218 (medium range order)

AnnotationAssertion(rdfs:label pmdco:PMD_0020218 "Mittelklasseauftrag"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020218 "medium range order"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020218 "periodic arrangement of structural features of many entities"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020218 "periodische Anordnung struktureller Merkmale vieler Entitäten"@de)

# Individual: pmdco:PMD_0020219 (long range order)

AnnotationAssertion(rdfs:label pmdco:PMD_0020219 "Langstreckenauftrag"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020219 "long range order"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020219 "periodic arrangement of structural features of virtually all entities"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020219 "periodische Anordnung struktureller Merkmale praktisch aller Entitäten"@de)

# Individual: pmdco:PMD_0020242 (no range order)

AnnotationAssertion(rdfs:label pmdco:PMD_0020242 "keine Bereichsreihenfolge"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0020242 "no range order"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020242 "keine periodische Anordnung struktureller Merkmale von Entitäten"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0020242 "no periodic arrangement of structural features of entites"@en)


