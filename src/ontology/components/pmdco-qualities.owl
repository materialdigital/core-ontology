AnnotationAssertion(rdfs:label pmdco:PMD_0080016 "radiant energy flux"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080016 "Radiant energy flux describes the radiant energy emitted, reflected, transmitted, or received per unit time"@en)
