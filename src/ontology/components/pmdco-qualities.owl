AnnotationAssertion(skos:definition pmdco:PMD_0001008 "Vorgang der Aufnahme elektromagnetischer Strahlung durch ein materielles Wesen"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0001008 "process of taking up elctromagnetic radiation by a material entity"@en)
SubClassOf(pmdco:PMD_0001008 pmdco:PMD_0000802)

