SubClassOf(pmdco:PMD_0000539 pmdco:PMD_0000949)
SubClassOf(pmdco:PMD_0000539 ObjectAllValuesFrom(obo:RO_0000052 ObjectUnionOf(obo:BFO_0000027 obo:BFO_0000030 pmdco:PMD_0000538)))

# Class: pmdco:PMD_0000547 (Änderung des Aggregatzustandes)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000547 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000547 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000547 "change of aggregate state"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000547 "Änderung des Aggregatzustandes"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000547 "a phase transformation (change of phase) involving the collective state of particles in portion of matter"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000547 "eine Phasenumwandlung (Phasenänderung), die den kollektiven Zustand von Teilchen in einem Teil der Materie betrifft"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000547 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000547 pmdco:PMD_0020136)

# Class: pmdco:PMD_0000549 (change of temperature)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000549 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000549 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000549 "Temperaturänderung"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000549 "change of temperature"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000549 "Temperaturänderung ist ein Prozess, bei dem ein Teilnehmer seine Temperatur ändert"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000549 "change of temperature is a process in which a particpant changes its temperature"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000549 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000549 obo:BFO_0000015)

# Class: pmdco:PMD_0000551 (chemische Zusammensetzung)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000551 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000551 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:comment pmdco:PMD_0000551 "See the editor note of composition to understand the difference between composition and chemical composition.

See the pattern example of composition to underatand the difference between composition and proportion."@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000551 "chemical composition"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000551 "chemische Zusammensetzung"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000551 "Die chemische Zusammensetzung ist eine intensive Eigenschaft eines Materieteils, die die Arten und Anteile reiner chemischer Elemente in dem Materieteil beschreibt, und ist Gegenstand einiger Datenelemente zur chemischen Zusammensetzung."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000551 "The chemical composition is an intensive quality of a portion of matter which describes the types and proportions of pure chemical elements in the portion of matter, and it is a subject of some chemical composition data item."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000551 "true"^^xsd:boolean)
AnnotationAssertion(pmdco:PMD_0000064 pmdco:PMD_0000551 "Material has quality chemical composition. Chemical composition is a subject of chemical composition data item. Chemical composition data item has members fraction value specifications (which have a numeral and a unit). Material has part portion of carbon. Material has relational quality mass proportion. Portion of carbon  has relational quality mass proportion. Mass propotion is specified by value fraction value specification. Same approach for all chemical elements."@en)
SubClassOf(pmdco:PMD_0000551 pmdco:PMD_0025001)

# Class: pmdco:PMD_0000553 (chemical potential)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000553 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000553 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000553 "chemical potential"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000553 "chemisches Potential"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000553 "an intensive quality of a thermodynamic system describing the energy change associated with the addition of a small quantity of a substance to a system at constant temperature and pressure."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000553 "eine intensive Qualität eines thermodynamischen Systems, die die Energieänderung beschreibt, die mit der Zugabe einer kleinen Menge einer Substanz zu einem System bei konstanter Temperatur und konstantem Druck verbunden ist."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000553 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000553 pmdco:PMD_0020274)
SubClassOf(pmdco:PMD_0000553 pmdco:PMD_0080005)

# Class: pmdco:PMD_0000586 (Absorption von Korpuskularstrahlung)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000586 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000586 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000586 "Absorption von Korpuskularstrahlung"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000586 "absorption of corpuscular radiation"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000586 "Vorgang der Aufnahme von Korpuskularstrahlung durch ein materielles Wesen"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000586 "process of taking up corpuscular radiation by a material entity"@en)
SubClassOf(pmdco:PMD_0000586 pmdco:PMD_0000802)

# Class: pmdco:PMD_0000587 (Risswachstum)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000587 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000587 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000587 "Risswachstum"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000587 "crack growth"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000587 "Das Risswachstum ist eine Schadensentwicklung, die die fortschreitende Ausdehnung eines Risses in einem Material unter Spannung beschreibt."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000587 "The crack growth is an evolution of damage describing the progressive extension of a crack in a material under stress."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000587 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000587 pmdco:PMD_0000635)

# Class: pmdco:PMD_0000591 (crystal structure)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000591 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000591 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:comment pmdco:PMD_0000591 "The finite set of periodic geometric arrangements is described e.g. by the 14 possible Bravais Lattices in three-dimensional space."@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000591 "Kristallstruktur"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000591 "crystal structure"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000591 "an intensive qualtty of a crystal that embodies the periodic geometric arrangement of entities in a crystal lattice."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000591 "eine intensive Kristallqualität, die die periodische geometrische Anordnung von Einheiten in einem Kristallgitter verkörpert."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000591 "true"^^xsd:boolean)
EquivalentClasses(pmdco:PMD_0000591 ObjectExactCardinality(1 pmdco:PMD_0000077 pmdco:PMD_0020099))
SubClassOf(pmdco:PMD_0000591 pmdco:PMD_0020131)

# Class: pmdco:PMD_0000595 (Defektdichte)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000595 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000595 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000595 "Defektdichte"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000595 "defect density"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000595 "an intensive quality describing the number of defects per unit volume or area in a material, which can affect its mechanical and electronic properties"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000595 "eine intensive Qualität, die die Anzahl der Defekte pro Volumen- oder Flächeneinheit in einem Material beschreibt, die sich auf seine mechanischen und elektronischen Eigenschaften auswirken können"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000595 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000595 pmdco:PMD_0080009)

# Class: pmdco:PMD_0000596 (deformation)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000596 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000596 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000596 "Verformung"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000596 "deformation"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000596 "Die Verformung ist ein Prozess, der eine Veränderung der Form, Größe oder Struktur eines Materials beschreibt, häufig unter dem Einfluss von Spannung oder Kraft."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000596 "The deformation is a process describing a change in the shape, size, or structure of a material often under the influence of stress or force."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000596 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000596 obo:BFO_0000015)

# Class: pmdco:PMD_0000597 (Massendichte)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000597 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000597 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000597 "Massendichte"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000597 "mass density"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000597 "universal intensive quality representing the mass of a portion of matter per unit volume"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000597 "universelle intensive Qualität, die die Masse eines Materieanteils pro Volumeneinheit darstellt"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000597 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000597 pmdco:PMD_0080009)

# Class: pmdco:PMD_0000604 (Dielektrizitätskonstante)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000604 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000604 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000604 "Dielektrizitätskonstante"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000604 "dielectric constant"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000604 "Die Dielektrizitätskonstante ist eine elektrische Eigenschaft, die ein Maß für die Fähigkeit eines Materials darstellt, elektrische Energie in einem elektrischen Feld zu speichern."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000604 "The dielectric constant is an electrical property representing a measure of a material's ability to store electrical energy in an electric field."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000604 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000604 pmdco:PMD_0000621)
DisjointClasses(pmdco:PMD_0000604 pmdco:PMD_0000620)

# Class: pmdco:PMD_0000618 (Elastizitätsmodul)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000618 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000618 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000618 "Elastizitätsmodul"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000618 "elastic modulus"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000618 "represents a material's stiffness, defined as the ratio of stress to strain in the elastic deformation region."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000618 "stellt die Steifigkeit eines Materials dar, definiert als das Verhältnis von Spannung zu Dehnung im elastischen Verformungsbereich."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000618 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000618 pmdco:PMD_0000949)
SubClassOf(pmdco:PMD_0000618 ObjectSomeValuesFrom(obo:RO_0000052 ObjectUnionOf(obo:BFO_0000027 obo:BFO_0000030 pmdco:PMD_0000538)))

# Class: pmdco:PMD_0000619 (elektrisches Potential)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000619 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000619 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000619 "electric potential"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000619 "elektrisches Potential"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000619 "an extensvie quality describing the amount of work needed to move a unit charge from a reference point to a specific location in an electric field."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000619 "eine ausführliche Qualität, die den Arbeitsaufwand beschreibt, der erforderlich ist, um eine Einheitsladung von einem Referenzpunkt zu einem bestimmten Ort in einem elektrischen Feld zu bewegen."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000619 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000619 pmdco:PMD_0020275)
SubClassOf(pmdco:PMD_0000619 pmdco:PMD_0080116)

# Class: pmdco:PMD_0000620 (elektrische Leitfähigkeit)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000620 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000620 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000620 "electrical conductivity"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000620 "elektrische Leitfähigkeit"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000620 "Die elektrische Leitfähigkeit ist eine elektrische Eigenschaft, die die Fähigkeit eines Materials beschreibt, elektrischen Strom zu leiten, beeinflusst von seiner Struktur und Zusammensetzung."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000620 "The electrical conductivity is an electrical property describing the ability of a material to conduct electric current, influenced by its structure and composition."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000620 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000620 pmdco:PMD_0000621)

# Class: pmdco:PMD_0000621 (elektrisches Eigentum)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000621 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0000621 "Necessary and sufficient conditions for 'electrical capability' have not yet been formalized. The term is defined as a specific subtype of 'physical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000621 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000621 "electrical property"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000621 "elektrisches Eigentum"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000621 "An electrical property is a material property that represents the characteristics of a material that determine its behavior under the influence of an electric field, such as conductivity, resistivity, and permittivity."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000621 "Eine elektrische Eigenschaft ist eine Materialeigenschaft, die die Eigenschaften eines Materials darstellt, die sein Verhalten unter dem Einfluss eines elektrischen Feldes bestimmen, wie z. B. Leitfähigkeit, spezifischer Widerstand und Permittivität."@de)
AnnotationAssertion(skos:example pmdco:PMD_0000621 "The semiconductivity of doped silicon is an electrical capability enabling switching in transistors"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000621 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000621 pmdco:PMD_0000005)
SubClassOf(pmdco:PMD_0000621 ObjectSomeValuesFrom(obo:BFO_0000054 pmdco:PMD_0000519))

# Class: pmdco:PMD_0000628 (Emission von Korpuskularstrahlung)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000628 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000628 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000628 "Emission von Korpuskularstrahlung"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000628 "emission of corpuscular radiation"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000628 "Die Emission von Korpuskularstrahlung ist eine Strahlungsemission, die die Freisetzung partikelbasierter Strahlung, beispielsweise Alpha- oder Betateilchen, aus einem Material oder System beschreibt."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000628 "The emission of corpuscular radiation is an emission of radiation describing the release of particle-based radiation, such as alpha or beta particles, from a material or system."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000628 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000628 pmdco:PMD_0000629)

# Class: pmdco:PMD_0000629 (emission of radiation)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000629 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000629 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000629 "Emission von Strahlung"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000629 "emission of radiation"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000629 "Die Emissionsstrahlung ist ein Prozess, der die Freisetzung von Energie in Form elektromagnetischer Wellen oder Partikel aus einem Material beschreibt."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000629 "The emission radiation is a process describing the release of energy in the form of electromagnetic waves or particles from a material."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000629 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000629 obo:BFO_0000015)

# Class: pmdco:PMD_0000630 (Emission von Wellenstrahlung)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000630 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000630 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000630 "Emission von Wellenstrahlung"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000630 "emission of wave radiation"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000630 "Die Emission von Wellenstrahlung ist eine Strahlungsemission, die die Freisetzung von Energie in Form von Wellen, beispielsweise elektromagnetischen oder akustischen Wellen, durch ein Material oder System beschreibt."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000630 "The emission of wave radioation is an emission of radiation describing the release of energy in the form of waves, such as electromagnetic or acoustic waves, by a material or system."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000630 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000630 pmdco:PMD_0000629)

# Class: pmdco:PMD_0000635 (Schadensentwicklung)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000635 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000635 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000635 "Schadensentwicklung"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000635 "evolution of damage"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000635 "An evolution of damage is a process representing the progression of material degradation under mechanical, thermal, or chemical stresses."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000635 "Eine Schadensentwicklung ist ein Prozess, der das Fortschreiten der Materialdegradation unter mechanischer, thermischer oder chemischer Belastung darstellt."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000635 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000635 obo:BFO_0000015)

# Class: pmdco:PMD_0000645 (formation of notch or scratch)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000645 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000645 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000645 "Bildung von Kerben oder Kratzern"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000645 "formation of notch or scratch"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000645 "Die Bildung einer Kerbe oder eines Kratzers ist ein Prozess, der die Entstehung kleiner Oberflächenfehler beschreibt, die die mechanischen Eigenschaften eines Materials beeinflussen können."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000645 "The formation of (a) notch or (a) scratch is a process that describes the creation of small surface imperfections, which can influence a material's mechanical properties."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000645 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000645 obo:BFO_0000015)

# Class: pmdco:PMD_0000768 (half-life)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000768 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000768 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000768 "Halbwertszeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000768 "half-life"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000768 "Die Halbwertszeit ist ein Prozessmerkmal, das die Zeit beschreibt, die ein Material oder eine Qualität eines Materiales benötigt, um seinen Anfangswert auf die Hälfte zu reduzieren"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000768 "The half-life is a process attribute describing the time it takes for a material entity or a quality of a material entity to reduce its initial value to a half"@en)
AnnotationAssertion(skos:example pmdco:PMD_0000768 "radioactive decay, material degradation"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000768 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000768 pmdco:PMD_0000008)

# Class: pmdco:PMD_0000773 (hardness)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000773 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000773 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000773 "Härte"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000773 "hardness"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000773 "Die Härte ist eine mechanische Eigenschaft, die als Maß für den Widerstand eines Materials gegenüber lokalisierter plastischer Verformung dient und häufig durch Eindring- oder Kratzmethoden getestet wird."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000773 "The hardness is a mechanical property used as a measure of a material's resistance to localized plastic deformation, often tested by indentation or scratch methods."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000773 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000773 pmdco:PMD_0000848)

# Class: pmdco:PMD_0000777 (Wärmekapazität)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000777 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000777 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000777 "Wärmekapazität"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000777 "heat capacity"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000777 "Die Wärmekapazität ist eine thermische Eigenschaft, die die Menge an Wärmeenergie beschreibt, die erforderlich ist, um die Temperatur eines Materials um einen bestimmten Betrag zu erhöhen."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000777 "The heat capacity is a thermal property describing the amount of heat energy required to raise the temperature of a material by a given amount."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000777 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000777 pmdco:PMD_0000981)
SubClassOf(pmdco:PMD_0000777 ObjectSomeValuesFrom(pmdco:PMD_0001029 pmdco:PMD_0000549))
DisjointClasses(pmdco:PMD_0000777 pmdco:PMD_0000978)

# Class: pmdco:PMD_0000789 (Indentationshärte)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000789 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000789 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000789 "Indentationshärte"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000789 "indentation hardness"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000789 "Die Eindruckhärte ist eine Härte, die den Widerstand eines Materials gegenüber der Verformung durch einen Eindringkörper angibt und zur Beurteilung der Oberflächenhärte verwendet wird."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000789 "The indentation hardness is a hardness representing the resistance of a material to deformation from an indenter, used to assess surface hardness."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000789 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000789 pmdco:PMD_0000773)

# Class: pmdco:PMD_0000790 (refraction)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000790 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000790 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:comment pmdco:PMD_0000790 "e.g., air into glass"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000790 "Brechung"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000790 "refraction"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000790 "Optical property which describes the bending of light as it passes from one medium into another due to a change in the light’s speed."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000790 "Optische Eigenschaft, die die Ablenkung des Lichts beim Übergang von einem Medium in ein anderes aufgrund einer Änderung der Lichtgeschwindigkeit beschreibt."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000790 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000790 pmdco:PMD_0000877)
DisjointClasses(pmdco:PMD_0000790 pmdco:PMD_0000911)

# Class: pmdco:PMD_0000802 (Absorption von Strahlung)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000802 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000802 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000802 "Absorption von Strahlung"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000802 "absorption of radiation"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000802 "Prozess der Aufnahme von Strahlung durch ein materielles Wesen"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000802 "process of taking up radiation by a material entity"@en)
SubClassOf(pmdco:PMD_0000802 obo:BFO_0000015)

# Class: pmdco:PMD_0000825 (magnetic property)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000825 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000825 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000825 "magnetic property"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000825 "magnetische Eigenschaft"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000825 "A magnetic property is a material property representing characteristics that describe how a material responds to magnetic fields, such as permeability and coercivity."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000825 "Eine magnetische Eigenschaft ist eine Materialeigenschaft, die Eigenschaften darstellt, die beschreiben, wie ein Material auf Magnetfelder reagiert, wie z. B. Permeabilität und Koerzitivfeldstärke."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000825 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000825 pmdco:PMD_0000005)

# Class: pmdco:PMD_0000848 (mechanische Eigenschaft)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000848 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0000848 "Necessary and sufficient conditions for 'mechanical capability' have not yet been formalized. The term is defined as a specific subtype of 'physical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000848 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:comment pmdco:PMD_0000848 "The axiom that mechanical property has realization some application of mechanical load treats only conventional materials and not such effects as magnetostriction etc."@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000848 "mechanical property"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000848 "mechanische Eigenschaft"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000848 "A mechanical property is a material property which is a characteristic of material M. Mechanical property has realization in a stimulating process (in most cases, application of mechanical load), and the stimulating process is an occurent part of another process, in which an object O that is an instance of M participates."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000848 "Eine mechanische Eigenschaft ist eine Materialeigenschaft, die eine Eigenschaft des Materials M ist. Eine mechanische Eigenschaft wird in einem stimulierenden Prozess (in den meisten Fällen durch Anwendung einer mechanischen Belastung) verwirklicht, und der stimulierende Prozess ist ein stattfindender Teil eines anderen Prozesses, an dem ein Objekt O, das eine Instanz von M ist, teilnimmt."@de)
AnnotationAssertion(skos:example pmdco:PMD_0000848 "A spring steel coil spring has the mechanical capability to store 50 J of elastic energy per cycle"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000848 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000848 obo:BFO_0000020)
SubClassOf(pmdco:PMD_0000848 ObjectSomeValuesFrom(obo:BFO_0000054 pmdco:PMD_0000522))

# Class: pmdco:PMD_0000851 (melting point)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000851 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000851 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000851 "Schmelzpunkt"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000851 "melting point"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000851 "Der Schmelzpunkt ist eine Zustandsgrenze einer Materie, die durch den Übergang vom festen in den flüssigen Zustand (oder umgekehrt) entsteht."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000851 "The melting point is a state of matter boundary realized by transition form the solid state to the liquid state (or vice versa)."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000851 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000851 pmdco:PMD_0020164)

# Class: pmdco:PMD_0000853 (kristallographische Textur)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000853 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000853 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:comment pmdco:PMD_0000853 "typically observed through crystallographic analysis"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000853 "crystallographic texture"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000853 "kristallographische Textur"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000853 "an intensive quality describing the arrangement and orientation of grains in a polychrystal"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000853 "eine intensive Qualität, die die Anordnung und Ausrichtung der Körner in einem Polykristall beschreibt"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000853 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000853 pmdco:PMD_0020131)

# Class: pmdco:PMD_0000861 (Mohs hardness)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000861 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000861 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000861 "Mohs hardness"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000861 "Mohshärte"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000861 "Scalar scratch hardness scale used to rank materials based on their ability to scratch one another."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000861 "Skalare Kratzhärteskala, mit der Materialien nach ihrer Fähigkeit, sich gegenseitig zu zerkratzen, eingestuft werden."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000861 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000861 pmdco:PMD_0000924)

# Class: pmdco:PMD_0000869 (chemical reaction)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000869 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000869 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000869 "chemical reaction"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000869 "chemische Reaktion"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000869 "Das Auftreten einer chemischen Reaktion ist der Prozess, bei dem Substanzen interagieren, um neue chemische Verbindungen zu bilden oder ihre Molekülstruktur zu verändern."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000869 "The occurrence of (a) chemical reaction is the process in which substances interact to form new chemical compounds or alter their molecular structure."@en)
SubClassOf(pmdco:PMD_0000869 obo:BFO_0000015)

# Class: pmdco:PMD_0000877 (optical property)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000877 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0000877 "Necessary and sufficient conditions for 'optical capability' have not yet been formalized. The term is defined as a specific subtype of 'physical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000877 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000877 "optical property"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000877 "optische Eigenschaft"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000877 "An optical property is a material property representing the characteristics that describe how a material interacts with light, including reflection, refraction, and absorption."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000877 "Eine optische Eigenschaft ist eine Materialeigenschaft, die die Eigenschaften darstellt, die beschreiben, wie ein Material mit Licht interagiert, einschließlich Reflexion, Brechung und Absorption."@de)
AnnotationAssertion(skos:example pmdco:PMD_0000877 "A camera lens has an optical capability of resolving 100 line pairs per mm at the image plane"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000877 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000877 obo:BFO_0000016)
SubClassOf(pmdco:PMD_0000877 obo:BFO_0000020)

# Class: pmdco:PMD_0000882 (Phasengrenze (Realisierung))

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000882 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000882 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000882 "Phasengrenze (Realisierung)"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000882 "phase boundary (realization)"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000882 "A phase boundary is a realizable entity that is realized by the transition between distinct phases."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000882 "Eine Phasengrenze ist eine realisierbare Einheit, die durch den Übergang zwischen verschiedenen Phasen realisiert wird."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000882 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000882 obo:BFO_0000017)

# Class: pmdco:PMD_0000889 (pore growth)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000889 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000889 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000889 "Porenwachstum"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000889 "pore growth"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000889 "Pore growth is an evolution of damage describing the process by which voids or pores in a material increase in size, often affecting its mechanical and physical properties."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000889 "Porenwachstum ist eine Schädigungsentwicklung, die den Prozess beschreibt, durch den Hohlräume oder Poren in einem Material an Größe zunehmen, was sich häufig auf dessen mechanische und physikalische Eigenschaften auswirkt."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000889 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000889 pmdco:PMD_0000635)

# Class: pmdco:PMD_0000896 (pressure)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000896 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000896 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:comment pmdco:PMD_0000896 "The pressure is commonly measured in Pascals."@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000896 "Druck"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000896 "pressure"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000896 "an intensive quality describing the force exerted per unit area in or on a material."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000896 "eine intensive Qualität, die die Kraft beschreibt, die pro Flächeneinheit in oder auf ein Material ausgeübt wird."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000896 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000896 pmdco:PMD_0000848)
DisjointClasses(pmdco:PMD_0000896 pmdco:PMD_0000967)

# Class: pmdco:PMD_0000910 (Rückprallhärte)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000910 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000910 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000910 "Rückprallhärte"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000910 "rebound hardness"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000910 "Die Rückprallhärte ist ein Maß für die Härte eines Materials und basiert auf der Rückprallhöhe eines Hammers, der auf das Material fällt."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000910 "The rebound hardness is representing a measure of a material's hardness based on the height of rebound of a hammer dropped on the material."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000910 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000910 pmdco:PMD_0000773)

# Class: pmdco:PMD_0000911 (Reflexionsvermögen)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000911 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000911 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000911 "Reflexionsvermögen"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000911 "reflectivity"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000911 "Das Reflexionsvermögen ist eine optische Eigenschaft, die den Anteil des einfallenden Lichts bzw. der Strahlung beschreibt, den ein Material reflektiert."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000911 "The reflectivity is an optical property that describes the proportion of incident light or radiation that a material reflects."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000911 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000911 pmdco:PMD_0000877)

# Class: pmdco:PMD_0000924 (Kratzhärte)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000924 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000924 "PERSON: Joerg Waitelonis")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0000924 "A measure of a material's resistance to deformation or scratching by a harder material.")
AnnotationAssertion(rdfs:label pmdco:PMD_0000924 "Kratzhärte"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000924 "scratch hardness"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000924 "Die Ritzhärte ist eine Härte, die ein Maß für den Widerstand eines Materials gegenüber Verformung oder Kratzern durch ein härteres Material darstellt."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000924 "The scratch hardness is a hardness representing a measure of a material's resistance to deformation or scratching by a harder material."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000924 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000924 pmdco:PMD_0000773)

# Class: pmdco:PMD_0000942 (specific surface area)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000942 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000942 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000942 "specific surface area"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000942 "spezifische Oberfläche"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000942 "an intensive quality embodying the total surface area of a material per unit of mass or volume."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000942 "eine intensive Qualität, die die Gesamtoberfläche eines Materials pro Massen- oder Volumeneinheit verkörpert."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000942 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000942 pmdco:PMD_0020131)

# Class: pmdco:PMD_0000947 (speed of sound)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000947 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000947 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000947 "Schallgeschwindigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000947 "speed of sound"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000947 "Die Schallgeschwindigkeit ist eine akustische Eigenschaft, die die Geschwindigkeit angibt, mit der sich Schallwellen durch ein Material ausbreiten, abhängig von seiner Dichte und seinen elastischen Eigenschaften."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000947 "The speed of sound is an acoustic property representing the rate at which sound waves travel through a material, dependent on its density and elastic properties."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000947 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000947 pmdco:PMD_0000506)

# Class: pmdco:PMD_0000949 (stiffness)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000949 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000949 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000949 "Steifigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000949 "stiffness"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000949 "Die Steifigkeit ist eine Materialeigenschaft, die den Widerstand eines Materials gegen Verformung unter Einwirkung einer Kraft beschreibt."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000949 "The stiffness is a material property describing the resistance of a material to deformation under an applied force."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000949 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000949 pmdco:PMD_0000848)
SubClassOf(pmdco:PMD_0000949 pmdco:PMD_0080164)
SubClassOf(pmdco:PMD_0000949 ObjectSomeValuesFrom(pmdco:PMD_0001029 pmdco:PMD_0000596))
DisjointClasses(pmdco:PMD_0000949 pmdco:PMD_0000952)

# Class: pmdco:PMD_0000950 (stimulating process)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000950 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000950 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000950 "anregender Prozess"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000950 "stimulating process"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000950 "Der Stimulationsprozess ist ein Prozess, der die Anwendung eines äußeren Einflusses wie Kraft, Wärme oder Strahlung beschreibt, um die materielle Reaktion zu untersuchen."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000950 "The stimulating process is a process describing the application of an external influence, such as force, heat, or radiation, to study material response."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000950 "true"^^xsd:boolean)
EquivalentClasses(pmdco:PMD_0000950 ObjectIntersectionOf(obo:BFO_0000015 ObjectSomeValuesFrom(obo:BFO_0000055 ObjectIntersectionOf(ObjectUnionOf(obo:BFO_0000016 pmdco:PMD_0000005) ObjectSomeValuesFrom(obo:RO_0000052 pmdco:PMD_0000001)))))
SubClassOf(pmdco:PMD_0000950 obo:BFO_0000015)

# Class: pmdco:PMD_0000952 (strength)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000952 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000952 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000952 "Festigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000952 "strength"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000952 "Die Festigkeit ist eine Materialeigenschaft, die die maximale Belastung beschreibt, der ein Material standhalten kann, bevor ein bestimmtes Ereignis eintritt"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000952 "The strength is a material property describing the maximum stress a material can withstand before a specific event occurs."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000952 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000952 pmdco:PMD_0000848)

# Class: pmdco:PMD_0000953 (structural and chemical decay)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000953 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000953 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000953 "structural and chemical decay"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000953 "struktureller und chemischer Zerfall"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000953 "Der strukturelle und chemische Zerfall ist eine Schädigungsentwicklung, die die Verschlechterung der Struktur und Zusammensetzung eines Materials im Laufe der Zeit aufgrund von Umwelt- oder Betriebsbedingungen beschreibt."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000953 "The structural and chemical decay is an evolution of damage describing the deterioration of a material's structure and composition over time due to environmental or operational conditions."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000953 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000953 pmdco:PMD_0000635)

# Class: pmdco:PMD_0000961 (Sublimationspunkt)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000961 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000961 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000961 "Sublimationspunkt"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000961 "sublimation point"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000961 "Der Sublimationspunkt ist eine Zustandsgrenze der Materie, die durch den Übergang vom festen in den gasförmigen Zustand (oder umgekehrt) entsteht."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000961 "The sublimation point is a state of matter boundary realized by transition from the solid state to the gaseous state (or vice versa)."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000961 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000961 pmdco:PMD_0020164)

# Class: pmdco:PMD_0000965 (surface layer (fiat object part))

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000965 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000965 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000965 "Oberflächenschicht (Fiat-Objektteil)"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000965 "surface layer (fiat object part)"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000965 "A surface layer (fiat object part) is a fiat object part that is part of only object. The surface layer is the three dimensional region defining the outermost layer of an object,"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000965 "Eine Oberflächenschicht (Fiat-Objektteil) ist ein Fiat-Objektteil, der nur Teil eines Objekts ist. Die Oberflächenschicht ist der dreidimensionale Bereich, der die äußerste Schicht eines Objekts definiert, wo Oberflächeninteraktionen mit anderen materiellen Einheiten stattfinden. Was als Oberfläche betrachtet wird, wird somit durch den Interaktionsprozess definiert."@de)
AnnotationAssertion(skos:example pmdco:PMD_0000965 "When considering optical properties of a surface layer (fiat object part) of a polished piece of metal we likely consider a different three dimensional spatial region than when considering the scratch hardness properties of the same polished piece of metal."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000965 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000965 obo:BFO_0000024)
SubClassOf(pmdco:PMD_0000965 ObjectAllValuesFrom(obo:BFO_0000050 ObjectUnionOf(obo:BFO_0000027 obo:BFO_0000030)))

# Class: pmdco:PMD_0000967 (temperature)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000967 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000967 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:comment pmdco:PMD_0000967 "The concept refers to an absolute temperature, not to be mistaken with temperature difference."@en)
AnnotationAssertion(rdfs:comment pmdco:PMD_0000967 "To express that an object has a temperature, the property 'intensive bearer of' can be used. It implies a chain of: object consists of some portion of matter and portion of matter bearer of some temperature."@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000967 "Temperatur"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000967 "temperature"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000967 "Die Temperatur ist eine grundlegende intensive Qualität, die die durchschnittliche atomare oder molekulare Bewegung oder Schwingung eines Teils der Materie darstellt."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000967 "The temperature is a fundamental intensive quality representing the average atomic or molcular movement or vibration of a portion of matter."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000967 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000967 pmdco:PMD_0080005)

# Class: pmdco:PMD_0000972 (zeitliches Eigentum)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000972 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000972 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000972 "temporal property"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000972 "zeitliches Eigentum"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000972 "A temporal property is a material property that represents attributes related to the time-dependent behavior of a material or process."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000972 "Eine zeitliche Eigenschaft ist eine Materialeigenschaft, die Attribute darstellt, die sich auf das zeitabhängige Verhalten eines Materials oder Prozesses beziehen."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000972 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000972 pmdco:PMD_0000005)

# Class: pmdco:PMD_0000975 (test piece role)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000975 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000975 "PERSON: Joerg Waitelonis")

# Class: pmdco:PMD_0000978 (Wärmeleitfähigkeit)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000978 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000978 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000978 "Wärmeleitfähigkeit"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000978 "thermal conductivity"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000978 "Die Wärmeleitfähigkeit ist eine thermische Eigenschaft, die die Fähigkeit eines Materials beschreibt, Wärme zu leiten."@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000978 "The thermal conductivity is a thermal property describing the ability of a material to conduct heat."@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000978 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000978 pmdco:PMD_0000981)

# Class: pmdco:PMD_0000981 (thermal property)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000981 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0000981 "Necessary and sufficient conditions for 'thermal capability' have not yet been formalized. The term is defined as a specific subtype of 'physical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000981 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000981 "thermal property"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0000981 "thermische Eigenschaft"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0000981 "A thermal property is a material property representing attributes of a material that describe its behavior under temperature changes, such as thermal conductivity and expansion."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000981 "Eine thermische Eigenschaft ist eine Materialeigenschaft, die Attribute eines Materials darstellt, die sein Verhalten bei Temperaturänderungen beschreiben, wie z. B. Wärmeleitfähigkeit und Ausdehnung."@de)
AnnotationAssertion(skos:example pmdco:PMD_0000981 "Refractory bricks have a high thermal capability, withstanding furnace temperatures above 1600 C"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000981 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000981 obo:BFO_0000016)
SubClassOf(pmdco:PMD_0000981 pmdco:PMD_0000005)
SubClassOf(pmdco:PMD_0000981 ObjectSomeValuesFrom(obo:BFO_0000054 pmdco:PMD_0000520))

# Class: pmdco:PMD_0000996 (triple point (state of matter))

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0000996 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0000996 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0000996 "Tripelpunkt"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0000996 "triple point (state of matter)"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000996 "a state of matter boundary (point) realized by transition from the solid state to the liquid state or the the gaseous state (or vice versa)."@en)
AnnotationAssertion(skos:definition pmdco:PMD_0000996 "eine Zustandsgrenze (Punkt) einer Materie, die durch den Übergang vom festen Zustand in den flüssigen Zustand oder den gasförmigen Zustand (oder umgekehrt) realisiert wird."@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0000996 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0000996 pmdco:PMD_0020164)

# Class: pmdco:PMD_0001008 (absorption of wave radiation)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0001008 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0001008 "PERSON: Joerg Waitelonis")
AnnotationAssertion(rdfs:label pmdco:PMD_0001008 "Absorption von Wellenstrahlung"@de)
