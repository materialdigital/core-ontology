AnnotationAssertion(skos:definition pmdco:PMD_0080186 "Radiation reflection capability characterizes an entity's ability to reflect electromagnetic radiation"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080186 "Strahlungsreflexionsfähigkeit beschreibt die Fähigkeit einer Entität, elektromagnetische Strahlung zu reflektieren"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080186 "Polished aluminum foil has high radiation reflection capability, reflecting 90 % of infrared radiation"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080186 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080186 pmdco:PMD_0000877)

