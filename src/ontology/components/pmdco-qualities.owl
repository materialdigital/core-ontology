AnnotationAssertion(rdfs:label pmdco:PMD_0020008 "bravais lattice monoclinic base-centered"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020008 "monoclinic Bravais lattice with base-centered centering (mC), having one 2-fold rotation axis and additional lattice points at the center of one pair of faces"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0020008 "monoklines Bravais-Gitter mit basiszentrierter Zentrierung (mC), einer zweizähligen Rotationsachse und zusätzlichen Gitterpunkten in der Mitte eines Flächenpaares"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0020008 "true"^^xsd:boolean)

