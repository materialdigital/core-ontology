AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080090 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080090 "Necessary and sufficient conditions for 'number density' have not yet been formalized. The term is defined as a specific subtype of 'density'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080090 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080090 "Anzahldichte"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080090 "number density"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080090 "Number Density"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080090 "Anzahldichte misst die Anzahl der Objekte pro Volumen- oder Flächeneinheit"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080090 "Number density measures the number of objects per unit volume or area"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080090 "Austenite at 900 C has a number density of about 6e28 iron atoms per cubic meter"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080090 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080090 pmdco:PMD_0080009)

# Class: pmdco:PMD_0080091 (pixel density)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080091 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080091 "Necessary and sufficient conditions for 'pixel density' have not yet been formalized. The term is defined as a specific subtype of 'number density'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080091 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080091 "Pixeldichte"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080091 "pixel density"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080091 "Pixel density describes the relationship between the number of pixels and the area they occupy on a related entity"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080091 "Pixeldichte beschreibt das Verhältnis zwischen der Anzahl der Pixel und der Fläche, die sie auf einer verwandten Entität einnehmen"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080091 "A 4K display panel has a pixel density of 210 ppi, providing sharp text rendering"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080091 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080091 pmdco:PMD_0080090)

# Class: pmdco:PMD_0080092 (electric flux density)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080092 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080092 "Necessary and sufficient conditions for 'electric flux density' have not yet been formalized. The term is defined as a specific subtype of 'density'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/electric-flux."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080092 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080092 <https://www.britannica.com/science/electric-flux>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080092 "electric flux density"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080092 "elektrische Flussdichte"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080092 "Die elektrische Flussdichte misst die Gesamtzahl der elektrischen Kraftlinien, die ein bestimmtes Gebiet schneiden, von positiven Ladungen ausgehen und bei negativen Ladungen enden"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080092 "Electric flux density measures the total number of electric lines of force intersecting a given area, originating on positive charges and terminating on negative charges"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080092 "Near a charged plate, the electric flux density is 8.85e-12 C/m2 per V/m of field strength"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080092 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080092 pmdco:PMD_0080597)

# Class: pmdco:PMD_0080093 (birefringence)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080093 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080093 "Necessary and sufficient conditions for 'birefringence' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080093 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080093 "Doppelbrechung"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080093 "birefringence"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080093 "Zweistrahl-Brechung"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080093 "double refraction"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080093 "Δn"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080093 "Birefringence is a physical relational quality of an optically anisotropic material that specifies the difference in refractive indices along two principal optical axes, causing incident light to split into two rays with different velocities"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080093 "Doppelbrechung ist eine physikalische relationale Qualität eines optisch anisotropen Materials, die die Differenz der Brechungsindizes entlang zweier optischer Hauptachsen angibt und bewirkt, dass einfallendes Licht in zwei Strahlen mit unterschiedlichen Geschwindigkeiten aufgespalten wird"@de)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080093 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080093 pmdco:PMD_0000877)

# Class: pmdco:PMD_0080094 (stress relaxation)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080094 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080094 "Necessary and sufficient conditions for 'stress relaxation' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080094 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080094 "Spannungsrelaxation"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080094 "stress relaxation"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080094 "Relaxationsgrad"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080094 "relaxation ratio"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080094 "Spannungsrelaxation ist eine physikalische relationale Qualität eines Materials, die das Verhältnis der Restspannung zur anfänglich aufgebrachten Spannung nach einem definierten Zeitintervall bei konstanter Dehnung ausdrückt und die Neigung des Materials zur internen Spannungsumverteilung über die Zeit quantifiziert"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080094 "Stress relaxation is a physical relational quality of a material that expresses the ratio of residual stress to initial applied stress after a defined time interval under constant strain, quantifying the material's tendency to internally redistribute stress over time"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080094 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080094 pmdco:PMD_0000848)

# Class: pmdco:PMD_0080095 (Kontaktwinkel)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080095 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080095 "Necessary and sufficient conditions for 'contact angle' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080095 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080095 "Kontaktwinkel"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080095 "contact angle"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080095 "Benetzungswinkel"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080095 "wetting angle"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080095 "θ"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080095 "Contact angle is a physical relational quality of a solid surface that quantifies the angle formed at the three-phase contact line between a liquid droplet, the solid surface, and the surrounding gas phase, characterizing the wettability of the surface by the liquid"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080095 "Kontaktwinkel ist eine physikalische relationale Qualität einer festen Oberfläche, die den Winkel an der Dreiphasengrenzlinie zwischen einem Flüssigkeitstropfen, der festen Oberfläche und der umgebenden Gasphase beschreibt und die Benetzbarkeit der Oberfläche durch die Flüssigkeit charakterisiert"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080095 "A hydrophobic polymer coating shows a water contact angle of 110 degrees, indicating poor wettability"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080095 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080095 pmdco:PMD_0000848)

# Class: pmdco:PMD_0080098 (Massenmischungsverhältnis)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080098 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080098 "Necessary and sufficient conditions for 'mass mix ratio' have not yet been formalized. The term is defined as a specific subtype of 'mass ratio'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Massenverh%C3%A4ltnis."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080098 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080098 <https://de.wikipedia.org/wiki/Massenverh%C3%A4ltnis>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080098 "Massenmischungsverhältnis"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080098 "mass mix ratio"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080098 "Das Massenmischungsverhältnis stellt das Verhältnis der Massen zweier Mischungskomponenten dar und liefert eine quantitative Beschreibung der Zusammensetzung"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080098 "Mass mix ratio represents the ratio of masses of two mixture components, providing a quantitative composition description"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080098 "A concrete mix uses a mass mix ratio of cement to aggregate of 1:4 for standard structural applications"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080098 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080098 pmdco:PMD_0020102)

# Class: pmdco:PMD_0080099 (dry mass)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080099 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080099 "Necessary and sufficient conditions for 'dry mass' have not yet been formalized. The term is defined as a specific subtype of 'mass ratio'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080099 "PERSON: Thomas Hanke")
AnnotationAssertion(rdfs:label pmdco:PMD_0080099 "Trockenmasse"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080099 "dry mass"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080099 "Dry mass denotes mass after removing all humidity from an object, typically using qualified heating methods in an oven"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080099 "Trockenmasse bezeichnet die Masse, nachdem einem Objekt die gesamte Feuchtigkeit entzogen wurde, typischerweise durch geeignete Erhitzungsmethoden in einem Ofen"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080099 "A fiber composite sample has a dry mass of 48.5 g after 24 hours in a drying oven at 80 C"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080099 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080099 pmdco:PMD_0020133)

# Class: pmdco:PMD_0080100 (Massenanteil)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080100 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080100 "Necessary and sufficient conditions for 'mass fraction' have not yet been formalized. The term is defined as a specific subtype of 'mass ratio'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Massenanteil."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080100 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080100 <https://de.wikipedia.org/wiki/Massenanteil>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080100 "Massenanteil"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080100 "mass fraction"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080100 "Der Massenanteil beschreibt den relativen Anteil einer Masse an der Gesamtmasse einer Mischung, ein gängiges quantitatives Maß"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080100 "Mass fraction describes the relative proportion of a mass to the total mass of a mixture, a common quantitative measure"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080100 "A binary Al-4 wt% Cu alloy has a copper mass fraction of 0.04"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080100 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080100 pmdco:PMD_0020102)

# Class: pmdco:PMD_0080101 (Massenkonzentration)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080101 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080101 "Necessary and sufficient conditions for 'mass concentration' have not yet been formalized. The term is defined as a specific subtype of 'material composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Massenkonzentration."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080101 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080101 <https://de.wikipedia.org/wiki/Massenkonzentration>)
AnnotationAssertion(rdfs:label pmdco:PMD_0080101 "Massenkonzentration"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080101 "mass concentration"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080101 "Die Massenkonzentration verknüpft die Masse einer Mischungskomponente mit dem Gesamtvolumen in einer quantitativen Beschreibung, die häufig in Lösungen verwendet wird"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080101 "Mass concentration links mass of a mixture component to the total volume in quantitative description, frequently used in solutions"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080101 "A saline infusion solution has a NaCl mass concentration of 9 g/L"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080101 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080101 pmdco:PMD_0025001)

# Class: pmdco:PMD_0080103 (volume concentration)

AnnotationAssertion(obo:IAO_0000114 pmdco:PMD_0080103 obo:IAO_0000122)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080103 "Necessary and sufficient conditions for 'volume concentration' have not yet been formalized. The term is defined as a specific subtype of 'volume ratio'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Volumenkonzentration."@en)
AnnotationAssertion(obo:IAO_0000117 pmdco:PMD_0080103 "PERSON: Thomas Hanke")
AnnotationAssertion(obo:IAO_0000119 pmdco:PMD_0080103 <https://de.wikipedia.org/wiki/Volumenkonzentration>)
