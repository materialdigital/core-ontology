AnnotationAssertion(skos:altLabel pmdco:PMD_0080170 "plasticity"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080170 "Plasticity signifies a material's ability to undergo permanent deformation without breaking or cracking"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080170 "Plastizität bezeichnet die Fähigkeit eines Materials, dauerhafte Verformungen ohne Bruch oder Riss zu erleiden"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080170 "Low-carbon steel exhibits high plasticity, allowing deep drawing without cracking"@en)
