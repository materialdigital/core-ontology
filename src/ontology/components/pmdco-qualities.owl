AnnotationAssertion(rdfs:label pmdco:PMD_0080172 "untere Streckgrenze"@de)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080172 "lower yield stress"@en)
AnnotationAssertion(skos:altLabel pmdco:PMD_0080172 "untere Fließspannung"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080172 "Lower yield strength defines the stress at which a material exhibits plastic behavior after initial yielding"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080172 "Untere Streckgrenze beschreibt die Spannung, bei der ein Material nach dem anfänglichen Fließen plastisches Verhalten zeigt"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080172 "The lower yield strength of mild steel is approximately 235 MPa, defining the onset of stable plastic flow"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080172 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080172 pmdco:PMD_0080171)

