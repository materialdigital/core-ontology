AnnotationAssertion(rdfs:label pmdco:PMD_0080015 "mechanical impulse"@en)
AnnotationAssertion(rdfs:label pmdco:PMD_0080015 "mechanischer Impuls"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080015 "Mechanical impulse signifies the change in momentum of an object when subjected to a force over time"@en)
AnnotationAssertion(skos:definition pmdco:PMD_0080015 "Unter mechanischem Impuls versteht man die Änderung des Impulses eines Objekts, wenn es im Laufe der Zeit einer Kraft ausgesetzt wird"@de)
AnnotationAssertion(skos:example pmdco:PMD_0080015 "A drop weight imparts a mechanical impulse of 50 N·s to the Charpy specimen during impact"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080015 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080015 pmdco:PMD_0000008)

