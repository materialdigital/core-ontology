AnnotationAssertion(skos:definition pmdco:PMD_0080156 "Biegefestigkeit bezeichnet die Fähigkeit eines Materials, unter Biegelast Deformationen zu widerstehen"@de)
AnnotationAssertion(skos:definition pmdco:PMD_0080156 "Flexural strength indicates a material's ability to resist deformation under flexural load"@en)
AnnotationAssertion(skos:example pmdco:PMD_0080156 "A ceramic bending bar fractures at a flexural strength of 350 MPa in a three-point bend test"@en)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080156 "true"^^xsd:boolean)
