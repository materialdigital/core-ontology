Declaration(AnnotationProperty(<http://purl.org/dc/terms/bibliographicCitation>))
Declaration(AnnotationProperty(<http://purl.org/dc/terms/created>))
Declaration(AnnotationProperty(<http://purl.org/dc/terms/title>))
Declaration(AnnotationProperty(<http://www.w3.org/2004/02/skos/core#definition>))
Declaration(AnnotationProperty(<https://w3id.org/pmd/co/logistics/PMD_0000060>))
Declaration(AnnotationProperty(<https://w3id.org/pmd/co/logistics/PMD_0001032>))



############################
#   Classes
############################

# Class: :PMD_0040000 (agreement)

AnnotationAssertion(rdfs:label :PMD_0040000 "agreement"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :PMD_0040000 "understanding between two or more parties that contains a set of commitments on the part of the parties"@en)
SubClassOf(:PMD_0040000 <http://purl.obolibrary.org/obo/IAO_0000030>)

# Class: :PMD_0040001 (agent)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> :PMD_0040001 "https://spec.industrialontologies.org/iof/ontology/core/Core/Agent")
AnnotationAssertion(rdfs:label :PMD_0040001 "agent"@en)
SubClassOf(:PMD_0040001 <http://purl.obolibrary.org/obo/BFO_0000040>)

# Class: :PMD_0040002 (piece of transport equipment)

AnnotationAssertion(rdfs:label :PMD_0040002 "piece of transport equipment"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> :PMD_0040002 "piece of equipment that has the function of holding, protecting, and securing a number of material entites for transportation purposes")
SubClassOf(:PMD_0040002 <http://purl.obolibrary.org/obo/BFO_0000030>)

# Class: <https://w3id.org/pmd/co/logistics/PMD_0000014> (<https://w3id.org/pmd/co/logistics/PMD_0000014>)

AnnotationAssertion(<https://w3id.org/pmd/co/logistics/PMD_0000060> <https://w3id.org/pmd/co/logistics/PMD_0000014> "true"^^xsd:boolean)

# Class: <https://w3id.org/pmd/co/logistics/PMD_0000598> (department)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/logistics/PMD_0000598> "Abteilung"@de)
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/logistics/PMD_0000598> "department"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/logistics/PMD_0000598> "A sub section of an organization [FIXME]"@en)
AnnotationAssertion(<https://w3id.org/pmd/co/logistics/PMD_0000060> <https://w3id.org/pmd/co/logistics/PMD_0000598> "true"^^xsd:boolean)
EquivalentClasses(<https://w3id.org/pmd/co/logistics/PMD_0000598> ObjectIntersectionOf(<https://w3id.org/pmd/co/logistics/PMD_0000879> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000196> <https://w3id.org/pmd/co/logistics/PMD_0000599>)))

# Class: <https://w3id.org/pmd/co/logistics/PMD_0000599> (department role)

AnnotationAssertion(rdfs:comment <https://w3id.org/pmd/co/logistics/PMD_0000599> "This role is also an indication that an organization is a sub section of another organization."@en)
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/logistics/PMD_0000599> "department role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/logistics/PMD_0000599> "A department role is a role describing a personal function or position within an organization that defines responsibilities or activities in a specified context."@en)
AnnotationAssertion(<https://w3id.org/pmd/co/logistics/PMD_0000060> <https://w3id.org/pmd/co/logistics/PMD_0000599> "true"^^xsd:boolean)
SubClassOf(<https://w3id.org/pmd/co/logistics/PMD_0000599> <http://purl.obolibrary.org/obo/BFO_0000023>)

# Class: <https://w3id.org/pmd/co/logistics/PMD_0000793> (initiator role)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/logistics/PMD_0000793> "initiator role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/logistics/PMD_0000793> "An initiator role is a role describing the position or function responsible for starting or catalyzing a process, often related to material testing or experiments."@en)
SubClassOf(<https://w3id.org/pmd/co/logistics/PMD_0000793> <http://purl.obolibrary.org/obo/BFO_0000023>)

# Class: <https://w3id.org/pmd/co/logistics/PMD_0000814> (laboratory)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <https://w3id.org/pmd/co/logistics/PMD_0000814> "“Laboratory.” Merriam-Webster.com Dictionary, Merriam-Webster, https://www.merriam-webster.com/dictionary/laboratory. Accessed 24 Nov. 2022."@en)
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/logistics/PMD_0000814> "Labor"@de)
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/logistics/PMD_0000814> "laboratory"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/logistics/PMD_0000814> "A place equipped for experimental study in a science or for testing and analysis."@en)
AnnotationAssertion(<https://w3id.org/pmd/co/logistics/PMD_0000060> <https://w3id.org/pmd/co/logistics/PMD_0000814> "true"^^xsd:boolean)
EquivalentClasses(Annotation(<https://w3id.org/pmd/co/logistics/PMD_0001032> "issue: https://github.com/materialdigital/core-ontology/issues/101") <https://w3id.org/pmd/co/logistics/PMD_0000814> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000029> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000196> <https://w3id.org/pmd/co/logistics/PMD_0000815>)))

# Class: <https://w3id.org/pmd/co/logistics/PMD_0000815> (laboratory role)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/logistics/PMD_0000815> "laboratory role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/logistics/PMD_0000815> "A laboratory role is a role specifying the functions or activities specific to experimental and analytical tasks performed in a laboratory setting."@en)
SubClassOf(<https://w3id.org/pmd/co/logistics/PMD_0000815> <http://purl.obolibrary.org/obo/BFO_0000023>)

# Class: <https://w3id.org/pmd/co/logistics/PMD_0000830> (Hersteller)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/logistics/PMD_0000830> "Hersteller"@de)
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/logistics/PMD_0000830> "manufacturer company"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/logistics/PMD_0000830> "Processing Node's manufacturer name, e.g.: \"Ipsen\", \"UPC\" or \"Bosch\""@en)
AnnotationAssertion(<https://w3id.org/pmd/co/logistics/PMD_0000060> <https://w3id.org/pmd/co/logistics/PMD_0000830> "true"^^xsd:boolean)
EquivalentClasses(<https://w3id.org/pmd/co/logistics/PMD_0000830> ObjectIntersectionOf(<https://w3id.org/pmd/co/logistics/PMD_0000879> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000196> <https://w3id.org/pmd/co/logistics/PMD_0000831>)))

# Class: <https://w3id.org/pmd/co/logistics/PMD_0000831> (manufacturer role)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/logistics/PMD_0000831> "manufacturer role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/logistics/PMD_0000831> "The manufacturer role is a role that involves the production or fabrication of materials, components, or systems."@en)
SubClassOf(<https://w3id.org/pmd/co/logistics/PMD_0000831> <http://purl.obolibrary.org/obo/BFO_0000023>)

# Class: <https://w3id.org/pmd/co/logistics/PMD_0000873> (operator role)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/logistics/PMD_0000873> "operator role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/logistics/PMD_0000873> "An operator role is a role indicating responsibility for operating equipment or systems, typically in a laboratory or manufacturing setting."@en)
AnnotationAssertion(<https://w3id.org/pmd/co/logistics/PMD_0000060> <https://w3id.org/pmd/co/logistics/PMD_0000873> "true"^^xsd:boolean)
SubClassOf(<https://w3id.org/pmd/co/logistics/PMD_0000873> <http://purl.obolibrary.org/obo/BFO_0000023>)

# Class: <https://w3id.org/pmd/co/logistics/PMD_0000879> (organization)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <https://w3id.org/pmd/co/logistics/PMD_0000879> <http://openenergy-platform.org/ontology/oeo/OEO_00030022>)
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/logistics/PMD_0000879> "organization"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/logistics/PMD_0000879> "An organization is an immaterial entity that has the organisation role and there exists some sort of legal framework that recognises the entity and its continued existence."@en)
AnnotationAssertion(<https://w3id.org/pmd/co/logistics/PMD_0000060> <https://w3id.org/pmd/co/logistics/PMD_0000879> "true"^^xsd:boolean)
AnnotationAssertion(<https://w3id.org/pmd/co/logistics/PMD_0001032> <https://w3id.org/pmd/co/logistics/PMD_0000879> "issue: https://github.com/materialdigital/core-ontology/issues/101")
SubClassOf(<https://w3id.org/pmd/co/logistics/PMD_0000879> <http://purl.obolibrary.org/obo/BFO_0000027>)

# Class: <https://w3id.org/pmd/co/logistics/PMD_0000881> (person)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000114> <https://w3id.org/pmd/co/logistics/PMD_0000881> <http://purl.obolibrary.org/obo/IAO_0000123>)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/logistics/PMD_0000881> "http://openenergy-platform.org/ontology/oeo/oeo-import-edits.owl"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/logistics/PMD_0000881> "person"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/logistics/PMD_0000881> "A person is a human being."@en)
AnnotationAssertion(<https://w3id.org/pmd/co/logistics/PMD_0000060> <https://w3id.org/pmd/co/logistics/PMD_0000881> "true"^^xsd:boolean)
SubClassOf(Annotation(<https://w3id.org/pmd/co/logistics/PMD_0001032> "https://github.com/materialdigital/core-ontology/issues/102") <https://w3id.org/pmd/co/logistics/PMD_0000881> <http://purl.obolibrary.org/obo/BFO_0000030>)

# Class: <https://w3id.org/pmd/co/logistics/PMD_0000909> (project)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/logistics/PMD_0000909> "Projekt"@de)
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/logistics/PMD_0000909> "project"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/logistics/PMD_0000909> "A series of goal-orientated (intent) activities and interactions to achieve a specific outcome."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/logistics/PMD_0000909> "Eine Reihe von zielorientierten (absichtlichen) Aktivitäten und Interaktionen, um ein bestimmtes Ergebnis zu erzielen."@de)
AnnotationAssertion(<https://w3id.org/pmd/co/logistics/PMD_0000060> <https://w3id.org/pmd/co/logistics/PMD_0000909> "true"^^xsd:boolean)
SubClassOf(<https://w3id.org/pmd/co/logistics/PMD_0000909> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000015> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000055> <https://w3id.org/pmd/co/logistics/PMD_0000014>)))


