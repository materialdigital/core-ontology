    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040071> "agent role held by an organization when it produces material products"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040072> <https://spec.industrialontologies.org/ontology/core/Core/SupplierRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040072> "supplier role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040072> "agent role held by a person or organization when it offers to sell or provide products or services"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040073> <https://spec.industrialontologies.org/ontology/core/Core/ServiceProviderRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040073> "service provider role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040073> "supplier role held by a person or organization when it offers to sell or provide a commercial service"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040074> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/LogisticsServiceProviderRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040074> "logistics service provider role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040074> "service provider role that is held by a business organization or person when it provides a logistics service"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040075> <https://spec.industrialontologies.org/ontology/supplychain/service/ServiceOntology/ManufacturingServiceProviderRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040075> "manufacturing service provider role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040075> "service provider role that is held by a person or business organization when it provides a manufacturing service"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040076> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/ConsigneeRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040076> "consignee role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040076> "role held by a person or business organization when it receives a shipment from a carrier and owns the shipment after the receipt"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040077> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/ConsignorRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040077> "consignor role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040077> "role held by a business organization or person when it prepares, initiates, and consigns a shipment it owns"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040078> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/DistributorRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040078> "distributor role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040078> "role held by a person or business organization when it buys some material products from a manufacturer and resells them to a wholesaler"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040079> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/RetailerRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040079> "retailer role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040079> "role held by a person or business organization when it buys products (material product) from manufacturers or wholesalers and offers them for sale to customers who are the end users of the product"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040080> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/WholesalerRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040080> "wholesaler role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040080> "role held by a person or business organization when it buys some product from a distributor and resells them to retailers"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040081> <https://spec.industrialontologies.org/ontology/core/Core/EquipmentRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040081> "equipment role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040081> "role held by a material artifact when it is planned to be involved in or is involved in carrying out some part of a planned process and that is not consumed in that planned process"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040082> <https://spec.industrialontologies.org/ontology/core/Core/MaintainableMaterialItemRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040082> "maintainable material item role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040082> "role played by an asset (engineered system or material artifact) when there is a maintenance strategy prescribing its maintenance process"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040083> <https://spec.industrialontologies.org/ontology/core/Core/MaterialComponentRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040083> "material component role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040083> "role held by a material entity when it is a proper part of another material entity or is planned to be a proper part of another material entity"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040084> <https://spec.industrialontologies.org/ontology/core/Core/MaterialProductRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040084> "material product role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040084> "role held by a material entity that is intended to be sold, or has been bought, or has been supplied"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040085> <https://spec.industrialontologies.org/ontology/core/Core/MaterialResourceRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040085> "material resource role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040085> "role played by a material entity that consists in it being available to a person or group of agents or engineered system"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040086> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/IndustrialInventoryRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040086> "industrial inventory role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040086> "role held by some material entity when it is stored by a bussiness organization and it is intended to be supplied to a customer or to be used or consumed in some product production process"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040087> <https://spec.industrialontologies.org/ontology/core/Core/RawMaterialRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040087> "raw material role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040087> "role held by a material entity when it is acquired by an organizational entity with some plan to transform or modify it into intermediate-level components or substances or into a product"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040088> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/CargoRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040088> "cargo role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040088> "role held by a material entity when it is being transported or is planned to be transported by a carrier"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040089> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/LocationRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040089> "location role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040089> "role held by a geospatial site when it is the location of some material entity at some time or the site of some process"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040090> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/ShipFromLocationRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040090> "ship from location role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040090> "location role held by a geospatial site when it is the location at which some dispatch process occures"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040091> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/ShipToLocationRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040091> "ship to location role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040091> "location role held by a geospatial site when it is the location at which some receiving process occures"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040092> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/TraceableResourceUnitRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040092> "traceable resource unit role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040092> "role held by a number of uniquely identified material entities when they participate in some supply chain processes or production processes while some agent observes them and collects information about them for future retrieval"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040093> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/LoadRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040093> "load role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040093> "traceable resource unit role held by a number of material entities that have been transferred or transported together"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040094> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/LogisticUnitRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040094> "logistic unit role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040094> "traceable resource unit role held by a number of material entities that are packaged together for transport or storage"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040095> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/LotRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040095> "lot role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040095> "traceable resource unit role held by material entities that have a shared production or transformation history"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040096> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/ShipmentRole>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040096> "shipment role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040096> "traceable resource unit role held by material entities when they undergo the same dispatch and receipt processes as prescribed by a bill of lading"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040097> <https://spec.industrialontologies.org/ontology/core/Core/BusinessProcess>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040097> "business process"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040097> "planned process which is prescribed by a plan specification with one or more objectives specified by a business organization"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040098> <https://spec.industrialontologies.org/ontology/core/Core/BuyingBusinessProcess>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040098> "buying business process"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040098> "business process wherein a financial instrument is used by an agent (buyer) to acquire ownership of a product or commercial service from another agent (seller) for the buyer itself or for another agent (customer)"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040099> <https://spec.industrialontologies.org/ontology/core/Core/CommercialService>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040099> "commercial service"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040099> "business process that consists of a service provisioning process and a consumption process"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040100> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/LogisticsService>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040100> "logistics service"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040100> "commercial service that consists of at least one transport process, packaging process, freight forwarding, or storage process"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040101> <https://spec.industrialontologies.org/ontology/core/Core/ProcuringBusinessProcess>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040101> "procuring business process"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040101> "business process that consists of buying and ensuring the supply of products or services"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040102> <https://spec.industrialontologies.org/ontology/core/Core/ProductProductionProcess>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040102> "product production process"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040102> "business process that consists of at least one manufacturing process through which raw materials and components are transformed or modified to create a material product"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040103> <https://spec.industrialontologies.org/ontology/core/Core/SellingBusinessProcess>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040103> "offering for sale business process"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040103> "business process wherein a product or commercial service is offered by an agent (seller) for another agent (buyer) to acquire ownership via a financial instrument"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040104> <https://spec.industrialontologies.org/ontology/core/Core/SupplyingBusinessProcess>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040104> "supplying business process"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040104> "business process wherein a product or service is supplied"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040105> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/ConsigningProcess>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040105> "consigning process"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040105> "business process that results in placing a material entity in the possession of some agent without changing the ownership until the material entity is sold"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040106> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/InventoryManagementProcess>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040106> "inventory management process"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040106> "business process that consists of the activities required for controlling, tracking, recording, and planning inventories"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040107> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/LogisticsProcess>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040107> "logistics process"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040107> "business process that consists of a combination of one or more transport, shipment preparation, storage or receiving processes"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040108> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/ReceivingProcess>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040108> "receiving process"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040108> "planned process in which an agent receives some material entity from another agent"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040109> <https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/SupplyChainProcess>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040109> "supply chain process"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040109> "planned process in which a supply chain plan specification is realized by a number of supply chain agents"@en-us)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000412> <https://w3id.org/pmd/co/PMD_0040110> <https://spec.industrialontologies.org/ontology/core/Core/ComputingProcess>)
