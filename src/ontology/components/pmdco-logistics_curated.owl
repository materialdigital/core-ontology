    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#comment> <https://w3id.org/pmd/co/PMD_0040005> "This role is also an indication that an organization is a sub section of another organization."@en)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040005> "department role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040005> "A department role is a role describing a personal function or position within an organization that defines responsibilities or activities in a specified context."@en)
    AnnotationAssertion(<https://w3id.org/pmd/co/logistics/PMD_0000060> <https://w3id.org/pmd/co/PMD_0040005> "true"^^<http://www.w3.org/2001/XMLSchema#boolean>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040006> "initiator role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040006> "An initiator role is a role describing the position or function responsible for starting or catalyzing a process, often related to material testing or experiments."@en)
    AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <https://w3id.org/pmd/co/PMD_0040007> "“Laboratory.” Merriam-Webster.com Dictionary, Merriam-Webster, https://www.merriam-webster.com/dictionary/laboratory. Accessed 24 Nov. 2022."@en)
