    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040007> "laboratory"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040007> "A place equipped for experimental study in a science or for testing and analysis."@en)
    AnnotationAssertion(<https://w3id.org/pmd/co/logistics/PMD_0000060> <https://w3id.org/pmd/co/PMD_0040007> "true"^^<http://www.w3.org/2001/XMLSchema#boolean>)
    AnnotationAssertion(<http://www.w3.org/2000/01/rdf-schema#label> <https://w3id.org/pmd/co/PMD_0040008> "laboratory role"@en)
    AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/co/PMD_0040008> "A laboratory role is a role specifying the functions or activities specific to experimental and analytical tasks performed in a laboratory setting."@en)
