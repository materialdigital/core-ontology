Prefix(xml:=<http://www.w3.org/XML/1998/namespace>)
Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)
Prefix(qudt:=<http://qudt.org/schema/qudt/>)
Prefix(rdfs:=<http://www.w3.org/2000/01/rdf-schema#>)
Prefix(dcterms:=<http://purl.org/dc/terms/>)


Ontology(<https://w3id.org/pmd/co/components/imports-edit.owl>
Import(<https://w3id.org/pmd/co/imports/bfo_import.owl>)
Import(<https://w3id.org/pmd/co/imports/iao_import.owl>)
Import(<https://w3id.org/pmd/co/imports/obi_import.owl>)
Import(<https://w3id.org/pmd/co/imports/ro_import.owl>)
Import(<https://w3id.org/pmd/co/imports/stato_import.owl>)
Import(<https://w3id.org/pmd/co/imports/uo_import.owl>)

Declaration(Class(obo:CHEBI_74236))
Declaration(Class(qudt:QuantityValue))
Declaration(Class(qudt:Unit))
Declaration(ObjectProperty(qudt:hasUnit))
Declaration(DataProperty(qudt:numericValue))
Declaration(AnnotationProperty(:PMD_0000060))

############################
#   Object Properties
############################

# Object Property: obo:BFO_0000117 (has occurrent part)

SubObjectPropertyOf(obo:BFO_0000117 obo:BFO_0000051)

# Object Property: obo:BFO_0000132 (occurrent part of)

SubObjectPropertyOf(Annotation(rdfs:comment "\"occurrent part of\" is not a BFO2020 temporalized relation. It just restricts the domain and range to \"occurrent\". That's why is should be OK to make it sub property of RO \"part of\"") obo:BFO_0000132 obo:BFO_0000050)

# Object Property: qudt:hasUnit (has unit)

AnnotationAssertion(dcterms:description qudt:hasUnit "This property relates a system of units with a unit of measure that is either a) defined by the system, or b) accepted for use by the system and is convertible to a unit of equivalent dimension that is defined by the system. Systems of units may distinguish between base and derived units. Base units are the units which measure the base quantities for the corresponding system of quantities. The base units are used to define units for all other quantities as products of powers of the base units. Such units are called derived units for the system."@en)
AnnotationAssertion(rdfs:isDefinedBy qudt:hasUnit <http://qudt.org/2.1/schema/qudt>)
AnnotationAssertion(rdfs:label qudt:hasUnit "has unit")
SubObjectPropertyOf(qudt:hasUnit obo:IAO_0000039)
ObjectPropertyRange(qudt:hasUnit qudt:Unit)


############################
#   Data Properties
############################

# Data Property: qudt:numericValue (numeric value)

AnnotationAssertion(rdfs:isDefinedBy qudt:numericValue <http://qudt.org/2.1/schema/qudt>)
AnnotationAssertion(rdfs:label qudt:numericValue "numeric value"@en)
SubDataPropertyOf(qudt:numericValue obo:OBI_0001937)



############################
#   Classes
############################

# Class: obo:CHEBI_74236 (polymerisation monomer)

SubClassOf(obo:CHEBI_74236 obo:BFO_0000023)

# Class: obo:NCBITaxon_9606 (homo sapiens)

AnnotationAssertion(rdfs:label obo:NCBITaxon_9606 "homo sapiens")
SubClassOf(obo:NCBITaxon_9606 obo:BFO_0000040)

# Class: obo:UO_0000000 (unit)

SubClassOf(obo:UO_0000000 obo:IAO_0000003)

# Class: qudt:QuantityValue (Quantity value)

AnnotationAssertion(rdfs:isDefinedBy qudt:QuantityValue <http://qudt.org/2.1/schema/qudt>)
AnnotationAssertion(rdfs:label qudt:QuantityValue "Quantity value")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> qudt:QuantityValue "A <i>Quantity Value</i> expresses the magnitude and kind of a quantity and is given by the product of a numerical value <code>n</code> and a unit of measure <code>U</code>. The number multiplying the unit is referred to as the numerical value of the quantity expressed in that unit. Refer to <a href=\"http://physics.nist.gov/Pubs/SP811/sec07.html\">NIST SP 811 section 7</a> for more on quantity values."@en)

# Class: qudt:Unit (Unit)

AnnotationAssertion(rdfs:isDefinedBy qudt:Unit <http://qudt.org/2.1/schema/qudt>)
AnnotationAssertion(rdfs:label qudt:Unit "Unit")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> qudt:Unit "A unit of measure, or unit, is a particular quantity value that has been chosen as a scale for measuring other quantities the same kind (more generally of equivalent dimension). 
For example, the meter is a quantity of length that has been rigorously defined and standardized by the BIPM (International Board of Weights and Measures).  Any measurement of the length can be expressed as a number multiplied by the unit meter. 
More formally, the value of a physical quantity Q with respect to a unit (U) is expressed as the scalar multiple of a real number (n) and U, as  $Q = nU$."@en)


SubObjectPropertyOf(ObjectPropertyChain(obo:BFO_0000055 obo:RO_0000059) obo:STATO_0000102)
AnnotationAssertion(obo:IAO_0000112 obo:IAO_0000098 "you might consinder EDAM formats as sublasses here http://edamontology.org/format_1915")
AnnotationAssertion(:PMD_0000060 obo:IAO_0020000 "true"^^xsd:boolean)
AnnotationAssertion(obo:IAO_0000116 obo:OBI_0000011 "PMDco : migration: https://github.com/materialdigital/core-ontology/issues/269")
AnnotationAssertion(owl:deprecated obo:OBI_0000011 "true"^^xsd:boolean)
AnnotationAssertion(rdfs:label dce:license "dc:license")
AnnotationAssertion(rdfs:label dcterms:license "dcterms:license")
)