AnnotationAssertion(rdfs:label pmdco:PMD_0080124 "acoustic capability"@en-US)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080124 "Necessary and sufficient conditions for 'acoustic capability' have not yet been formalized. The term is defined as a specific subtype of 'physical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions."@en-US)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080124 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080124 obo:BFO_0000016)

