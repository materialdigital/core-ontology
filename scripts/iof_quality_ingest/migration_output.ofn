AnnotationAssertion(rdfs:label pmdco:PMD_0080016 "Strahlungsfluss"@de)
AnnotationAssertion(rdfs:label pmdco:PMD_0080016 "radiant energy flux"@en-US)
AnnotationAssertion(obo:IAO_0000116 pmdco:PMD_0080016 "Necessary and sufficient conditions for 'radiant energy flux' have not yet been formalized. The term is defined as a specific subtype of 'physical process characteristic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Radiant_energy."@en-US)
AnnotationAssertion(pmdco:PMD_0000060 pmdco:PMD_0080016 "true"^^xsd:boolean)
SubClassOf(pmdco:PMD_0080016 pmdco:PMD_0020244)

# Class: pmdco:PMD_0080017 (temperature profile)
# Adopted from IOF: <https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TemperatureProfile>

AnnotationAssertion(rdfs:label pmdco:PMD_0080017 "temperature profile"@en-US)
