            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">magnetic ceramic</rdfs:label>
        <skos:altLabel>ferrites</skos:altLabel>
        <skos:definition xml:lang="en">electroceramic that exhibits magnetic properties, typically based on iron oxides combined with other metal oxides</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050088 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050088">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
