    <!-- https://w3id.org/pmd/co/PMD_0020117 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020117">
        <rdfs:label xml:lang="en">aggregate state solid</rdfs:label>
        <skos:definition xml:lang="en">A state where the bonds between entities transmit shear forces.</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020118 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020118">
        <rdfs:label xml:lang="en">aggregate state liquid</rdfs:label>
        <skos:definition xml:lang="en">A state where the bonds of the entities transmit no shear force.</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020119 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020119">
        <rdfs:label xml:lang="en">aggregate state gaseous</rdfs:label>
        <skos:definition xml:lang="en">A state where the entities have no bonding.</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020120 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020120">
        <rdfs:label xml:lang="en">aggregate state plasma</rdfs:label>
        <skos:definition xml:lang="en">An aggregate state where the entities are atom nuclei and have no bonds.</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020121 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020121">
        <rdfs:label xml:lang="en">aggregate state atom gas</rdfs:label>
        <skos:definition xml:lang="en">A gaseous state where the gas entities are atoms.</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020122 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020122">
        <rdfs:label xml:lang="en">aggregate state supercritical fluid</rdfs:label>
        <skos:definition xml:lang="en">A state with strong bindings between entities that do not transmit shear force.</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020123 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020123">
        <rdfs:label xml:lang="en">aggregate state mesomorphic</rdfs:label>
        <skos:definition xml:lang="en">A state where some bonds transmit shear stresses and some do not.</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020124 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020124">
        <rdfs:label xml:lang="en">aggregate state suprafluid</rdfs:label>
        <skos:definition xml:lang="en">A state with frictionless binding that transmits no shear force between entities.</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020125 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020125">
        <rdfs:label xml:lang="en">aggregate state suprasolid</rdfs:label>
        <skos:definition xml:lang="en">A state that exhibits suprafluid and solid properties.</skos:definition>
        <PMD_0000060 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</PMD_0000060>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020217 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020217">
        <rdfs:label xml:lang="en">short range order</rdfs:label>
        <skos:definition xml:lang="en">periodic arrangement of structural features up to a few entities</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020218 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020218">
        <rdfs:label xml:lang="en">medium range order</rdfs:label>
        <skos:definition xml:lang="en">periodic arrangement of structural features of many entities</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020219 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020219">
        <rdfs:label xml:lang="en">long range order</rdfs:label>
        <skos:definition xml:lang="en">periodic arrangement of structural features of virtually all entities</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/pmd/co/PMD_0020242 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/pmd/co/PMD_0020242">
        <rdfs:label xml:lang="en">no range order</rdfs:label>
        <skos:definition xml:lang="en">no periodic arrangement of structural features of entites</skos:definition>
    </owl:NamedIndividual>
    


