        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000112"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">dielectric ceramic</rdfs:label>
        <skos:definition xml:lang="en">electroceramic that serves primarily as electrical insulators due to their high dielectric constants</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050085 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050085">
        <owl:equivalentClass>
