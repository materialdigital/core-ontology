                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000112"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
