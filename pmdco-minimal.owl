                                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000825"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000546"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000111"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000112"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000825"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">electroceramic</rdfs:label>
        <skos:definition xml:lang="en">ceramic that is specifically engineered for electrical, magnetic, or superconducting applications</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050082 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050082">
        <owl:equivalentClass>
