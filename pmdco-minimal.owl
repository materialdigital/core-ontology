                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000111"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050081"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000111"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">superconducting ceramic</rdfs:label>
        <skos:definition xml:lang="en">electroceramic that exhibits zero electrical resistance below a critical temperature</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050118 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050118">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
