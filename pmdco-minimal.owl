        <rdfs:label xml:lang="en">functional glass</rdfs:label>
        <skos:comment>axiom is related to functional material</skos:comment>
        <skos:definition xml:lang="en">glass that is designed to perform specific roles beyond conventional optical applications</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050134 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050134">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000661"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000091"/>
