                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000790"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">optical glass</rdfs:label>
        <skos:comment>composition and processing chosen to achieve specified optical/mechanical parameters such as refractive index and dispersion.</skos:comment>
        <skos:definition xml:lang="en">glass manufactured for optical components</skos:definition>
        <skos:example>e.g., lenses, prisms, mirrors</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0050133 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0050133">
        <owl:equivalentClass>
