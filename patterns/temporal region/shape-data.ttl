<https://w3id.org/pmd/co/test/shape/temporal_region> rdf:type owl:Ontology .

ex:annealing_1 a process: .
ex:heat_treatment_1 a process: .
ex:period_of_annealing_1 a temporal_interval: .
ex:period_of_heat_treatment_1 a temporal_interval: . 
ex:furnace_operation_life a temporal_interval: .
ex:furnace_1 a object: .
ex:start a temporal_instant: .
ex:end a temporal_instant: .

ex:annealing_1 occupies_temporal_region: ex:period_of_annealing_1 . 
ex:heat_treatment_1 occupies_temporal_region: ex:period_of_heat_treatment_1 .
ex:period_of_heat_treatment_1 has_first_instant: ex:start . 
ex:period_of_heat_treatment_1 has_last_instant: ex:end .
ex:period_of_annealing_1 proper_temporal_part_of: ex:period_of_heat_treatment_1 .
ex:period_of_heat_treatment_1 temporal_part_of: ex:furnace_operation_life .
ex:furnace_1 exists_at: ex:furnace_operation_life .
ex:furnace_1 participates_in: ex:annealing_1 .
