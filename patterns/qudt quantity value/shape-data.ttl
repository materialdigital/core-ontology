@prefix : <https://w3id.org/pmd/co/test#> .
@prefix ex: <https://www.example.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@base <https://w3id.org/pmd/co/test#> .

<https://w3id.org/pmd/co/test/shape-qudt-quantity-value> rdf:type owl:Ontology .

@prefix has_measurement_unit_label: <http://purl.obolibrary.org/obo/IAO_0000039> .
@prefix has_specified_numeric_value: <http://purl.obolibrary.org/obo/OBI_0001937> .
@prefix measurement_unit: <http://purl.obolibrary.org/obo/IAO_0000003> .

# --- UO-based representation (classic OBI/IAO pattern) ---
# Unit is a UO individual typed as IAO measurement unit (IAO_0000003).
# Uses IAO_0000039 (has measurement unit label) and OBI_0001937 (has specified numeric value).

ex:tensile_strength_UO
    rdf:type obo:OBI_0001931 ;
    has_measurement_unit_label: <http://purl.obolibrary.org/obo/UO_0000015> ;
    has_specified_numeric_value: 450.0 .

<http://purl.obolibrary.org/obo/UO_0000015>
    rdf:type measurement_unit: .

# --- QUDT-based representation (QUDT quantity value pattern) ---
# Unit is a QUDT unit individual typed as qudt:Unit.
# Uses qudt:unit (SubPropertyOf IAO_0000039) and qudt:numericValue (SubPropertyOf OBI_0001937).
# The individual is typed as pmd:PMD_0080205 (QUDT scalar quantity value),
# which is EquivalentTo OBI_0001931 AND (qudt:unit some qudt:Unit).

ex:tensile_strength_QUDT
    rdf:type <https://w3id.org/pmd/co/PMD_0080205> ;
    qudt:unit unit:MegaPA ;
    qudt:numericValue 450.0 .

unit:MegaPA
    rdf:type qudt:Unit .
