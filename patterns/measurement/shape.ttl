@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pmd: <https://w3id.org/pmd/co/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <https://w3id.org/pmd/co/shapes/measurement/> .
@prefix : shape: .
@base shape: .

shape:
  rdf:type owl:Ontology ;
  owl:imports sh: .
  
shape:assay rdf:type sh:NodeShape ;
          sh:targetClass  <http://purl.obolibrary.org/obo/OBI_0000070> ; # obi:assay
    
    # One property pointing to the output ...
    sh:property [
        # obi:has_specified_output
        sh:path <http://purl.obolibrary.org/obo/OBI_0000299> ;  
        sh:minCount 1 ;
        #iao:measurement_datum
        sh:class <http://purl.obolibrary.org/obo/IAO_0000109> ; 
    ] ;
    # TODO: require that the output data item "is_quality_measurement_of" an SDC of the measurand
    
    # ... and one property pointing to the input
    sh:property [
        # obi:has_specified_input
        sh:path <http://purl.obolibrary.org/obo/OBI_0000293> ;  
        sh:minCount 1 ;
        #bfo:material entity
        sh:class <http://purl.obolibrary.org/obo/BFO_0000040> ;
    ] ;
    
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "property path 'has_specified_input'/'has_role' must point to the same  (role-)resource as the 'realizes' of our assay." ;
        sh:select """
            PREFIX ex: <#>
            SELECT ?this ?value
            WHERE {
                ?this <http://purl.obolibrary.org/obo/OBI_0000293>/<http://purl.obolibrary.org/obo/RO_0000087> ?value .   # walk the sequence path
                FILTER NOT EXISTS {
                    ?this <http://purl.obolibrary.org/obo/BFO_0000055> ?value .  # role must also exist via realizes
                }
            }
        """ 
    ] ;

   sh:closed false ;
   sh:ignoredProperties ( rdf:type owl:topDataProperty owl:topObjectProperty ) .


shape:object rdf:type sh:NodeShape ;
          sh:targetClass  <http://purl.obolibrary.org/obo/BFO_0000030> .