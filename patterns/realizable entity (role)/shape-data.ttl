<https://w3id.org/pmd/co/test/role> rdf:type owl:Ontology  .

ex:tensile_testing a assay: .
ex:tensile_testing has_specified_input: ex:tensile_test_piece .
# ex:tensile_testing achieves_planned_objective: ex:objective_1 .
ex:tensile_testing has_specified_output: ex:stress_strain_curve .
# ex:tensile_testing assay_measures_characteristic: ex:ultimate_tensile_strength .
ex:tensile_testing realizes: ex:plan_of_tensile_test .

 ex:stress_strain_curve a  measurement_datum: .
ex:plan_of_tensile_test a plan: .

# ex:objective_1 is_about: ex:tensile_test_piece .
ex:stress_strain_curve  is_about: ex:tensile_test_piece .

ex:tensile_test_piece a object: .
ex:tensile_test_piece has_role: ex:evaluant_role_of_test_piece .

ex:evaluant_role_of_test_piece a evaluant_role: .
ex:evaluant_role_of_test_piece has_realization: ex:tensile_testing  .

