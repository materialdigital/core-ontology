@prefix ex: <https://w3id.org/pmd/co/pattern/different_qualities_in_object_matter_microstructure/example/> .
@prefix pattern: <https://w3id.org/pmd/co/pattern/different_qualities_in_object_matter_microstructure/> .
@prefix : <https://w3id.org/pmd/co/pattern/different_qualities_in_object_matter_microstructure/> .
@base <https://w3id.org/pmd/co/pattern/different_qualities_in_object_matter_microstructure/> .

@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

@prefix pmd: <https://w3id.org/pmd/co/> .
@prefix ro: <http://purl.obolibrary.org/obo/RO_> .
@prefix bfo: <http://purl.obolibrary.org/obo/BFO_> .
@prefix obi: <http://purl.obolibrary.org/obo/OBI_> .
@prefix iao: <http://purl.obolibrary.org/obo/IAO_> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Object_pellet_O_and_portion_of_Ceramic_C
    rdf:type bfo:0000030 ;
    ro:0000086 ex:mass_of_pellet ;
    bfo:0000051 ex:portion_of_polycrystalline_ceramic_C , ex:O_bulk , ex:O_surface ;
    rdfs:label "Object pellet O & portion of Ceramic C" .

ex:mass_of_pellet
    rdf:type pmd:PMD_0020133 ;
    rdfs:label "mass of pellet" .

ex:portion_of_polycrystalline_ceramic_C
    rdf:type pmd:PMD_0000546 ;
    ro:0000086 ex:composition_of_ceramic_C ;
    ro:0000091 ex:ceramic_C_property ;
    rdfs:label "portion of polycrystalline ceramic C" .


ex:composition_of_ceramic_C
    rdf:type pmd:PMD_0000551 ;
    rdfs:label "composition of ceramic C" .

ex:ceramic_C_property
    rdf:type pmd:PMD_0000848 ;
    rdfs:label "ceramic C property" .

ex:O_bulk
    rdf:type pmd:PMD_0000538 ;
    ro:0000091 ex:softer_bulk_property ;
    bfo:0000051 ex:B_crystal_form_in_bulk ;
    rdfs:label "O-bulk" .

ex:O_surface
    rdf:type pmd:PMD_0000965 ;
    ro:0000091 ex:harder_surface_property ;
    bfo:0000051 ex:B_crystal_form_in_surface ;
    rdfs:label "O-surface" .

ex:softer_bulk_property
    rdf:type pmd:PMD_0000773 ;
    rdfs:label "softer bulk property" .

ex:harder_surface_property
    rdf:type pmd:PMD_0000773 ;
    rdfs:label "harder surface property" .

ex:B_crystal_form_in_bulk
    rdf:type pmd:PMD_0000663 ;
    ro:0000091 ex:property_of_B_crystal_for_bulk ;
    rdfs:label "B-crystal-form in bulk" .

ex:B_crystal_form_in_surface
    rdf:type pmd:PMD_0000663 ;
    ro:0000091 ex:property_of_B_crystal_for_surface ;
    rdfs:label "B-crystal-form in surface" .

ex:property_of_B_crystal_for_bulk
    rdf:type pmd:PMD_0000848 ;
    rdfs:label "property of B-crystal" .

ex:property_of_B_crystal_for_surface
    rdf:type pmd:PMD_0000848 ;
    rdfs:label "property of B-crystal" .

ex:volume_proportion_of_B_crystal_in_bulk
    rdf:type pmd:PMD_0020104 ;
    pmd:PMD_0025999 ex:B_crystal_form_in_bulk , ex:O_bulk ;
    rdfs:label "volume proportion of B-crystal in bulk" .

ex:B_Crys_Vol_fraction_in_bulk
    rdf:type pmd:PMD_0025997 ;
    obi:0001927 ex:volume_proportion_of_B_crystal_in_bulk ;
    iao:0000039 ex:mass_volume_percentage_for_bulk ;
    obi:0001937 "5"^^xsd:decimal ;
    rdfs:label "B-Crys.Vol.fraction in bulk" .

ex:mass_volume_percentage_for_bulk
    rdfs:label "mass volume percentage" .


ex:volume_proportion_of_B_crystal_in_surface
    rdf:type pmd:PMD_0020104 ;
    pmd:PMD_0025999 ex:B_crystal_form_in_surface , ex:O_surface ;
    rdfs:label "volume proportion of B-crystal in surface" .


ex:B_Crys_Vol_fraction_in_surface
    rdf:type pmd:PMD_0025997 ;
    obi:0001927 ex:volume_proportion_of_B_crystal_in_surface ;
    iao:0000039 ex:mass_volume_percentage_for_surface ;
    obi:0001937 "80"^^xsd:decimal ;
    rdfs:label "B-Crys.Vol.fraction in surface" .

ex:mass_volume_percentage_for_surface
    rdfs:label "mass volume percentage" .
