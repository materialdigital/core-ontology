co:PMD_0020121 rdf:type owl:NamedIndividual ;
               rdfs:label "aggregate state atom gas"@en ;
               skos:definition "A gaseous state where the gas entities are atoms."@en ;
               co:PMD_0000060 "true"^^xsd:boolean .


