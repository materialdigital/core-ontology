###  https://w3id.org/pmd/co/PMD_0020244
co:PMD_0020244 rdf:type owl:Class ;
               rdfs:subClassOf co:PMD_0020226 ;
               rdfs:label "flux"@en ;
               skos:definition "a flow of a unit-entity per unit time"@en .


