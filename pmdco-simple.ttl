co:PMD_0020239 rdf:type owl:Class ;
               rdfs:subClassOf co:PMD_0020213 ;
               rdfs:label "small angle grain boundary"@en ;
               skos:definition "a grain boundary whose adjacent crystalls have a small angle of misalignment"@en .


