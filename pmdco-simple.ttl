co:PMD_0020125 rdf:type owl:NamedIndividual ;
               rdfs:label "aggregate state suprasolid"@en ;
               skos:definition "A state that exhibits suprafluid and solid properties."@en ;
               co:PMD_0000060 "true"^^xsd:boolean .


